<ResourceDictionary
	xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
	<ResourceDictionary.MergedDictionaries>
		<ResourceDictionary
			Source="/BrukerLC.Styling;component/Colors/Brushes.xaml" />
		<ResourceDictionary
			Source="/BrukerLC.Styling;component/Converters/Converters.xaml" />
		<ResourceDictionary
			Source="/BrukerLC.Styling;component/VectorGraphics/Shapes.xaml" />
		<ResourceDictionary
			Source="/BrukerLC.Styling;component/Settings/Typography.xaml" />
		<ResourceDictionary
			Source="/BrukerLC.Styling;component/Styles/FrameworkElement.xaml" />
	</ResourceDictionary.MergedDictionaries>
	<Style
		x:Key="DefaultPumpControlStyle"
		TargetType="{x:Type PumpControl}"
		BasedOn="{StaticResource FrameworkElementStyle}">
		<Setter
			Property="BorderBrush"
			Value="#FFA9A9A9" />
		<Setter
			Property="Background"
			Value="#FFD3D3D3" />
		<Setter
			Property="Foreground"
			Value="#FFA9A9A9" />
		<Setter
			Property="PumpControl.Throughput"
			Value="{Binding Throughput}" />
		<Setter
			Property="PumpControl.ThroughputUnit"
			Value="{Binding ThroughputUnit}" />
		<Setter
			Property="PumpControl.Pressure"
			Value="{Binding Pressure}" />
		<Setter
			Property="PumpControl.PressureUnit"
			Value="{Binding PressureUnit}" />
		<Setter
			Property="PumpControl.VolumeLeft"
			Value="{Binding VolumeLeft}" />
		<Setter
			Property="PumpControl.VolumeUnit"
			Value="{Binding VolumeUnit}" />
		<Setter
			Property="PumpControl.FillLevel"
			Value="{Binding FillLevel}" />
		<Setter
			Property="APValidation.HasError"
			Value="{Binding HasError}" />
		<Setter
			Property="APValidation.ErrorMessage"
			Value="{Binding ErrorMessage}" />
		<Setter
			Property="APActivatable.IsActive"
			Value="{Binding IsActive}" />
		<Setter
			Property="APActivatable.ActiveBrush"
			Value="{Binding ActiveBrush}" />
		<Setter
			Property="APSignalizable.IsSignalize"
			Value="{Binding IsSignalize, FallbackValue=False}" />
		<Setter
			Property="APSignalizable.SignalizeBrush"
			Value="{Binding SignalizeBrush, FallbackValue=Transparent}" />
		<Setter
			Property="Width"
			Value="53" />
		<Setter
			Property="VerticalContentAlignment"
			Value="Center" />
		<Setter
			Property="HorizontalContentAlignment"
			Value="Center" />
		<Setter
			Property="BorderThickness"
			Value="3" />
		<Setter
			Property="PumpControl.CornerRadius"
			Value="10" />
		<Setter
			Property="FontSize"
			Value="{StaticResource 10FontSize}" />
		<Setter
			Property="Template">
			<Setter.Value>
				<ControlTemplate
					TargetType="{x:Type PumpControl}">
					<StackPanel>
						<Grid
							x:Name="PumpLabels"
							Margin="10"
							VerticalAlignment="{TemplateBinding Control.VerticalContentAlignment}">
							<Grid.RowDefinitions>
								<RowDefinition />
								<RowDefinition />
							</Grid.RowDefinitions>
							<Grid
								x:Name="ThroughtputLabels"
								VerticalAlignment="{TemplateBinding Control.VerticalContentAlignment}">
								<Grid.RowDefinitions>
									<RowDefinition />
									<RowDefinition />
								</Grid.RowDefinitions>
								<ContentPresenter
									HorizontalAlignment="Center"
									TextElement.Foreground="#FF000000">
									<ContentPresenter.Content>
										<MultiBinding
											Converter="{StaticResource FlowSensorDecimalPlacesConverter}">
											<Binding
												Path="Throughput"
												RelativeSource="{RelativeSource TemplatedParent}" />
											<Binding
												Path="ThroughputUnit"
												RelativeSource="{RelativeSource TemplatedParent}" />
										</MultiBinding>
									</ContentPresenter.Content>
								</ContentPresenter>
								<TextBlock
									Grid.Row="1"
									HorizontalAlignment="Left"
									Margin="0,0,0,0"
									Foreground="{TemplateBinding Control.Foreground}"
									Text="{TemplateBinding PumpControl.ThroughputUnit}" />
							</Grid>
							<Grid
								x:Name="PressureLabels"
								Row="1"
								Margin="0 8 0 0"
								VerticalAlignment="{TemplateBinding Control.VerticalContentAlignment}">
								<Grid.RowDefinitions>
									<RowDefinition />
									<RowDefinition />
								</Grid.RowDefinitions>
								<ContentPresenter
									HorizontalAlignment="{TemplateBinding Control.HorizontalContentAlignment}"
									TextElement.Foreground="#FF000000"
									Content="{TemplateBinding Pressure, ConverterParameter=' 0;-0', Converter={StaticResource DecimalPlacesConverter}}" />
								<TextBlock
									Grid.Row="1"
									HorizontalAlignment="{TemplateBinding Control.HorizontalContentAlignment}"
									Foreground="{TemplateBinding Control.Foreground}"
									Text="{TemplateBinding PumpControl.PressureUnit}" />
							</Grid>
						</Grid>
						<Grid
							Height="102">
							<Grid.ColumnDefinitions>
								<ColumnDefinition
									Width="Auto" />
								<ColumnDefinition
									Width="Auto" />
							</Grid.ColumnDefinitions>
							<Grid.RowDefinitions>
								<RowDefinition />
								<RowDefinition
									Height="Auto" />
							</Grid.RowDefinitions>
							<Border
								x:Name="PumpBorder"
								Grid.Column="1"
								Width="52"
								BorderBrush="{TemplateBinding Control.BorderBrush}"
								BorderThickness="{TemplateBinding Control.BorderThickness}"
								CornerRadius="{TemplateBinding PumpControl.CornerRadius}"
								Background="{TemplateBinding Foreground, Converter={StaticResource ColorOpacityConverter}}">
								<Grid>
									<Grid.RowDefinitions>
										<RowDefinition
											Height="Auto" />
										<RowDefinition
											Height="Auto" />
									</Grid.RowDefinitions>
									<Border
										Margin="0 -1 0 0"
										Background="{TemplateBinding Control.Foreground}"
										CornerRadius="{TemplateBinding PumpControl.CornerRadius}"
										Height="{Binding FillLevel, ConverterParameter=90, Converter={StaticResource HeightToPrecentageConverter}}" />
									<Path
										Grid.Row="1"
										Margin="0 2 0 0"
										HorizontalAlignment="Center"
										Fill="#FF808080"
										Data="{StaticResource PumpGeometry}" />
								</Grid>
							</Border>
							<Border
								x:Name="OuterBorder"
								Grid.Column="1"
								Background="#00FFFFFF"
								BorderBrush="{TemplateBinding Control.BorderBrush}"
								BorderThickness="{TemplateBinding Control.BorderThickness}"
								CornerRadius="{TemplateBinding PumpControl.CornerRadius}" />
						</Grid>
						<Grid
							x:Name="VolumeLabels"
							Row="1"
							Margin="0 2 0 0"
							VerticalAlignment="{TemplateBinding Control.VerticalContentAlignment}"
							Visibility="{Binding IsService, Converter={StaticResource VisibilityConverter}}">
							<Grid.ColumnDefinitions>
								<ColumnDefinition />
								<ColumnDefinition
									Width="Auto" />
							</Grid.ColumnDefinitions>
							<ContentPresenter
								HorizontalAlignment="Right"
								TextElement.Foreground="#FF000000"
								Content="{TemplateBinding VolumeLeft, ConverterParameter=' 0.00;-0.00', Converter={StaticResource VolumeDecimalPlacesConverter}}" />
							<TextBlock
								Grid.Column="1"
								Margin="2,0,0,0"
								HorizontalAlignment="Left"
								Foreground="{TemplateBinding Control.Foreground}"
								Text="{TemplateBinding PumpControl.VolumeUnit}" />
						</Grid>
					</StackPanel>
				</ControlTemplate>
			</Setter.Value>
		</Setter>
		<Style.Triggers>
			<Trigger
				Property="APActivatable.IsActive"
				Value="True">
				<Setter
					Property="Foreground"
					Value="{Binding (APActivatable.ActiveBrush), RelativeSource={RelativeSource Self}}" />
				<Setter
					Property="BorderBrush"
					Value="{StaticResource LightGrayBrush}" />
			</Trigger>
			<Trigger
				Property="APValidation.HasError"
				Value="True">
				<Setter
					Property="Foreground"
					Value="{StaticResource GrayBrush}" />
				<Setter
					Property="Background"
					Value="{StaticResource LightGrayBrush}" />
				<Setter
					Property="BorderBrush"
					Value="{StaticResource ErrorBrush}" />
			</Trigger>
			<Trigger
				Property="APSignalizable.IsSignalize"
				Value="True">
				<Setter
					Property="Foreground"
					Value="{Binding (APSignalizable.SignalizeBrush), RelativeSource={RelativeSource Self}}" />
			</Trigger>
		</Style.Triggers>
	</Style>
	<Style
		x:Key="PumpControlAStyle"
		TargetType="{x:Type PumpControl}"
		BasedOn="{StaticResource DefaultPumpControlStyle}">
		<Style.Triggers>
			<Trigger
				Property="APActivatable.IsActive"
				Value="True">
				<Setter
					Property="Foreground"
					Value="{Binding (APActivatable.ActiveBrush), RelativeSource={RelativeSource Self}}" />
				<Setter
					Property="BorderBrush"
					Value="{StaticResource LightGrayBrush}" />
				<Setter
					Property="Background"
					Value="{StaticResource BlueBrush_30}" />
			</Trigger>
		</Style.Triggers>
	</Style>
	<Style
		x:Key="PumpControlBStyle"
		TargetType="{x:Type PumpControl}"
		BasedOn="{StaticResource DefaultPumpControlStyle}">
		<Style.Triggers>
			<Trigger
				Property="APActivatable.IsActive"
				Value="True">
				<Setter
					Property="Foreground"
					Value="{Binding (APActivatable.ActiveBrush), RelativeSource={RelativeSource Self}}" />
				<Setter
					Property="BorderBrush"
					Value="{StaticResource LightGrayBrush}" />
				<Setter
					Property="Background"
					Value="{StaticResource BlueBrush_30}" />
			</Trigger>
		</Style.Triggers>
	</Style>
</ResourceDictionary>
