<ResourceDictionary
	xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:attached="clr-namespace:BrukerLC.Utils.Attached;assembly=BrukerLC.Utils">
	<ResourceDictionary.MergedDictionaries>
		<ResourceDictionary
			Source="/BrukerLC.Styling;component/Colors/Brushes.xaml" />
		<ResourceDictionary
			Source="/BrukerLC.Styling;component/Converters/Converters.xaml" />
		<ResourceDictionary
			Source="/BrukerLC.Styling;component/Styles/FrameworkElement.xaml" />
	</ResourceDictionary.MergedDictionaries>
	<Style
		x:Key="DefaultLinkControlStyle"
		TargetType="{x:Type LinkControl}"
		BasedOn="{StaticResource FrameworkElementStyle}">
		<Setter
			Property="attached:APActivatable.IsActive"
			Value="{Binding IsActive, FallbackValue=False}" />
		<Setter
			Property="attached:APActivatable.ActiveBrush"
			Value="{Binding ActiveBrush, FallbackValue=Blue}" />
		<Setter
			Property="attached:APValidation.HasError"
			Value="{Binding HasError, FallbackValue=False}" />
		<Setter
			Property="attached:APValidation.ErrorMessage"
			Value="{Binding ErrorMessage}" />
		<Setter
			Property="attached:APSignalizable.IsSignalize"
			Value="{Binding IsSignalize, FallbackValue=False}" />
		<Setter
			Property="attached:APSignalizable.SignalizeBrush"
			Value="{Binding SignalizeBrush, FallbackValue=Transparent}" />
		<Setter
			Property="attached:APVisibleEnableable.IsVisible"
			Value="{Binding IsVisible, FallbackValue=True}" />
		<Setter
			Property="attached:APVisibleEnableable.IsNearTransparent"
			Value="{Binding IsNearTransparent, FallbackValue=False}" />
		<Setter
			Property="Background"
			Value="{StaticResource LightGrayBrush}" />
		<Setter
			Property="Template">
			<Setter.Value>
				<ControlTemplate
					TargetType="{x:Type LinkControl}">
					<DockPanel
						Name="linkPanel">
						<Canvas
							DockPanel.Dock="Top"
							Visibility="{Binding Path=(attached:APVisibleEnableable.IsVisible), Converter={StaticResource VisibilityConverter}, RelativeSource={RelativeSource Self}}"
							Opacity="{Binding Path=(attached:APVisibleEnableable.IsNearTransparent), Converter={StaticResource OpacityConverter}, RelativeSource={RelativeSource Self}}">
							<FrameworkElement.ContextMenu>
								<ContextMenu
									Visibility="{Binding IsEditable, Converter={StaticResource VisibilityConverter}}">
									<MenuItem
										Header="Edit..."
										Command="{Binding EditLinkCommand}"
										CommandParameter="{Binding Header}" />
								</ContextMenu>
							</FrameworkElement.ContextMenu>
							<Path
								Data="{TemplateBinding LinkControl.PathData}"
								Stroke="{TemplateBinding Control.Background}"
								StrokeThickness="6" />
							<Ellipse
								Canvas.Left="{TemplateBinding LinkControl.EndPointLeft}"
								Canvas.Top="{TemplateBinding LinkControl.EndPointTop}"
								Width="6"
								Height="6"
								Fill="{TemplateBinding Control.Background}" />
							<Ellipse
								x:Name="StartPoint"
								Canvas.Left="{TemplateBinding LinkControl.StartPointLeft}"
								Canvas.Top="{TemplateBinding LinkControl.StartPointTop}"
								Width="6"
								Height="6"
								Fill="{TemplateBinding Control.Background}"
								Visibility="Collapsed" />
						</Canvas>
						<Popup
							Placement="Mouse"
							PopupAnimation="Fade"
							HorizontalOffset="15"
							VerticalOffset="-50"
							PlacementTarget="{Binding ElementName=linkPanel}"
							Visibility="{Binding IsPopupVisible, Converter={StaticResource VisibilityConverter}}">
							<FrameworkElement.Style>
								<Style
									TargetType="{x:Type Popup}">
									<Style.Triggers>
										<DataTrigger
											Value="True"
											Binding="{Binding IsMouseOver, ElementName=linkPanel}">
											<TriggerBase.EnterActions>
												<BeginStoryboard>
													<Storyboard>
														<BooleanAnimationUsingKeyFrames
															Storyboard.TargetProperty="IsOpen"
															FillBehavior="HoldEnd">
															<DiscreteBooleanKeyFrame
																KeyTime="0:0:0"
																Value="True" />
														</BooleanAnimationUsingKeyFrames>
													</Storyboard>
												</BeginStoryboard>
											</TriggerBase.EnterActions>
											<TriggerBase.ExitActions>
												<BeginStoryboard>
													<Storyboard>
														<BooleanAnimationUsingKeyFrames
															Storyboard.TargetProperty="IsOpen"
															FillBehavior="HoldEnd">
															<DiscreteBooleanKeyFrame
																KeyTime="0:0:0"
																Value="False" />
														</BooleanAnimationUsingKeyFrames>
													</Storyboard>
												</BeginStoryboard>
											</TriggerBase.ExitActions>
										</DataTrigger>
									</Style.Triggers>
								</Style>
							</FrameworkElement.Style>
							<Border
								BorderThickness="1"
								SnapsToDevicePixels="True">
								<UIElement.Effect>
									<DropShadowEffect
										ShadowDepth="4" />
								</UIElement.Effect>
								<Border.Background>
									<LinearGradientBrush
										StartPoint="0,0"
										EndPoint="0,1">
										<GradientBrush.GradientStops>
											<GradientStopCollection>
												<GradientStop
													Color="White"
													Offset="0.0" />
												<GradientStop
													Color="LightGray"
													Offset="1.0" />
											</GradientStopCollection>
										</GradientBrush.GradientStops>
									</LinearGradientBrush>
								</Border.Background>
								<Border.BorderBrush>
									<SolidColorBrush
										Color="#FF888888" />
								</Border.BorderBrush>
								<Grid
									Row="1"
									Margin="2">
									<Grid.ColumnDefinitions>
										<ColumnDefinition />
										<ColumnDefinition />
									</Grid.ColumnDefinitions>
									<Grid.RowDefinitions>
										<RowDefinition
											Height="Auto" />
										<RowDefinition
											Height="Auto" />
										<RowDefinition
											Height="Auto" />
									</Grid.RowDefinitions>
									<TextBlock
										Grid.ColumnSpan="2"
										Style="{StaticResource titleText}"
										Text="{Binding Header}" />
									<TextBlock
										Grid.Row="1"
										Text="Length:"
										Style="{StaticResource nameText}" />
									<Grid
										Row="1"
										Column="1">
										<Grid.ColumnDefinitions>
											<ColumnDefinition
												Width="Auto" />
											<ColumnDefinition
												Width="Auto" />
										</Grid.ColumnDefinitions>
										<TextBlock
											Style="{StaticResource dataText}"
											Text="{Binding Length}" />
										<TextBlock
											Grid.Column="1"
											Style="{StaticResource nameText}"
											Text="{Binding LengthUnit}" />
									</Grid>
									<TextBlock
										Grid.Row="2"
										Text="ID:"
										Style="{StaticResource nameText}" />
									<Grid
										Row="2"
										Column="1">
										<Grid.ColumnDefinitions>
											<ColumnDefinition
												Width="Auto" />
											<ColumnDefinition
												Width="Auto" />
										</Grid.ColumnDefinitions>
										<TextBlock
											Style="{StaticResource dataText}"
											Text="{Binding ID}" />
										<TextBlock
											Grid.Column="1"
											Style="{StaticResource nameText}"
											Text="{Binding IDUnit}" />
									</Grid>
								</Grid>
							</Border>
						</Popup>
					</DockPanel>
					<ControlTemplate.Triggers>
						<Trigger
							Property="LinkControl.StartPoint"
							Value="True">
							<Setter
								TargetName="StartPoint"
								Property="Visibility"
								Value="Visible" />
						</Trigger>
					</ControlTemplate.Triggers>
				</ControlTemplate>
			</Setter.Value>
		</Setter>
		<Style.Triggers>
			<Trigger
				Property="attached:APActivatable.IsActive"
				Value="True">
				<Setter
					Property="Background"
					Value="{Binding (APActivatable.ActiveBrush), RelativeSource={RelativeSource Self}}" />
				<Setter
					Property="Panel.ZIndex"
					Value="1000" />
			</Trigger>
			<Trigger
				Property="attached:APValidation.HasError"
				Value="True">
				<Setter
					Property="Background"
					Value="{StaticResource ErrorBrush}" />
				<Setter
					Property="Panel.ZIndex"
					Value="1000" />
			</Trigger>
			<Trigger
				Property="attached:APSignalizable.IsSignalize"
				Value="True">
				<Setter
					Property="Background"
					Value="{Binding (APSignalizable.SignalizeBrush), RelativeSource={RelativeSource Self}}" />
				<Setter
					Property="Panel.ZIndex"
					Value="1000" />
			</Trigger>
			<Trigger
				Property="attached:APVisibleEnableable.IsVisible"
				Value="False">
				<Setter
					Property="Visibility"
					Value="Hidden" />
			</Trigger>
			<Trigger
				Property="UIElement.IsMouseOver"
				Value="True">
				<Setter
					Property="attached:APActivatable.IsActive"
					Value="True" />
				<Setter
					Property="Panel.ZIndex"
					Value="1000" />
			</Trigger>
		</Style.Triggers>
	</Style>
</ResourceDictionary>
