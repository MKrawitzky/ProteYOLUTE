<ResourceDictionary
	xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:attached="clr-namespace:BrukerLC.Utils.Attached;assembly=BrukerLC.Utils">
	<ResourceDictionary.MergedDictionaries>
		<ResourceDictionary
			Source="/BrukerLC.Styling;component/Colors/Brushes.xaml" />
		<ResourceDictionary
			Source="/BrukerLC.Styling;component/VectorGraphics/Shapes.xaml" />
		<ResourceDictionary
			Source="/BrukerLC.Styling;component/Styles/FrameworkElement.xaml" />
		<ResourceDictionary
			Source="/BrukerLC.Styling;component/Converters/Converters.xaml" />
	</ResourceDictionary.MergedDictionaries>
	<Style
		x:Key="DefaultTrapControlStyle"
		TargetType="{x:Type TrapControl}"
		BasedOn="{StaticResource FrameworkElementStyle}">
		<Setter
			Property="attached:APActivatable.IsActive"
			Value="{Binding IsActive, FallbackValue=False}" />
		<Setter
			Property="attached:APActivatable.ActiveBrush"
			Value="{Binding ActiveBrush, FallbackValue=Blue}" />
		<Setter
			Property="attached:APValidation.HasError"
			Value="{Binding HasError}" />
		<Setter
			Property="attached:APValidation.ErrorMessage"
			Value="{Binding ErrorMessage}" />
		<Setter
			Property="attached:APSignalizable.IsSignalize"
			Value="{Binding IsSignalize, FallbackValue=False}" />
		<Setter
			Property="attached:APSignalizable.SignalizeBrush"
			Value="{Binding SignalizeBrush, FallbackValue=Transparent}" />
		<Setter
			Property="attached:APVisibleEnableable.IsVisible"
			Value="{Binding IsVisible, FallbackValue=True}" />
		<Setter
			Property="attached:APVisibleEnableable.IsNearTransparent"
			Value="{Binding IsNearTransparent, FallbackValue=False}" />
		<Setter
			Property="BorderThickness"
			Value="1" />
		<Setter
			Property="HorizontalContentAlignment"
			Value="Center" />
		<Setter
			Property="BorderBrush"
			Value="{StaticResource DarkGrayBrush}" />
		<Setter
			Property="Background"
			Value="{StaticResource LightGrayBrush}" />
		<Setter
			Property="Template">
			<Setter.Value>
				<ControlTemplate
					TargetType="{x:Type TrapControl}">
					<DockPanel
						Name="linkPanel">
						<Grid
							DockPanel.Dock="Top"
							Visibility="{Binding Path=(attached:APVisibleEnableable.IsVisible), Converter={StaticResource VisibilityConverter}, RelativeSource={RelativeSource Self}}"
							Opacity="{Binding Path=(attached:APVisibleEnableable.IsNearTransparent), Converter={StaticResource OpacityConverter}, RelativeSource={RelativeSource Self}}">
							<FrameworkElement.ContextMenu>
								<ContextMenu
									Visibility="{Binding IsEditable, Converter={StaticResource VisibilityConverter}}">
									<MenuItem
										Header="Edit..."
										Command="{Binding EditLinkCommand}"
										CommandParameter="{Binding Header}" />
								</ContextMenu>
							</FrameworkElement.ContextMenu>
							<Grid.RowDefinitions>
								<RowDefinition
									Height="Auto" />
								<RowDefinition />
								<RowDefinition
									Height="Auto" />
							</Grid.RowDefinitions>
							<Path
								HorizontalAlignment="{TemplateBinding Control.HorizontalContentAlignment}"
								Fill="{TemplateBinding Control.BorderBrush}"
								Data="{StaticResource TrapGeometry}" />
							<Border
								Grid.Row="1"
								Width="6"
								Height="25"
								Margin="0 3"
								HorizontalAlignment="{TemplateBinding Control.HorizontalContentAlignment}"
								Background="{TemplateBinding Control.Background}"
								BorderBrush="{TemplateBinding Control.BorderBrush}"
								BorderThickness="{TemplateBinding Control.BorderThickness}" />
							<Border
								Grid.Row="1"
								Width="15"
								Height="4"
								VerticalAlignment="Top"
								Background="{TemplateBinding Control.Background}"
								BorderBrush="{TemplateBinding Control.BorderBrush}"
								BorderThickness="{TemplateBinding Control.BorderThickness}"
								CornerRadius="1" />
							<Border
								Grid.Row="1"
								Width="15"
								Height="4"
								VerticalAlignment="Bottom"
								Background="{TemplateBinding Control.Background}"
								BorderBrush="{TemplateBinding Control.BorderBrush}"
								BorderThickness="{TemplateBinding Control.BorderThickness}"
								CornerRadius="1" />
							<Path
								Grid.Row="2"
								HorizontalAlignment="{TemplateBinding Control.HorizontalContentAlignment}"
								Fill="{TemplateBinding Control.BorderBrush}"
								RenderTransformOrigin=".5,.5"
								Data="{StaticResource TrapGeometry}">
								<UIElement.RenderTransform>
									<RotateTransform
										Angle="180" />
								</UIElement.RenderTransform>
							</Path>
						</Grid>
						<Popup
							Placement="Mouse"
							PopupAnimation="Fade"
							HorizontalOffset="15"
							VerticalOffset="-50"
							PlacementTarget="{Binding ElementName=linkPanel}"
							Visibility="{Binding IsPopupVisible, Converter={StaticResource VisibilityConverter}}">
							<FrameworkElement.Style>
								<Style
									TargetType="{x:Type Popup}">
									<Style.Triggers>
										<DataTrigger
											Value="True"
											Binding="{Binding IsMouseOver, ElementName=linkPanel}">
											<TriggerBase.EnterActions>
												<BeginStoryboard>
													<Storyboard>
														<BooleanAnimationUsingKeyFrames
															Storyboard.TargetProperty="IsOpen"
															FillBehavior="HoldEnd">
															<DiscreteBooleanKeyFrame
																KeyTime="0:0:0"
																Value="True" />
														</BooleanAnimationUsingKeyFrames>
													</Storyboard>
												</BeginStoryboard>
											</TriggerBase.EnterActions>
											<TriggerBase.ExitActions>
												<BeginStoryboard>
													<Storyboard>
														<BooleanAnimationUsingKeyFrames
															Storyboard.TargetProperty="IsOpen"
															FillBehavior="HoldEnd">
															<DiscreteBooleanKeyFrame
																KeyTime="0:0:0"
																Value="False" />
														</BooleanAnimationUsingKeyFrames>
													</Storyboard>
												</BeginStoryboard>
											</TriggerBase.ExitActions>
										</DataTrigger>
									</Style.Triggers>
								</Style>
							</FrameworkElement.Style>
							<Border
								BorderThickness="1"
								SnapsToDevicePixels="True">
								<UIElement.Effect>
									<DropShadowEffect
										ShadowDepth="4" />
								</UIElement.Effect>
								<Border.Background>
									<LinearGradientBrush
										StartPoint="0,0"
										EndPoint="0,1">
										<GradientBrush.GradientStops>
											<GradientStopCollection>
												<GradientStop
													Color="White"
													Offset="0.0" />
												<GradientStop
													Color="LightGray"
													Offset="1.0" />
											</GradientStopCollection>
										</GradientBrush.GradientStops>
									</LinearGradientBrush>
								</Border.Background>
								<Border.BorderBrush>
									<SolidColorBrush
										Color="#FF888888" />
								</Border.BorderBrush>
								<Grid
									Row="1"
									Margin="2">
									<Grid.ColumnDefinitions>
										<ColumnDefinition />
										<ColumnDefinition />
									</Grid.ColumnDefinitions>
									<Grid.RowDefinitions>
										<RowDefinition
											Height="Auto" />
										<RowDefinition
											Height="Auto" />
										<RowDefinition
											Height="Auto" />
									</Grid.RowDefinitions>
									<TextBlock
										Grid.ColumnSpan="2"
										Style="{StaticResource titleText}"
										Text="{Binding Header}" />
									<TextBlock
										Grid.Row="1"
										Text="Length:"
										Style="{StaticResource nameText}" />
									<Grid
										Row="1"
										Column="1">
										<Grid.ColumnDefinitions>
											<ColumnDefinition
												Width="Auto" />
											<ColumnDefinition
												Width="Auto" />
										</Grid.ColumnDefinitions>
										<TextBlock
											Style="{StaticResource dataText}"
											Text="{Binding Length}" />
										<TextBlock
											Grid.Column="1"
											Style="{StaticResource nameText}"
											Text="{Binding LengthUnit}" />
									</Grid>
									<TextBlock
										Grid.Row="2"
										Text="ID:"
										Style="{StaticResource nameText}" />
									<Grid
										Row="2"
										Column="1">
										<Grid.ColumnDefinitions>
											<ColumnDefinition
												Width="Auto" />
											<ColumnDefinition
												Width="Auto" />
										</Grid.ColumnDefinitions>
										<TextBlock
											Style="{StaticResource dataText}"
											Text="{Binding ID}" />
										<TextBlock
											Grid.Column="1"
											Style="{StaticResource nameText}"
											Text="{Binding IDUnit}" />
									</Grid>
								</Grid>
							</Border>
						</Popup>
					</DockPanel>
				</ControlTemplate>
			</Setter.Value>
		</Setter>
		<Style.Triggers>
			<Trigger
				Property="attached:APActivatable.IsActive"
				Value="True">
				<Setter
					Property="Background"
					Value="{Binding (APActivatable.ActiveBrush), RelativeSource={RelativeSource Self}}" />
			</Trigger>
			<Trigger
				Property="attached:APValidation.HasError"
				Value="True">
				<Setter
					Property="Background"
					Value="{StaticResource ErrorBrush}" />
			</Trigger>
			<Trigger
				Property="attached:APSignalizable.IsSignalize"
				Value="True">
				<Setter
					Property="Background"
					Value="{Binding (APSignalizable.SignalizeBrush), RelativeSource={RelativeSource Self}}" />
			</Trigger>
			<Trigger
				Property="attached:APVisibleEnableable.IsVisible"
				Value="False">
				<Setter
					Property="Visibility"
					Value="Hidden" />
			</Trigger>
		</Style.Triggers>
	</Style>
</ResourceDictionary>
