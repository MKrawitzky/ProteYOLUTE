<ResourceDictionary
	xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:attached="clr-namespace:BrukerLC.Utils.Attached;assembly=BrukerLC.Utils">
	<ResourceDictionary.MergedDictionaries>
		<ResourceDictionary
			Source="/BrukerLC.Styling;component/Colors/Brushes.xaml" />
		<ResourceDictionary
			Source="/BrukerLC.Styling;component/Styles/FrameworkElement.xaml" />
		<ResourceDictionary
			Source="/BrukerLC.Styling;component/Converters/Converters.xaml" />
		<ResourceDictionary
			Source="/BrukerLC.Styling;component/VectorGraphics/Shapes.xaml" />
	</ResourceDictionary.MergedDictionaries>
	<Style
		x:Key="DefaultOutputControlStyle"
		TargetType="{x:Type OutputControl}"
		BasedOn="{StaticResource FrameworkElementStyle}">
		<Setter
			Property="BorderThickness"
			Value="1" />
		<Setter
			Property="HorizontalContentAlignment"
			Value="Center" />
		<Setter
			Property="VerticalContentAlignment"
			Value="Center" />
		<Setter
			Property="attached:APActivatable.IsActive"
			Value="{Binding IsActive, FallbackValue=False}" />
		<Setter
			Property="attached:APActivatable.ActiveBrush"
			Value="{Binding ActiveBrush, FallbackValue=Blue}" />
		<Setter
			Property="attached:APValidation.HasError"
			Value="{Binding HasError}" />
		<Setter
			Property="attached:APValidation.ErrorMessage"
			Value="{Binding ErrorMessage}" />
		<Setter
			Property="attached:APSignalizable.IsSignalize"
			Value="{Binding IsSignalize, FallbackValue=False}" />
		<Setter
			Property="attached:APSignalizable.SignalizeBrush"
			Value="{Binding SignalizeBrush, FallbackValue=Transparent}" />
		<Setter
			Property="attached:APVisibleEnableable.IsVisible"
			Value="{Binding IsVisible, FallbackValue=True}" />
		<Setter
			Property="attached:APVisibleEnableable.IsNearTransparent"
			Value="{Binding IsNearTransparent, FallbackValue=False}" />
		<Setter
			Property="Background"
			Value="{StaticResource LightGrayBrush}" />
		<Setter
			Property="BorderBrush"
			Value="{StaticResource DarkGrayBrush}" />
		<Setter
			Property="Width"
			Value="102" />
		<Setter
			Property="Height"
			Value="16" />
		<Setter
			Property="Template">
			<Setter.Value>
				<ControlTemplate
					TargetType="{x:Type OutputControl}">
					<Grid
						Visibility="{Binding Path=(attached:APVisibleEnableable.IsVisible), Converter={StaticResource VisibilityConverter}, RelativeSource={RelativeSource Self}}"
						Opacity="{Binding Path=(attached:APVisibleEnableable.IsNearTransparent), Converter={StaticResource OpacityConverter}, RelativeSource={RelativeSource Self}}">
						<Grid.ColumnDefinitions>
							<ColumnDefinition
								Width="8" />
							<ColumnDefinition
								Width="40" />
							<ColumnDefinition
								Width="8" />
							<ColumnDefinition
								Width="10" />
							<ColumnDefinition
								Width="16" />
						</Grid.ColumnDefinitions>
						<Path
							Fill="{TemplateBinding Control.BorderBrush}"
							RenderTransformOrigin=".5,.5"
							Data="{StaticResource TrapGeometry}">
							<UIElement.RenderTransform>
								<TransformGroup>
									<RotateTransform
										Angle="-90" />
									<TranslateTransform
										X="2" />
								</TransformGroup>
							</UIElement.RenderTransform>
						</Path>
						<Grid
							Column="1"
							Margin="-8 0">
							<Border
								Height="6"
								Margin="4 0"
								VerticalAlignment="{TemplateBinding Control.VerticalContentAlignment}"
								Background="{TemplateBinding Control.Background}"
								BorderBrush="{TemplateBinding Control.BorderBrush}"
								BorderThickness="{TemplateBinding Control.BorderThickness}" />
							<Border
								Width="5"
								Height="15"
								HorizontalAlignment="Left"
								Background="{TemplateBinding Control.Background}"
								BorderBrush="{TemplateBinding Control.BorderBrush}"
								BorderThickness="{TemplateBinding Control.BorderThickness}"
								CornerRadius="1" />
							<Border
								Width="5"
								Height="15"
								HorizontalAlignment="Right"
								Background="{TemplateBinding Control.Background}"
								BorderBrush="{TemplateBinding Control.BorderBrush}"
								BorderThickness="{TemplateBinding Control.BorderThickness}"
								CornerRadius="1" />
						</Grid>
						<Path
							Grid.Column="2"
							Fill="{TemplateBinding Control.BorderBrush}"
							RenderTransformOrigin=".5,.5"
							Data="{StaticResource TrapGeometry}">
							<UIElement.RenderTransform>
								<TransformGroup>
									<RotateTransform
										Angle="90" />
									<TranslateTransform
										X="-2" />
								</TransformGroup>
							</UIElement.RenderTransform>
						</Path>
						<Border
							Grid.Column="3"
							Height="6"
							Margin="2.5 0 -1 0"
							VerticalAlignment="Center"
							Background="{TemplateBinding Control.Background}" />
						<Polygon
							Grid.Column="4"
							Fill="{TemplateBinding Control.Background}"
							Points="0,0 16,8 0,16" />
					</Grid>
				</ControlTemplate>
			</Setter.Value>
		</Setter>
		<Style.Triggers>
			<Trigger
				Property="attached:APActivatable.IsActive"
				Value="True">
				<Setter
					Property="Background"
					Value="{Binding (APActivatable.ActiveBrush), RelativeSource={RelativeSource Self}}" />
			</Trigger>
			<Trigger
				Property="attached:APValidation.HasError"
				Value="True">
				<Setter
					Property="Background"
					Value="{StaticResource ErrorBrush}" />
			</Trigger>
			<Trigger
				Property="attached:APSignalizable.IsSignalize"
				Value="True">
				<Setter
					Property="Background"
					Value="{Binding (APSignalizable.SignalizeBrush), RelativeSource={RelativeSource Self}}" />
			</Trigger>
			<Trigger
				Property="attached:APVisibleEnableable.IsVisible"
				Value="False">
				<Setter
					Property="Visibility"
					Value="Hidden" />
			</Trigger>
		</Style.Triggers>
	</Style>
</ResourceDictionary>
