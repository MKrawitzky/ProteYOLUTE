<ResourceDictionary
	xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
	<ResourceDictionary.MergedDictionaries>
		<ResourceDictionary
			Source="/BrukerLC.Styling;component/Colors/Brushes.xaml" />
	</ResourceDictionary.MergedDictionaries>
	<Style
		x:Key="DefaultTooltipStyle"
		TargetType="{x:Type ToolTip}">
		<Setter
			Property="Template">
			<Setter.Value>
				<ControlTemplate
					TargetType="{x:Type ToolTip}">
					<Border
						BorderThickness="2"
						CornerRadius="2"
						Background="{StaticResource WhiteBrush}"
						BorderBrush="{StaticResource ErrorBrush}">
						<ContentPresenter
							Margin="4" />
					</Border>
				</ControlTemplate>
			</Setter.Value>
		</Setter>
	</Style>
	<Style
		x:Key="FrameworkElementStyle"
		TargetType="{x:Type FrameworkElement}">
		<Setter
			Property="FrameworkElement.ToolTip">
			<Setter.Value>
				<ToolTip
					Style="{StaticResource DefaultTooltipStyle}"
					Content="{Binding ErrorMessage}" />
			</Setter.Value>
		</Setter>
		<Style.Triggers>
			<DataTrigger
				Binding="{Binding ErrorMessage}"
				Value="{x:Null}">
				<Setter
					Property="FrameworkElement.ToolTip"
					Value="{x:Null}" />
			</DataTrigger>
		</Style.Triggers>
	</Style>
	<Style
		x:Key="titleText"
		TargetType="{x:Type TextBlock}">
		<Setter
			Property="FontWeight"
			Value="Normal" />
		<Setter
			Property="FontSize"
			Value="12" />
		<Setter
			Property="FontStyle"
			Value="Normal" />
		<Setter
			Property="HorizontalAlignment"
			Value="left" />
		<Setter
			Property="Foreground"
			Value="#0071BC" />
		<Setter
			Property="Margin"
			Value="4,0,4,8" />
	</Style>
	<Style
		x:Key="nameText"
		TargetType="{x:Type TextBlock}">
		<Setter
			Property="FontWeight"
			Value="Normal" />
		<Setter
			Property="FontSize"
			Value="11" />
		<Setter
			Property="Margin"
			Value="4" />
		<Style.Triggers>
			<Trigger
				Property="IsEnabled"
				Value="False">
				<Setter
					Property="UIElement.Opacity"
					Value="0.5" />
			</Trigger>
		</Style.Triggers>
	</Style>
	<Style
		x:Key="dataText"
		TargetType="{x:Type TextBlock}">
		<Setter
			Property="FontWeight"
			Value="Normal" />
		<Setter
			Property="FontSize"
			Value="11" />
		<Setter
			Property="Background"
			Value="#FFFFFFFF" />
		<Setter
			Property="Margin"
			Value="4" />
		<Setter
			Property="HorizontalAlignment"
			Value="Stretch" />
		<Setter
			Property="TextBlock.Padding"
			Value="1" />
		<Setter
			Property="MinWidth"
			Value="40" />
		<Style.Triggers>
			<Trigger
				Property="IsEnabled"
				Value="False">
				<Setter
					Property="UIElement.Opacity"
					Value="0.5" />
			</Trigger>
		</Style.Triggers>
	</Style>
</ResourceDictionary>
