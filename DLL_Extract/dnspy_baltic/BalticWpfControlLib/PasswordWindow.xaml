<Window
	x:Class="BalticWpfControlLib.PasswordWindow"
	xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
	xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
	xmlns:local="clr-namespace:BalticWpfControlLib"
	xmlns:syncfusion="http://schemas.syncfusion.com/wpf"
	Title="Service Access"
	SizeToContent="WidthAndHeight"
	ResizeMode="NoResize"
	WindowStartupLocation="CenterOwner">
	<Grid
		Margin="8,4,8,2"
		Width="240">
		<Grid.RowDefinitions>
			<RowDefinition
				Height="Auto" />
			<RowDefinition
				Height="Auto" />
			<RowDefinition
				Height="Auto" />
		</Grid.RowDefinitions>
		<syncfusion:SfTextInputLayout
			x:Name="idInputLayout"
			Hint="ID"
			HelperText="A new ID has been generated"
			MinWidth="140"
			IsHitTestVisible="False"
			HasError="{Binding IsError}">
			<TextBox
				IsReadOnly="True"
				Foreground="{Binding ElementName=idInputLayout, Path=Foreground, Mode=TwoWay}"
				Text="{Binding ID}" />
		</syncfusion:SfTextInputLayout>
		<syncfusion:SfTextInputLayout
			x:Name="pwdInputLayout"
			Grid.Row="1"
			Hint="Password"
			Margin="0,8,0,0"
			HelperText="Enter the password that matches the ID"
			MinWidth="140"
			Foreground="{Binding ElementName=pwdInputLayout, Path=Foreground, Mode=TwoWay}"
			HasError="{Binding IsError}"
			ErrorText="{Binding ErrorNotifyText}">
			<PasswordBox
				x:Name="pswdBox"
				PasswordChar="*" />
		</syncfusion:SfTextInputLayout>
		<StackPanel
			Orientation="Horizontal"
			Grid.Row="2"
			HorizontalAlignment="Right"
			VerticalAlignment="Bottom">
			<Button
				Name="btnOK"
				Content="OK"
				Width="75"
				Height="22"
				IsDefault="True"
				Margin="0,8,8,4"
				Click="btnOK_Click" />
			<Button
				Content="Cancel"
				Width="75"
				Height="22"
				Margin="0,8,0,4"
				IsCancel="True" />
		</StackPanel>
	</Grid>
</Window>
