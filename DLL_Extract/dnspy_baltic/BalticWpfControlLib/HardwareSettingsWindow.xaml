<Window
	x:Class="BalticWpfControlLib.HardwareSettingsWindow"
	xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:utilities="clr-namespace:BalticWpfControlLib.Utilities"
	Title="Bruker Hardware Settings"
	ResizeMode="NoResize"
	SizeToContent="WidthAndHeight"
	Background="{DynamicResource {x:Static SystemColors.ControlBrushKey}}"
	WindowStartupLocation="CenterScreen"
	ShowInTaskbar="False"
	xmlns:balticwpfcontrollib="clr-namespace:BalticWpfControlLib"
	Closing="Window_Closing"
	KeyDown="Window_KeyDown">
	<Grid>
		<Grid
			Name="gridSettings">
			<Grid.RowDefinitions>
				<RowDefinition
					Height="*" />
				<RowDefinition
					Height="Auto" />
			</Grid.RowDefinitions>
			<StackPanel
				Orientation="Horizontal"
				Grid.Row="1"
				HorizontalAlignment="Right"
				VerticalAlignment="Bottom">
				<Button
					Name="btnOK"
					Content="OK"
					Width="75"
					Height="22"
					IsDefault="True"
					Margin="0,8,8,4"
					Click="btnOK_Click" />
				<Button
					Name="btnCanel"
					Content="Cancel"
					Width="75"
					Height="22"
					Margin="0,8,4,4"
					IsCancel="True" />
			</StackPanel>
		</Grid>
	</Grid>
</Window>
