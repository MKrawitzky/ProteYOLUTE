<UserControl
    x:Class="BalticWpfControlLib.Controls.LiveDashboardPanel"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:BalticWpfControlLib.Controls"
    Background="#FF1A1A2E">

    <UserControl.Resources>
        <Style x:Key="MetricLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#FF8888AA"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style x:Key="MetricValue" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#FF00FF88"/>
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="HorizontalAlignment" Value="Right"/>
        </Style>
        <Style x:Key="MetricUnit" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#FF666666"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="3,0,0,0"/>
        </Style>
        <Style x:Key="CardBorder" TargetType="Border">
            <Setter Property="Background" Value="#FF12121A"/>
            <Setter Property="BorderBrush" Value="#FF1E1E2E"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="12"/>
            <Setter Property="Margin" Value="4"/>
        </Style>
        <Style x:Key="CardTitle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#FF8888AA"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
            <Setter Property="TextTransform" Value=""/>
        </Style>
        <Style x:Key="AlertBorder" TargetType="Border">
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="Margin" Value="0,2"/>
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <Grid Margin="4">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Row 0: Pressure & Flow Cards -->
            <UniformGrid Grid.Row="0" Columns="2">
                <!-- Pressure Card -->
                <Border Style="{StaticResource CardBorder}">
                    <StackPanel>
                        <TextBlock Text="PRESSURE" Style="{StaticResource CardTitle}"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Ch A" Style="{StaticResource MetricLabel}"/>
                            <TextBlock Grid.Row="0" Grid.Column="1" x:Name="txtPressureA" Text="--" Style="{StaticResource MetricValue}"/>
                            <TextBlock Grid.Row="0" Grid.Column="2" Text="bar" Style="{StaticResource MetricUnit}"/>
                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Ch B" Style="{StaticResource MetricLabel}" Margin="0,4,0,0"/>
                            <TextBlock Grid.Row="1" Grid.Column="1" x:Name="txtPressureB" Text="--" Style="{StaticResource MetricValue}" Margin="0,4,0,0"/>
                            <TextBlock Grid.Row="1" Grid.Column="2" Text="bar" Style="{StaticResource MetricUnit}" Margin="3,4,0,0"/>
                        </Grid>
                        <!-- Mini pressure chart -->
                        <Border Background="#FF0D0D15" CornerRadius="4" Margin="0,8,0,0" Height="80">
                            <Canvas x:Name="canvasPressure" ClipToBounds="True"/>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- Flow Card -->
                <Border Style="{StaticResource CardBorder}">
                    <StackPanel>
                        <TextBlock Text="FLOW" Style="{StaticResource CardTitle}"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Ch A" Style="{StaticResource MetricLabel}"/>
                            <TextBlock Grid.Row="0" Grid.Column="1" x:Name="txtFlowA" Text="--" Style="{StaticResource MetricValue}"/>
                            <TextBlock Grid.Row="0" Grid.Column="2" Text="µL/min" Style="{StaticResource MetricUnit}"/>
                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Ch B" Style="{StaticResource MetricLabel}" Margin="0,4,0,0"/>
                            <TextBlock Grid.Row="1" Grid.Column="1" x:Name="txtFlowB" Text="--" Style="{StaticResource MetricValue}" Margin="0,4,0,0"/>
                            <TextBlock Grid.Row="1" Grid.Column="2" Text="µL/min" Style="{StaticResource MetricUnit}" Margin="3,4,0,0"/>
                        </Grid>
                        <Border Background="#FF0D0D15" CornerRadius="4" Margin="0,8,0,0" Height="80">
                            <Canvas x:Name="canvasFlow" ClipToBounds="True"/>
                        </Border>
                    </StackPanel>
                </Border>
            </UniformGrid>

            <!-- Row 1: Smart Column & Trap -->
            <UniformGrid Grid.Row="1" Columns="2">
                <!-- Smart Column -->
                <Border Style="{StaticResource CardBorder}">
                    <StackPanel>
                        <TextBlock Text="SMART COLUMN" Style="{StaticResource CardTitle}"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Text="Column" Style="{StaticResource MetricLabel}"/>
                            <TextBlock Grid.Row="0" Grid.Column="1" x:Name="txtColumnName" Text="--" Foreground="#FFE0E0E0" FontSize="13" HorizontalAlignment="Right"/>
                            <TextBlock Grid.Row="1" Text="Performance" Style="{StaticResource MetricLabel}" Margin="0,4,0,0"/>
                            <TextBlock Grid.Row="1" Grid.Column="1" x:Name="txtColumnScore" Text="--%" Style="{StaticResource MetricValue}" FontSize="15" Margin="0,4,0,0"/>
                            <TextBlock Grid.Row="2" Text="Injections" Style="{StaticResource MetricLabel}" Margin="0,4,0,0"/>
                            <TextBlock Grid.Row="2" Grid.Column="1" x:Name="txtColumnInj" Text="--" Foreground="#FFE0E0E0" FontSize="13" HorizontalAlignment="Right" Margin="0,4,0,0"/>
                            <TextBlock Grid.Row="3" Text="Remaining" Style="{StaticResource MetricLabel}" Margin="0,4,0,0"/>
                            <TextBlock Grid.Row="3" Grid.Column="1" x:Name="txtColumnRemain" Text="--" Foreground="#FFE0E0E0" FontSize="13" HorizontalAlignment="Right" Margin="0,4,0,0"/>
                        </Grid>
                        <!-- Performance bar -->
                        <Border Background="#FF1A1A2A" CornerRadius="3" Height="6" Margin="0,8,0,0">
                            <Border x:Name="barColumn" Background="#FF00FF88" CornerRadius="3" HorizontalAlignment="Left" Width="0"/>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- Smart Trap -->
                <Border Style="{StaticResource CardBorder}">
                    <StackPanel>
                        <TextBlock Text="SMART TRAP" Style="{StaticResource CardTitle}"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Text="Trap" Style="{StaticResource MetricLabel}"/>
                            <TextBlock Grid.Row="0" Grid.Column="1" x:Name="txtTrapName" Text="--" Foreground="#FFE0E0E0" FontSize="13" HorizontalAlignment="Right"/>
                            <TextBlock Grid.Row="1" Text="Performance" Style="{StaticResource MetricLabel}" Margin="0,4,0,0"/>
                            <TextBlock Grid.Row="1" Grid.Column="1" x:Name="txtTrapScore" Text="--%" Style="{StaticResource MetricValue}" FontSize="15" Margin="0,4,0,0"/>
                            <TextBlock Grid.Row="2" Text="Injections" Style="{StaticResource MetricLabel}" Margin="0,4,0,0"/>
                            <TextBlock Grid.Row="2" Grid.Column="1" x:Name="txtTrapInj" Text="--" Foreground="#FFE0E0E0" FontSize="13" HorizontalAlignment="Right" Margin="0,4,0,0"/>
                            <TextBlock Grid.Row="3" Text="Health" Style="{StaticResource MetricLabel}" Margin="0,4,0,0"/>
                            <TextBlock Grid.Row="3" Grid.Column="1" x:Name="txtTrapHealth" Text="--" Foreground="#FFE0E0E0" FontSize="13" HorizontalAlignment="Right" Margin="0,4,0,0"/>
                        </Grid>
                        <Border Background="#FF1A1A2A" CornerRadius="3" Height="6" Margin="0,8,0,0">
                            <Border x:Name="barTrap" Background="#FF00FF88" CornerRadius="3" HorizontalAlignment="Left" Width="0"/>
                        </Border>
                    </StackPanel>
                </Border>
            </UniformGrid>

            <!-- Row 2: Gradient Progress & Valve State -->
            <UniformGrid Grid.Row="2" Columns="2">
                <!-- Gradient Progress -->
                <Border Style="{StaticResource CardBorder}">
                    <StackPanel>
                        <TextBlock Text="GRADIENT" Style="{StaticResource CardTitle}"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Text="%B" Style="{StaticResource MetricLabel}"/>
                            <TextBlock Grid.Row="0" Grid.Column="1" x:Name="txtPercentB" Text="--%" Style="{StaticResource MetricValue}" FontSize="22"/>
                            <TextBlock Grid.Row="1" Text="Progress" Style="{StaticResource MetricLabel}" Margin="0,4,0,0"/>
                            <TextBlock Grid.Row="1" Grid.Column="1" x:Name="txtGradientPct" Text="--%" Foreground="#FF4488FF" FontSize="15" HorizontalAlignment="Right" Margin="0,4,0,0"/>
                            <TextBlock Grid.Row="2" Text="State" Style="{StaticResource MetricLabel}" Margin="0,4,0,0"/>
                            <TextBlock Grid.Row="2" Grid.Column="1" x:Name="txtSystemState" Text="Idle" Foreground="#FF8888AA" FontSize="13" HorizontalAlignment="Right" Margin="0,4,0,0"/>
                        </Grid>
                        <!-- Gradient bar -->
                        <Border Background="#FF1A1A2A" CornerRadius="3" Height="8" Margin="0,8,0,0">
                            <Border x:Name="barGradient" CornerRadius="3" HorizontalAlignment="Left" Width="0">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                        <GradientStop Color="#FF4488FF" Offset="0"/>
                                        <GradientStop Color="#FFE94560" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                            </Border>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- Valve State -->
                <Border Style="{StaticResource CardBorder}">
                    <StackPanel>
                        <TextBlock Text="VALVES" Style="{StaticResource CardTitle}"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Text="Valve A" Style="{StaticResource MetricLabel}"/>
                            <TextBlock Grid.Row="0" Grid.Column="1" x:Name="txtValveA" Text="--" Foreground="#FF4488FF" FontSize="13" HorizontalAlignment="Right"/>
                            <TextBlock Grid.Row="1" Text="Valve B" Style="{StaticResource MetricLabel}" Margin="0,3,0,0"/>
                            <TextBlock Grid.Row="1" Grid.Column="1" x:Name="txtValveB" Text="--" Foreground="#FF4488FF" FontSize="13" HorizontalAlignment="Right" Margin="0,3,0,0"/>
                            <TextBlock Grid.Row="2" Text="Injection" Style="{StaticResource MetricLabel}" Margin="0,3,0,0"/>
                            <TextBlock Grid.Row="2" Grid.Column="1" x:Name="txtValveI" Text="--" Foreground="#FFFFAA00" FontSize="13" HorizontalAlignment="Right" Margin="0,3,0,0"/>
                            <TextBlock Grid.Row="3" Text="Trap" Style="{StaticResource MetricLabel}" Margin="0,3,0,0"/>
                            <TextBlock Grid.Row="3" Grid.Column="1" x:Name="txtValveT" Text="--" Foreground="#FF00FF88" FontSize="13" HorizontalAlignment="Right" Margin="0,3,0,0"/>
                        </Grid>
                    </StackPanel>
                </Border>
            </UniformGrid>

            <!-- Row 3: System Counters -->
            <Border Grid.Row="3" Style="{StaticResource CardBorder}">
                <StackPanel>
                    <TextBlock Text="SYSTEM HEALTH" Style="{StaticResource CardTitle}"/>
                    <UniformGrid Columns="4">
                        <StackPanel HorizontalAlignment="Center" Margin="4">
                            <TextBlock x:Name="txtTotalRuns" Text="0" Foreground="#FFE94560" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center"/>
                            <TextBlock Text="Runs" Foreground="#FF666666" FontSize="10" HorizontalAlignment="Center"/>
                        </StackPanel>
                        <StackPanel HorizontalAlignment="Center" Margin="4">
                            <TextBlock x:Name="txtTotalInj" Text="0" Foreground="#FFE94560" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center"/>
                            <TextBlock Text="Injections" Foreground="#FF666666" FontSize="10" HorizontalAlignment="Center"/>
                        </StackPanel>
                        <StackPanel HorizontalAlignment="Center" Margin="4">
                            <TextBlock x:Name="txtPumpHours" Text="0" Foreground="#FFE94560" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center"/>
                            <TextBlock Text="Pump Hrs" Foreground="#FF666666" FontSize="10" HorizontalAlignment="Center"/>
                        </StackPanel>
                        <StackPanel HorizontalAlignment="Center" Margin="4">
                            <TextBlock x:Name="txtValveSwitches" Text="0" Foreground="#FFE94560" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center"/>
                            <TextBlock Text="Valve Sw" Foreground="#FF666666" FontSize="10" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </UniformGrid>
                </StackPanel>
            </Border>

            <!-- Row 4: Active Alerts -->
            <Border Grid.Row="4" Style="{StaticResource CardBorder}">
                <StackPanel>
                    <TextBlock Text="ACTIVE ALERTS" Style="{StaticResource CardTitle}"/>
                    <StackPanel x:Name="alertsPanel">
                        <Border Style="{StaticResource AlertBorder}" Background="#FF001133" BorderBrush="#FF4488FF" BorderThickness="1,0,0,0">
                            <TextBlock Text="System ready — no active alerts" Foreground="#FF4488FF" FontSize="12"/>
                        </Border>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>
    </ScrollViewer>
</UserControl>
