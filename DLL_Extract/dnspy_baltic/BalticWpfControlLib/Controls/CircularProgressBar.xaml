<UserControl
	x:Class="BalticWpfControlLib.Controls.CircularProgressBar"
	xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
	xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
	xmlns:local="clr-namespace:BalticWpfControlLib.Controls"
	Height="Auto"
	Width="Auto"
	Background="#00FFFFFF"
	IsVisibleChanged="HandleVisibleChanged">
	<Grid
		x:Name="LayoutRoot"
		Background="#00FFFFFF"
		ToolTip="Searching...."
		HorizontalAlignment="Center"
		VerticalAlignment="Center">
		<Canvas
			RenderTransformOrigin="0.5,0.5"
			HorizontalAlignment="Center"
			VerticalAlignment="Center"
			Width="120"
			Height="120"
			Loaded="HandleLoaded"
			Unloaded="HandleUnloaded">
			<Ellipse
				x:Name="C0"
				Width="20"
				Height="20"
				Canvas.Left="0"
				Canvas.Top="0"
				Stretch="Fill"
				Fill="#FF4682B4"
				Opacity="1.0" />
			<Ellipse
				x:Name="C1"
				Width="20"
				Height="20"
				Canvas.Left="0"
				Canvas.Top="0"
				Stretch="Fill"
				Fill="#FF4682B4"
				Opacity="0.9" />
			<Ellipse
				x:Name="C2"
				Width="20"
				Height="20"
				Canvas.Left="0"
				Canvas.Top="0"
				Stretch="Fill"
				Fill="#FF4682B4"
				Opacity="0.8" />
			<Ellipse
				x:Name="C3"
				Width="20"
				Height="20"
				Canvas.Left="0"
				Canvas.Top="0"
				Stretch="Fill"
				Fill="#FF4682B4"
				Opacity="0.7" />
			<Ellipse
				x:Name="C4"
				Width="20"
				Height="20"
				Canvas.Left="0"
				Canvas.Top="0"
				Stretch="Fill"
				Fill="#FF4682B4"
				Opacity="0.6" />
			<Ellipse
				x:Name="C5"
				Width="20"
				Height="20"
				Canvas.Left="0"
				Canvas.Top="0"
				Stretch="Fill"
				Fill="#FF4682B4"
				Opacity="0.5" />
			<Ellipse
				x:Name="C6"
				Width="20"
				Height="20"
				Canvas.Left="0"
				Canvas.Top="0"
				Stretch="Fill"
				Fill="#FF4682B4"
				Opacity="0.4" />
			<Ellipse
				x:Name="C7"
				Width="20"
				Height="20"
				Canvas.Left="0"
				Canvas.Top="0"
				Stretch="Fill"
				Fill="#FF4682B4"
				Opacity="0.3" />
			<Ellipse
				x:Name="C8"
				Width="20"
				Height="20"
				Canvas.Left="0"
				Canvas.Top="0"
				Stretch="Fill"
				Fill="#FF4682B4"
				Opacity="0.2" />
			<UIElement.RenderTransform>
				<RotateTransform
					x:Name="SpinnerRotate"
					Angle="0" />
			</UIElement.RenderTransform>
		</Canvas>
	</Grid>
</UserControl>
