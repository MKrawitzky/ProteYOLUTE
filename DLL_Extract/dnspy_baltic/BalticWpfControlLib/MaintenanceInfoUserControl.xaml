<UserControl
	x:Class="BalticWpfControlLib.MaintenanceInfoUserControl"
	xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
	xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
	xmlns:utilities="clr-namespace:BalticWpfControlLib.Utilities"
	xmlns:local="clr-namespace:BalticWpfControlLib"
	xmlns:lc="clr-namespace:Bruker.Lc.Maintenance;assembly=Bruker.Lc">
	<UIElement.CommandBindings>
		<CommandBinding
			Command="{x:Static local:MaintenanceInfoUserControl.ResetCommand}"
			Executed="ResetBinding_Executed" />
	</UIElement.CommandBindings>
	<Expander
		ExpandDirection="Down"
		Header="{Binding Path=Component}">
		<HeaderedContentControl.HeaderTemplate>
			<DataTemplate>
				<TextBlock
					FontWeight="Bold"
					Text="{Binding}" />
			</DataTemplate>
		</HeaderedContentControl.HeaderTemplate>
		<StackPanel>
			<FrameworkElement.Resources>
				<ResourceDictionary>
					<utilities:MaintenanceInfoValueConverter
						x:Key="MaintenanceInfoValueConverter" />
					<utilities:BoolToGroupEndMarginConverter
						x:Key="boolToGroupEndMarginConverter" />
					<utilities:MaintenanceCounterToVisibilityConverter
						x:Key="MaintenanceCounterToVisibilityConverter" />
					<utilities:MaintenanceItemToVisibilityConverter
						x:Key="MaintenanceItemToVisibilityConverter" />
				</ResourceDictionary>
			</FrameworkElement.Resources>
			<ItemsControl
				Grid.IsSharedSizeScope="True"
				KeyboardNavigation.IsTabStop="False"
				ItemsSource="{Binding Path=InfoItems, UpdateSourceTrigger=PropertyChanged}">
				<ItemsControl.ItemTemplate>
					<DataTemplate>
						<Grid>
							<UIElement.Visibility>
								<MultiBinding
									Converter="{StaticResource MaintenanceItemToVisibilityConverter}">
									<Binding
										Path="IsService" />
									<Binding
										Path="DataContext.IsAppService"
										RelativeSource="{RelativeSource AncestorType={x:Type local:MaintenanceInfoUserControl}}" />
								</MultiBinding>
							</UIElement.Visibility>
							<Grid.ColumnDefinitions>
								<ColumnDefinition
									SharedSizeGroup="Name" />
								<ColumnDefinition
									SharedSizeGroup="Value" />
								<ColumnDefinition
									SharedSizeGroup="Reset" />
								<ColumnDefinition />
							</Grid.ColumnDefinitions>
							<TextBlock
								Grid.Column="0"
								Margin="4,4,4,0"
								Text="{Binding Path=Name, StringFormat={}{0}:}" />
							<StackPanel
								Orientation="Horizontal"
								Grid.Column="1">
								<TextBlock
									Margin="4,4,4,0">
									<TextBlock.Text>
										<MultiBinding
											Converter="{StaticResource MaintenanceInfoValueConverter}">
											<Binding
												Path="Value" />
											<Binding
												Path="Format" />
										</MultiBinding>
									</TextBlock.Text>
								</TextBlock>
								<TextBlock
									Text="{Binding Path=Unit}"
									Margin="{Binding Path=IsGroupEnd, Converter='{StaticResource boolToGroupEndMarginConverter}'}" />
							</StackPanel>
							<Button
								Grid.Column="2"
								VerticalContentAlignment="Center"
								Command="{x:Static local:MaintenanceInfoUserControl.ResetCommand}"
								CommandParameter="{Binding}">
								<Image
									Source="Images/reset_20.png" />
								<UIElement.Visibility>
									<MultiBinding
										Converter="{StaticResource MaintenanceCounterToVisibilityConverter}">
										<Binding />
										<Binding
											Path="DataContext.IsAppService"
											RelativeSource="{RelativeSource AncestorType={x:Type local:MaintenanceInfoUserControl}}" />
									</MultiBinding>
								</UIElement.Visibility>
								<FrameworkElement.ToolTip>
									<ToolTip
										ContentStringFormat="Reset '{0}'"
										Content="{Binding Path=Name}" />
								</FrameworkElement.ToolTip>
							</Button>
						</Grid>
					</DataTemplate>
				</ItemsControl.ItemTemplate>
			</ItemsControl>
		</StackPanel>
	</Expander>
</UserControl>
