<UserControl
	x:Class="BalticWpfControlLib.LCUserControl"
	xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
	xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
	xmlns:local="clr-namespace:BalticWpfControlLib"
	xmlns:utilities="clr-namespace:BalticWpfControlLib.Utilities"
	xmlns:controls="clr-namespace:BalticWpfControlLib.Controls"
	Loaded="UserControl_Loaded"
	Unloaded="UserControl_UnLoaded">
	<FrameworkElement.Resources>
		<ResourceDictionary>
			<ResourceDictionary.MergedDictionaries>
				<ResourceDictionary
					Source="/BrukerLC.Styling;component/LookAndFeel.xaml" />
				<ResourceDictionary
					Source="Resources/MyResourceDictionary.xaml" />
				<ResourceDictionary
					Source="Themes/ImageButton.xaml" />
				<ResourceDictionary
					Source="Resources/BrukerIcons.xaml" />
			</ResourceDictionary.MergedDictionaries>
		</ResourceDictionary>
	</FrameworkElement.Resources>
	<DockPanel
		VerticalAlignment="Stretch"
		HorizontalAlignment="Stretch"
		Background="{DynamicResource {x:Static SystemColors.ControlBrushKey}}"
		LastChildFill="True">
		<Border
			BorderBrush="#0071BC"
			BorderThickness="1"
			Margin="8,8,8,8"
			VerticalAlignment="Stretch"
			DockPanel.Dock="Bottom">
			<Grid>
				<FrameworkElement.Resources>
					<ResourceDictionary
						Source="Resources/MyResourceDictionary.xaml" />
				</FrameworkElement.Resources>
				<Grid.ColumnDefinitions>
					<ColumnDefinition
						Width="*" />
					<ColumnDefinition
						Width="Auto" />
				</Grid.ColumnDefinitions>
				<Border
					Name="bdrScriptAction"
					Grid.Row="0"
					BorderBrush="#0071BC"
					BorderThickness="0"
					Margin="0,4,0,0"
					VerticalAlignment="Top"
					Visibility="Hidden">
					<Grid>
						<Grid.ColumnDefinitions>
							<ColumnDefinition
								Width="Auto" />
							<ColumnDefinition
								Width="*" />
							<ColumnDefinition
								Width="Auto" />
						</Grid.ColumnDefinitions>
						<Label
							Grid.Column="0"
							VerticalContentAlignment="Center"
							Content="Progress"
							Margin="8,0,0,0" />
						<ProgressBar
							Name="progScriptAction"
							Grid.Column="1"
							Height="18"
							Margin="0,0,8,0"
							Minimum="0"
							Maximum="100" />
						<TextBlock
							Name="tbScriptAction"
							Grid.Column="1"
							Height="18"
							Margin="8,0,8,0"
							VerticalAlignment="Center" />
						<StackPanel
							Grid.Column="2"
							Orientation="Horizontal"
							VerticalAlignment="Center">
							<Button
								Name="btnStop"
								DockPanel.Dock="Right"
								Style="{StaticResource BalticButtonStyle}"
								Height="26"
								HorizontalAlignment="Right"
								Margin="0,0,0,0">
								<DockPanel>
									<Image
										Stretch="Uniform"
										DockPanel.Dock="Left"
										HorizontalAlignment="Left"
										Source="Images/error_24.png" />
									<TextBlock
										Name="tbStopBtnText"
										DockPanel.Dock="Left"
										Margin="2,0,0,0"
										VerticalAlignment="Center"
										Text="Stop Preparation" />
								</DockPanel>
							</Button>
						</StackPanel>
					</Grid>
				</Border>
				<Border
					Name="bdrScriptWrapPanel"
					Grid.Row="0"
					BorderBrush="#0071BC"
					BorderThickness="0"
					Margin="0,0,0,0"
					VerticalAlignment="Stretch">
					<Grid>
						<Grid.ColumnDefinitions>
							<ColumnDefinition
								Width="*" />
							<ColumnDefinition
								Width="Auto" />
						</Grid.ColumnDefinitions>
						<WrapPanel
							Name="wrapPanelScripts"
							Grid.Column="0" />
					</Grid>
				</Border>
				<Button
					Grid.Column="1"
					Style="{StaticResource BalticButtonStyle}"
					Width="140"
					Height="26"
					Margin="18,4,8,4"
					VerticalAlignment="Top"
					Click="Statistics_Click">
					<DockPanel>
						<Image
							DockPanel.Dock="Left"
							HorizontalAlignment="Left"
							Source="Images/dashboard_20.png" />
						<TextBlock
							DockPanel.Dock="Left"
							Width="104"
							Margin="2,0,0,0"
							HorizontalAlignment="Left"
							VerticalAlignment="Center"
							Text="System information" />
					</DockPanel>
				</Button>
			</Grid>
		</Border>
		<Grid
			Name="storyGrid"
			VerticalAlignment="Stretch">
			<FrameworkElement.Resources>
				<ResourceDictionary>
					<local:ImageConverter
						x:Key="ImageConverter" />
					<utilities:BoolToVisibilityConverter
						x:Key="boolToVisConverter" />
					<utilities:PanelDimensionsConverter
						x:Key="PanelConverter" />
					<utilities:PanelMarginConverter
						x:Key="MarginConverter" />
					<Storyboard
						x:Key="flashAnimation">
						<DoubleAnimation
							Storyboard.TargetName="btnConfirm"
							Storyboard.TargetProperty="Opacity"
							From="1"
							To="0.3"
							AutoReverse="True"
							Duration="0:0:0.1"
							RepeatBehavior="3x" />
					</Storyboard>
					<LinearGradientBrush
						x:Key="SplitterBackground"
						StartPoint="0,0"
						EndPoint="1,0">
						<GradientBrush.GradientStops>
							<GradientStopCollection>
								<GradientStop
									Color="LightGray"
									Offset="0.0" />
								<GradientStop
									Color="LightGray"
									Offset="0.20" />
								<GradientStop
									Color="#0071BC"
									Offset="0.5" />
								<GradientStop
									Color="LightGray"
									Offset="0.80" />
								<GradientStop
									Color="LightGray"
									Offset="1.0" />
							</GradientStopCollection>
						</GradientBrush.GradientStops>
					</LinearGradientBrush>
				</ResourceDictionary>
			</FrameworkElement.Resources>
			<Grid.RowDefinitions>
				<RowDefinition
					Height="1*"
					MinHeight="120" />
				<RowDefinition
					Height="4" />
				<RowDefinition
					Height="3*"
					MinHeight="100" />
			</Grid.RowDefinitions>
			<Border
				Grid.Row="0"
				Margin="8,8,8,0"
				VerticalAlignment="Stretch">
				<Grid>
					<Grid.RowDefinitions>
						<RowDefinition
							Height="Auto" />
						<RowDefinition
							Height="1*" />
					</Grid.RowDefinitions>
					<Border
						Name="hdrBorder"
						Grid.Row="0"
						Height="24"
						BorderThickness="1,1,1,0"
						BorderBrush="#0071BC">
						<TextBlock
							Name="tbStatus"
							Padding="4"
							VerticalAlignment="Center" />
					</Border>
					<Border
						Grid.Row="1"
						VerticalAlignment="Stretch">
						<Grid
							x:Name="mainGrid"
							VerticalAlignment="Stretch">
							<ListView
								Name="dgMessage"
								MinHeight="75"
								SelectionMode="Single"
								ScrollViewer.HorizontalScrollBarVisibility="Auto"
								ScrollViewer.VerticalScrollBarVisibility="Auto"
								SelectionChanged="dgMessage_SelectionChanged"
								SizeChanged="dgMessage_SizeChanged"
								PreviewMouseDown="dgMessage_PreviewMouseDown">
								<ItemsControl.ItemContainerStyle>
									<Style
										TargetType="{x:Type ListViewItem}">
										<Setter
											Property="Height"
											Value="20" />
									</Style>
								</ItemsControl.ItemContainerStyle>
								<ListView.View>
									<GridView
										AllowsColumnReorder="False">
										<GridViewColumn
											Header="Time"
											Width="Auto">
											<GridViewColumn.CellTemplate>
												<DataTemplate>
													<TextBlock
														TextWrapping="Wrap"
														Text="{Binding Path=Raised}" />
												</DataTemplate>
											</GridViewColumn.CellTemplate>
										</GridViewColumn>
										<GridViewColumn
											Header="Subject"
											Width="Auto">
											<GridViewColumn.CellTemplate>
												<DataTemplate>
													<TextBlock
														TextWrapping="Wrap"
														Text="{Binding Path=Subject, ConverterParameter='
', Converter={local:SubjectListConverter}}" />
												</DataTemplate>
											</GridViewColumn.CellTemplate>
										</GridViewColumn>
										<GridViewColumn
											Header="Action item or message">
											<GridViewColumn.CellTemplate>
												<DataTemplate>
													<TextBlock
														TextTrimming="CharacterEllipsis"
														Text="{Binding Path=Description}" />
												</DataTemplate>
											</GridViewColumn.CellTemplate>
										</GridViewColumn>
									</GridView>
								</ListView.View>
							</ListView>
							<StackPanel
								x:Name="bottomPanel"
								ZIndex="99"
								VerticalAlignment="Bottom"
								Visibility="Hidden"
								Margin="2,0,2,0">
								<UIElement.RenderTransform>
									<TranslateTransform />
								</UIElement.RenderTransform>
								<StackPanel
									Orientation="Vertical">
									<StackPanel
										Name="messagePanel"
										Orientation="Vertical"
										Background="#FFD3D3D3">
										<Grid
											x:Name="propertiesPanel"
											Height="50"
											Width="{Binding ElementName=mainGrid, Path=Width}">
											<Grid.RowDefinitions>
												<RowDefinition
													Height="*" />
											</Grid.RowDefinitions>
											<Grid.ColumnDefinitions>
												<ColumnDefinition
													Width="Auto" />
												<ColumnDefinition
													Width="*" />
												<ColumnDefinition
													Width="Auto" />
											</Grid.ColumnDefinitions>
											<Image
												Name="imgMessage"
												Grid.Column="0"
												Height="46"
												Width="46"
												Margin="2"
												VerticalAlignment="Top" />
											<StackPanel
												Name="stkPanel"
												Grid.Column="1">
												<TextBlock
													Name="lblSubject"
													TextWrapping="Wrap"
													VerticalAlignment="Center"
													Margin="4,2,2,2"
													FontWeight="SemiBold" />
												<TextBlock
													Name="lblMessage"
													TextWrapping="Wrap"
													VerticalAlignment="Center"
													Margin="4,2,2,2" />
											</StackPanel>
											<StackPanel
												Grid.Column="2">
												<controls:ImageButton
													x:Name="btnClose"
													Click="closeButton_Click"
													Margin="0,4,0,0"
													Style="{DynamicResource ButtonStyleClose}"
													ImageSize="14"
													VerticalAlignment="Top"
													HorizontalAlignment="Right"
													Visibility="Collapsed" />
												<Button
													Name="btnConfirm"
													Width="85"
													Height="24"
													Content="Confirm"
													Margin="0,4,6,0"
													VerticalAlignment="Bottom"
													Style="{StaticResource BalticButtonStyle}"
													Visibility="Hidden"
													Click="confirmButton_Click" />
											</StackPanel>
										</Grid>
									</StackPanel>
								</StackPanel>
							</StackPanel>
						</Grid>
					</Border>
				</Grid>
			</Border>
			<GridSplitter
				Grid.Row="1"
				Height="4"
				Background="{StaticResource SplitterBackground}"
				VerticalAlignment="Stretch"
				HorizontalAlignment="Stretch"
				ResizeDirection="Rows"
				Focusable="False" />
			<Border
				Grid.Row="2"
				BorderBrush="#0071BC"
				BorderThickness="1,1,1,1"
				Margin="8,0,8,0"
				VerticalAlignment="Stretch">
				<Grid
					Name="chartGrid"
					Background="{StaticResource WhiteBrush}">
					<Grid.ColumnDefinitions>
						<ColumnDefinition
							Width="*" />
						<ColumnDefinition
							Width="5" />
						<ColumnDefinition
							Width="2*" />
					</Grid.ColumnDefinitions>
					<Image
						Width="100"
						Opacity="0.5"
						Source="{StaticResource LogoProteoElute}"
						VerticalAlignment="Top"
						HorizontalAlignment="Left"
						Margin="14,10,0,0"
						Panel.ZIndex="100" />
					<TextBlock
						x:Name="txtService"
						Text="*** SERVICE ***"
						Foreground="#FFFF0000"
						VerticalAlignment="Top"
						HorizontalAlignment="Right"
						Margin="4,10,4,0"
						FontSize="14"
						Panel.ZIndex="99"
						Visibility="{Binding IsService, Converter='{StaticResource boolToVisConverter}'}" />
					<DiagramControl
						Name="Diagram"
						Grid.Column="0"
						MouseDoubleClick="Diagram_MouseDoubleClick"
						ToolTip="Double-click to pop out" />
					<GridSplitter
						Grid.Column="1"
						Width="4"
						Background="{StaticResource SplitterBackground}"
						HorizontalAlignment="Stretch"
						Focusable="False" />
				</Grid>
			</Border>
		</Grid>
	</DockPanel>
</UserControl>
