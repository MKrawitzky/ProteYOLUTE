<UserControl
	x:Class="BalticWpfControlLib.AdvancedParameterControl"
	xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
	xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
	xmlns:utils="clr-namespace:BalticWpfControlLib.Utilities"
	xmlns:local="clr-namespace:BalticWpfControlLib"
	xmlns:syncfusion="http://schemas.syncfusion.com/wpf">
	<FrameworkElement.Resources>
		<ResourceDictionary>
			<ResourceDictionary.MergedDictionaries>
				<ResourceDictionary
					Source="Resources/SyncfusionStyle.xaml" />
			</ResourceDictionary.MergedDictionaries>
			<local:AdvParameterTypeTemplateSelector
				x:Key="dataTemplateSelector" />
			<local:AdvParameterValueConverter
				x:Key="paramValueConverter" />
			<local:BoolToVisCollapseConverter
				x:Key="boolToVisCollapseConverter" />
			<local:StringToSymbolsConverter
				x:Key="stringToSymbolsConverter" />
			<local:BoolToVisInvCollapseConverter
				x:Key="boolToVisInvConverter" />
			<utils:ObjectToIntConverter
				x:Key="ObjectToIntConverter" />
		</ResourceDictionary>
	</FrameworkElement.Resources>
	<local:ContainerTemplatableItemsControl
		x:Name="ParameterItems"
		SourceUpdated="ParameterItems_SourceUpdated"
		Grid.IsSharedSizeScope="True"
		KeyboardNavigation.IsTabStop="False"
		ItemTemplateSelector="{StaticResource dataTemplateSelector}"
		ItemsSource="{Binding Parameters}">
		<FrameworkElement.Resources>
			<ResourceDictionary>
				<DataTemplate
					x:Key="defaultParamTemplate"
					DataType="local:AdvProcParam">
					<TextBlock
						TextWrapping="Wrap"
						TextTrimming="CharacterEllipsis"
						VerticalAlignment="Center"
						Text="{Binding Path=Value, NotifyOnSourceUpdated=True, Converter={StaticResource paramValueConverter}}" />
				</DataTemplate>
				<DataTemplate
					x:Key="intParamTemplate"
					DataType="local:AdvProcParam">
					<syncfusion:IntegerTextBox
						HorizontalContentAlignment="Right"
						Value="{Binding Value, NotifyOnSourceUpdated=True, UpdateSourceTrigger=PropertyChanged, Converter={StaticResource ObjectToIntConverter}}">
						<FrameworkElement.Style>
							<Style
								TargetType="{x:Type syncfusion:IntegerTextBox}"
								BasedOn="{StaticResource DefaultIntegerTextboxStyle}">
								<Style.Triggers>
									<DataTrigger
										Value="True"
										Binding="{Binding HasError}">
										<Setter
											Property="BorderBrush"
											Value="#FFFF0000" />
										<Setter
											Property="BorderThickness"
											Value="2" />
										<Setter
											Property="FrameworkElement.ToolTip"
											Value="{Binding ErrorMessage}" />
										<Setter
											Property="syncfusion:EditorBase.FocusedBorderBrush"
											Value="#FFFF0000" />
									</DataTrigger>
								</Style.Triggers>
							</Style>
						</FrameworkElement.Style>
					</syncfusion:IntegerTextBox>
				</DataTemplate>
				<DataTemplate
					x:Key="doubleParamTemplate"
					DataType="local:AdvProcParam">
					<syncfusion:DoubleTextBox
						HorizontalContentAlignment="Right"
						NumberDecimalDigits="1"
						Value="{Binding Path=Value, NotifyOnSourceUpdated=True, UpdateSourceTrigger=PropertyChanged}">
						<FrameworkElement.Style>
							<Style
								TargetType="{x:Type syncfusion:DoubleTextBox}"
								BasedOn="{StaticResource DefaultDoubleTextboxStyle}">
								<Style.Triggers>
									<DataTrigger
										Value="True"
										Binding="{Binding HasError}">
										<Setter
											Property="BorderBrush"
											Value="#FFFF0000" />
										<Setter
											Property="BorderThickness"
											Value="2" />
										<Setter
											Property="FrameworkElement.ToolTip"
											Value="{Binding ErrorMessage}" />
										<Setter
											Property="syncfusion:EditorBase.FocusedBorderBrush"
											Value="#FFFF0000" />
									</DataTrigger>
								</Style.Triggers>
							</Style>
						</FrameworkElement.Style>
					</syncfusion:DoubleTextBox>
				</DataTemplate>
				<DataTemplate
					x:Key="stringParamTemplate"
					DataType="local:AdvProcParam">
					<TextBox
						Text="{Binding Path=Value, NotifyOnSourceUpdated=True}">
						<FrameworkElement.Style>
							<Style
								TargetType="{x:Type TextBox}">
								<Style.Triggers>
									<DataTrigger
										Value="True"
										Binding="{Binding HasError}">
										<Setter
											Property="BorderBrush"
											Value="#FFFF0000" />
										<Setter
											Property="BorderThickness"
											Value="2" />
										<Setter
											Property="FrameworkElement.ToolTip"
											Value="{Binding ErrorMessage}" />
									</DataTrigger>
								</Style.Triggers>
							</Style>
						</FrameworkElement.Style>
					</TextBox>
				</DataTemplate>
				<DataTemplate
					x:Key="boolParamTemplate"
					DataType="local:AdvProcParam">
					<CheckBox
						IsChecked="{Binding Path=Value, NotifyOnSourceUpdated=True}" />
				</DataTemplate>
			</ResourceDictionary>
		</FrameworkElement.Resources>
		<ItemsControl.ItemContainerStyle>
			<Style
				TargetType="{x:Type ContentControl}">
				<Setter
					Property="KeyboardNavigation.IsTabStop"
					Value="False" />
				<Setter
					Property="Template">
					<Setter.Value>
						<ControlTemplate
							TargetType="{x:Type ContentControl}">
							<Border
								Name="ItemBorder"
								BorderThickness="1"
								BorderBrush="{TemplateBinding Control.Background}"
								Margin="0,1,0,1"
								Visibility="{Binding Path=IsVisible, Converter='{StaticResource boolToVisCollapseConverter}'}">
								<Grid
									VerticalAlignment="Center"
									Margin="1">
									<Grid.ColumnDefinitions>
										<ColumnDefinition
											SharedSizeGroup="A" />
										<ColumnDefinition
											SharedSizeGroup="B" />
										<ColumnDefinition
											Width="Auto" />
									</Grid.ColumnDefinitions>
									<Grid.RowDefinitions>
										<RowDefinition
											Height="Auto" />
									</Grid.RowDefinitions>
									<TextBlock
										Grid.Column="0"
										HorizontalAlignment="Left"
										VerticalAlignment="Center"
										Text="{Binding Path=Name, StringFormat={}{0}:}" />
									<ContentPresenter
										Grid.Column="1"
										HorizontalAlignment="Stretch"
										VerticalAlignment="Center"
										Margin="2,0,2,0" />
									<TextBlock
										Grid.Column="2"
										HorizontalAlignment="Left"
										VerticalAlignment="Center"
										Text="{Binding Unit, Converter='{StaticResource stringToSymbolsConverter}'}"
										Visibility="{Binding HasChildren, Converter='{StaticResource boolToVisInvConverter}'}" />
									<Border
										Name="bdrChildSettings"
										Grid.Column="2"
										CornerRadius="1"
										BorderThickness="2"
										Visibility="{Binding HasChildren, Converter='{StaticResource boolToVisCollapseConverter}'}">
										<FrameworkElement.Style>
											<Style>
												<Style.Triggers>
													<DataTrigger
														Value="True"
														Binding="{Binding IsChildError}">
														<Setter
															Property="Border.BorderBrush"
															Value="#FFFF0000" />
													</DataTrigger>
													<DataTrigger
														Value="False"
														Binding="{Binding IsChildError}">
														<Setter
															Property="Border.BorderBrush"
															Value="#00FFFFFF" />
													</DataTrigger>
												</Style.Triggers>
											</Style>
										</FrameworkElement.Style>
										<Button
											Name="btnChildSettings"
											Margin="2,2,1,2"
											Command="{Binding Path=ChildSettingsCmd}"
											CommandParameter="{Binding ElementName=btnChildSettings}">
											<Image
												Source="Images/Settings_30.png"
												Height="18" />
										</Button>
									</Border>
								</Grid>
							</Border>
						</ControlTemplate>
					</Setter.Value>
				</Setter>
			</Style>
		</ItemsControl.ItemContainerStyle>
	</local:ContainerTemplatableItemsControl>
</UserControl>
