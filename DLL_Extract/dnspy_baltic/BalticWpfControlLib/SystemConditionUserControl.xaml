<UserControl
	x:Class="BalticWpfControlLib.SystemConditionUserControl"
	xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
	xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
	xmlns:balticwpfcontrollib="clr-namespace:BalticWpfControlLib">
	<Grid>
		<Grid.RowDefinitions>
			<RowDefinition
				Height="Auto" />
			<RowDefinition
				Height="Auto" />
			<RowDefinition
				Height="Auto" />
			<RowDefinition
				Height="Auto" />
			<RowDefinition
				Height="*" />
			<RowDefinition
				Height="Auto" />
		</Grid.RowDefinitions>
		<Grid
			Row="0">
			<Grid.ColumnDefinitions>
				<ColumnDefinition
					Width="Auto" />
				<ColumnDefinition
					Width="*" />
			</Grid.ColumnDefinitions>
			<Label
				Grid.Column="0"
				Content="Time:" />
			<TextBlock
				Name="Raised"
				Grid.Column="1" />
		</Grid>
		<Grid
			Row="1">
			<Grid.ColumnDefinitions>
				<ColumnDefinition
					Width="Auto" />
				<ColumnDefinition
					Width="*" />
			</Grid.ColumnDefinitions>
			<Label
				Grid.Column="0"
				Content="Subject:" />
			<TextBlock
				Name="Subject"
				Grid.Column="1" />
		</Grid>
		<Grid
			Row="2">
			<Grid.ColumnDefinitions>
				<ColumnDefinition
					Width="Auto" />
				<ColumnDefinition
					Width="*" />
			</Grid.ColumnDefinitions>
			<Label
				Grid.Column="0"
				Content="Severity:" />
			<TextBlock
				Name="Severity"
				Grid.Column="1" />
		</Grid>
		<Label
			Grid.Row="3"
			Content="Message:" />
		<TextBlock
			Name="Description"
			Grid.Row="4" />
		<Grid
			Row="5"
			IsSharedSizeScope="True">
			<Grid.ColumnDefinitions>
				<ColumnDefinition
					Width="*" />
				<ColumnDefinition
					Width="Auto"
					SharedSizeGroup="btns" />
				<ColumnDefinition
					Width="Auto"
					SharedSizeGroup="btns" />
			</Grid.ColumnDefinitions>
			<Button
				Name="Confirm"
				Grid.Column="1"
				Content="Confirm" />
			<Button
				Name="Close"
				Grid.Column="2"
				Content="Close"
				IsCancel="True"
				IsDefault="True" />
		</Grid>
	</Grid>
</UserControl>
