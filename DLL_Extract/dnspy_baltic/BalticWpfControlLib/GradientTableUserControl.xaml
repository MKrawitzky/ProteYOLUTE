<UserControl
	x:Class="BalticWpfControlLib.GradientTableUserControl"
	xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
	xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
	xmlns:local="clr-namespace:BalticWpfControlLib"
	xmlns:controls="clr-namespace:BalticWpfControlLib.Controls"
	xmlns:utilities="clr-namespace:BalticWpfControlLib.Utilities"
	xmlns:syncfusion="http://schemas.syncfusion.com/wpf"
	Margin="0"
	Padding="0">
	<FrameworkElement.Resources>
		<ResourceDictionary>
			<ResourceDictionary.MergedDictionaries>
				<ResourceDictionary
					Source="Resources/SyncfusionStyle.xaml" />
				<ResourceDictionary
					Source="Resources/MyResourceDictionary.xaml" />
				<ResourceDictionary
					Source="Themes/ImageButton.xaml" />
			</ResourceDictionary.MergedDictionaries>
		</ResourceDictionary>
	</FrameworkElement.Resources>
	<Grid
		Margin="2">
		<FrameworkElement.Resources>
			<ResourceDictionary>
				<utilities:ColumnEquilTimeToStringConverter
					x:Key="ColumnEquilTimeToString" />
				<utilities:BoolInverterConverter
					x:Key="boolInverter" />
				<utilities:BoolToForegroundConverter
					x:Key="foregroundConverter" />
				<utilities:BoolToMarginConverter
					x:Key="marginConverter" />
				<utilities:BoolToVisibilityCollapseConverter
					x:Key="boolToVisConverterCollapse" />
				<Style
					x:Key="titleText"
					TargetType="{x:Type TextBlock}">
					<Setter
						Property="Margin"
						Value="2,2,2,2" />
					<Setter
						Property="FontWeight"
						Value="Normal" />
					<Setter
						Property="FontSize"
						Value="9" />
					<Setter
						Property="HorizontalAlignment"
						Value="Left" />
					<Setter
						Property="Foreground"
						Value="#0071BC" />
				</Style>
				<Style
					x:Key="footnoteText"
					TargetType="{x:Type TextBlock}">
					<Setter
						Property="Margin"
						Value="1,1,1,1" />
					<Setter
						Property="FontWeight"
						Value="Normal" />
					<Setter
						Property="FontSize"
						Value="9" />
					<Setter
						Property="HorizontalAlignment"
						Value="Left" />
					<Setter
						Property="Foreground"
						Value="#0071BC" />
				</Style>
				<Style
					x:Key="GradientDataGridStyle"
					TargetType="{x:Type DataGrid}">
					<Setter
						Property="DataGrid.ColumnHeaderStyle"
						Value="{DynamicResource GradientColHdrStyle}" />
					<Setter
						Property="DataGrid.RowHeaderStyle"
						Value="{DynamicResource GradientRowHdrStyle}" />
					<Setter
						Property="DataGrid.RowStyle"
						Value="{DynamicResource GradientRowStyle}" />
					<Setter
						Property="DataGrid.CellStyle"
						Value="{DynamicResource GradientCellStyle}" />
					<Setter
						Property="Background"
						Value="#00FFFFFF" />
				</Style>
				<Style
					x:Key="GradientColHdrStyle"
					TargetType="{x:Type DataGridColumnHeader}">
					<Setter
						Property="Height"
						Value="30" />
					<Setter
						Property="Background"
						Value="#0071BC" />
					<Setter
						Property="Foreground"
						Value="#FFFFFFFF" />
					<Setter
						Property="BorderBrush"
						Value="{DynamicResource {x:Static SystemColors.ControlBrushKey}}" />
					<Setter
						Property="BorderThickness"
						Value="0,0,1,0" />
					<Setter
						Property="FontSize"
						Value="11" />
					<EventSetter
						Event="Click"
						Handler="GradientColumnHeader_Click" />
				</Style>
				<Style
					x:Key="GradientRowHdrStyle"
					TargetType="{x:Type DataGridRowHeader}">
					<Setter
						Property="Background"
						Value="{DynamicResource {x:Static SystemColors.ControlBrushKey}}" />
					<Setter
						Property="Foreground"
						Value="#FFFF0000" />
					<Setter
						Property="BorderBrush"
						Value="#B4B4B4" />
					<Setter
						Property="BorderThickness"
						Value="0" />
					<Setter
						Property="Width"
						Value="10" />
					<Setter
						Property="HorizontalAlignment"
						Value="Center" />
					<Setter
						Property="Padding"
						Value="5,0,0,0" />
					<Setter
						Property="FontWeight"
						Value="SemiBold" />
				</Style>
				<Style
					x:Key="GradientRowStyle"
					TargetType="{x:Type DataGridRow}">
					<Setter
						Property="Background"
						Value="#FFFFFFFF" />
					<Style.Triggers>
						<Trigger
							Property="UIElement.IsMouseOver"
							Value="True">
							<Setter
								Property="Background"
								Value="#FFFFFFFF" />
							<Setter
								Property="Foreground"
								Value="#FF000000" />
							<Setter
								Property="DataGridRow.IsSelected"
								Value="True" />
						</Trigger>
						<DataTrigger
							Value="False"
							Binding="{Binding Path=IsValidState, UpdateSourceTrigger=PropertyChanged}">
							<Setter
								Property="BorderBrush"
								Value="#FFFF0000" />
							<Setter
								Property="BorderThickness"
								Value="1" />
						</DataTrigger>
					</Style.Triggers>
				</Style>
				<Style
					x:Key="GradientCellStyle"
					TargetType="{x:Type DataGridCell}">
					<Setter
						Property="Height"
						Value="34" />
					<Style.Triggers>
						<Trigger
							Property="DataGridCell.IsSelected"
							Value="True">
							<Setter
								Property="Background"
								Value="#00FFFFFF" />
							<Setter
								Property="BorderBrush"
								Value="#00FFFFFF" />
						</Trigger>
						<Trigger
							Property="UIElement.IsKeyboardFocusWithin"
							Value="True">
							<Setter
								Property="BorderBrush"
								Value="#00FFFFFF" />
							<Setter
								Property="Background"
								Value="#00FFFFFF" />
						</Trigger>
					</Style.Triggers>
				</Style>
				<Style
					x:Key="{x:Type TextBox}"
					TargetType="{x:Type TextBox}">
					<Setter
						Property="Validation.ErrorTemplate">
						<Setter.Value>
							<ControlTemplate>
								<DockPanel
									LastChildFill="True">
									<Border
										BorderBrush="#FFFF0000"
										BorderThickness="1">
										<AdornedElementPlaceholder />
									</Border>
								</DockPanel>
							</ControlTemplate>
						</Setter.Value>
					</Setter>
					<Style.Triggers>
						<Trigger
							Property="Validation.HasError"
							Value="true">
							<Setter
								Property="FrameworkElement.ToolTip"
								Value="{Binding Path=(Validation.Errors)[0].ErrorContent, RelativeSource={RelativeSource Self}}" />
						</Trigger>
						<Trigger
							Property="UIElement.IsFocused"
							Value="True">
							<Setter
								Property="Background"
								Value="#F4F4F4" />
							<Setter
								Property="BorderThickness"
								Value="0" />
						</Trigger>
					</Style.Triggers>
				</Style>
				<Style
					x:Key="doubleTextBoxStyle"
					TargetType="{x:Type syncfusion:DoubleTextBox}"
					BasedOn="{StaticResource DefaultDoubleTextboxStyle}">
					<Style.Triggers>
						<Trigger
							Property="IsEnabled"
							Value="False">
							<Setter
								Property="Background"
								Value="#FFFFFFFF" />
						</Trigger>
						<Trigger
							Property="UIElement.IsFocused"
							Value="True">
							<Setter
								Property="Background"
								Value="#FFFFFFFF" />
							<Setter
								Property="BorderThickness"
								Value="0" />
						</Trigger>
					</Style.Triggers>
				</Style>
				<Style
					x:Key="durationTextBoxStyle"
					TargetType="{x:Type syncfusion:DoubleTextBox}"
					BasedOn="{StaticResource DefaultDoubleTextboxStyle}">
					<Setter
						Property="Background"
						Value="#F4F4F4" />
					<Setter
						Property="BorderBrush"
						Value="#F4F4F4" />
					<Style.Triggers>
						<Trigger
							Property="IsEnabled"
							Value="False">
							<Setter
								Property="Background"
								Value="#F4F4F4" />
						</Trigger>
						<Trigger
							Property="UIElement.IsFocused"
							Value="True">
							<Setter
								Property="Background"
								Value="#F4F4F4" />
						</Trigger>
					</Style.Triggers>
				</Style>
			</ResourceDictionary>
		</FrameworkElement.Resources>
		<Border
			BorderBrush="#FFD3D3D3"
			BorderThickness="1">
			<DockPanel
				VerticalAlignment="Stretch"
				Height="Auto">
				<TextBlock
					DockPanel.Dock="Top"
					Text="GRADIENT"
					Style="{StaticResource titleText}" />
				<Grid>
					<Grid.RowDefinitions>
						<RowDefinition />
						<RowDefinition
							Height="Auto" />
					</Grid.RowDefinitions>
					<Border
						Name="bdrTable"
						Margin="5,10,5,5"
						DockPanel.Dock="Bottom">
						<DataGrid
							Name="dgGradient"
							AlternationCount="2"
							Style="{DynamicResource GradientDataGridStyle}"
							AutoGenerateColumns="False"
							ScrollViewer.VerticalScrollBarVisibility="Auto"
							HorizontalGridLinesBrush="#B4B4B4"
							VerticalGridLinesBrush="{DynamicResource {x:Static SystemColors.ControlBrushKey}}"
							HorizontalScrollBarVisibility="Disabled"
							CanUserAddRows="False"
							HeadersVisibility="Column"
							RowDetailsVisibilityMode="VisibleWhenSelected">
							<DataGrid.Columns>
								<DataGridTemplateColumn
									Width="60">
									<DataGridColumn.HeaderTemplate>
										<DataTemplate>
											<TextBlock
												Text="Time (min)"
												Width="Auto"
												TextWrapping="Wrap"
												TextAlignment="Center"
												HorizontalAlignment="Center" />
										</DataTemplate>
									</DataGridColumn.HeaderTemplate>
									<DataGridTemplateColumn.CellTemplate>
										<DataTemplate>
											<StackPanel
												ToolTip="{Binding Path=ErrorToolTip, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, NotifyOnSourceUpdated=True}">
												<Border
													BorderBrush="#FFD3D3D3"
													BorderThickness="0,0,0,1"
													Margin="-1,-1,-1,0">
													<syncfusion:DoubleTextBox
														CornerRadius="0"
														ScrollInterval="1.0"
														FontFamily="SegoeUI"
														FontWeight="Normal"
														BorderBrush="#FFFFFFFF"
														Background="#FFFFFFFF"
														Height="19"
														BorderThickness="0"
														MinValue="0"
														MaxValue="999"
														TextAlignment="Right"
														Padding="0,3,0,0"
														VerticalContentAlignment="Center"
														IsReadOnly="{Binding Path=IsTimeEditable, Converter='{StaticResource boolInverter}'}"
														Value="{Binding Path=Time, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, NotifyOnValidationError=True}"
														Validation.Error="Validation_Error"
														LostFocus="TimeTextBox_LostFocus"
														ValueChanged="TimeTextBox_ValueChanged" />
												</Border>
												<Border
													Margin="-1,0,-1,-1">
													<DockPanel
														HorizontalAlignment="Stretch"
														VerticalAlignment="Stretch"
														IsEnabled="false">
														<TextBox
															DockPanel.Dock="Left"
															Height="17"
															Width="20"
															IsEnabled="false"
															Text="Δ"
															Background="#F4F4F4"
															VerticalContentAlignment="Center"
															BorderThickness="0"
															Foreground="{Binding Path=IsLastRow, NotifyOnSourceUpdated=True, Converter='{StaticResource foregroundConverter}'}" />
														<syncfusion:DoubleTextBox
															DockPanel.Dock="Right"
															CornerRadius="0"
															Height="17"
															FontFamily="SegoeUI"
															IsScrollingOnCircle="False"
															EnableFocusColors="False"
															IsReadOnly="True"
															VerticalContentAlignment="Center"
															BorderThickness="0"
															TextSelectionOnFocus="False"
															Padding="0,3,0,0"
															Style="{StaticResource durationTextBoxStyle}"
															TextAlignment="Right"
															Value="{Binding Path=Duration, UpdateSourceTrigger=PropertyChanged, NotifyOnSourceUpdated=True}"
															PositiveForeground="{Binding Path=IsLastRow, NotifyOnSourceUpdated=True, Converter='{StaticResource foregroundConverter}'}" />
													</DockPanel>
												</Border>
											</StackPanel>
										</DataTemplate>
									</DataGridTemplateColumn.CellTemplate>
									<DataGridColumn.CellStyle>
										<Style
											TargetType="{x:Type DataGridCell}">
											<Setter
												Property="IsTabStop"
												Value="False" />
											<Setter
												Property="BorderBrush"
												Value="{DynamicResource {x:Static SystemColors.ControlBrushKey}}" />
											<Setter
												Property="Background"
												Value="#F4F4F4" />
											<Style.Triggers>
												<Trigger
													Property="DataGridCell.IsSelected"
													Value="True">
													<Setter
														Property="BorderBrush"
														Value="{DynamicResource {x:Static SystemColors.ControlBrushKey}}" />
													<Setter
														Property="Background"
														Value="#F4F4F4" />
												</Trigger>
											</Style.Triggers>
										</Style>
									</DataGridColumn.CellStyle>
								</DataGridTemplateColumn>
								<DataGridTemplateColumn
									Width="67">
									<DataGridColumn.HeaderTemplate>
										<DataTemplate>
											<TextBlock
												Text="Composition (%B)"
												Width="Auto"
												TextWrapping="Wrap"
												TextAlignment="Center"
												HorizontalAlignment="Center" />
										</DataTemplate>
									</DataGridColumn.HeaderTemplate>
									<DataGridTemplateColumn.CellTemplate>
										<DataTemplate>
											<StackPanel
												ToolTip="{Binding Path=ErrorToolTip, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, NotifyOnSourceUpdated=True}">
												<Border
													BorderThickness="0,0,0,1"
													BorderBrush="#FFD3D3D3"
													Margin="-1,-1,-1,0">
													<syncfusion:DoubleTextBox
														NumberDecimalDigits="1"
														CornerRadius="0"
														FontFamily="SegoeUI"
														FontWeight="Normal"
														BorderBrush="#FFFFFFFF"
														Background="#FFFFFFFF"
														Height="19"
														BorderThickness="0"
														MinValue="0"
														MaxValue="100"
														TextAlignment="Right"
														Padding="0,3,5,0"
														VerticalContentAlignment="Center"
														Value="{Binding Path=Composition, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
														Validation.Error="Validation_Error"
														ValueChanged="CompositionTextBox_ValueChanged" />
												</Border>
												<Border
													Margin="-1,0,-1,-1">
													<TextBox
														Height="17"
														BorderThickness="0"
														IsEnabled="False"
														Background="#F4F4F4" />
												</Border>
											</StackPanel>
										</DataTemplate>
									</DataGridTemplateColumn.CellTemplate>
									<DataGridColumn.CellStyle>
										<Style
											TargetType="{x:Type DataGridCell}">
											<Setter
												Property="IsTabStop"
												Value="False" />
											<Setter
												Property="BorderBrush"
												Value="{DynamicResource {x:Static SystemColors.ControlBrushKey}}" />
											<Setter
												Property="Background"
												Value="#F4F4F4" />
											<Style.Triggers>
												<Trigger
													Property="DataGridCell.IsSelected"
													Value="True">
													<Setter
														Property="BorderBrush"
														Value="{DynamicResource {x:Static SystemColors.ControlBrushKey}}" />
													<Setter
														Property="Background"
														Value="#F4F4F4" />
												</Trigger>
											</Style.Triggers>
										</Style>
									</DataGridColumn.CellStyle>
								</DataGridTemplateColumn>
								<DataGridTemplateColumn
									Width="52">
									<DataGridColumn.HeaderTemplate>
										<DataTemplate>
											<TextBlock
												Text="Flow rate (µL/min)"
												Width="Auto"
												TextWrapping="Wrap"
												TextAlignment="Center"
												HorizontalAlignment="Center" />
										</DataTemplate>
									</DataGridColumn.HeaderTemplate>
									<DataGridTemplateColumn.CellTemplate>
										<DataTemplate>
											<StackPanel
												ToolTip="{Binding Path=ErrorToolTip, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, NotifyOnSourceUpdated=True}">
												<Border
													BorderThickness="0,0,0,1"
													BorderBrush="#FFD3D3D3"
													Margin="-1,-1,-1,0">
													<syncfusion:DoubleTextBox
														CornerRadius="0"
														IsScrollingOnCircle="True"
														FontFamily="SegoeUI"
														NumberDecimalDigits="2"
														FontWeight="Normal"
														BorderBrush="#FFFFFFFF"
														Background="#FFFFFFFF"
														Height="19"
														BorderThickness="0"
														MinValue="0.01"
														MaxValue="10"
														ScrollInterval="0.01"
														TextAlignment="Right"
														Padding="0,3,0,0"
														VerticalContentAlignment="Center"
														Value="{Binding Path=Flow, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, NotifyOnSourceUpdated=True, NotifyOnTargetUpdated=True, NotifyOnValidationError=True}"
														Validation.Error="Validation_Error"
														ValueChanged="FlowTextBox_ValueChanged" />
												</Border>
												<Border
													Margin="-1,0,-1,-1">
													<TextBox
														Height="17"
														BorderThickness="0"
														IsEnabled="False"
														Background="#F4F4F4" />
												</Border>
											</StackPanel>
										</DataTemplate>
									</DataGridTemplateColumn.CellTemplate>
									<DataGridColumn.CellStyle>
										<Style
											TargetType="{x:Type DataGridCell}">
											<Setter
												Property="IsTabStop"
												Value="False" />
											<Setter
												Property="BorderBrush"
												Value="{DynamicResource {x:Static SystemColors.ControlBrushKey}}" />
											<Setter
												Property="Background"
												Value="#F4F4F4" />
											<Style.Triggers>
												<Trigger
													Property="DataGridCell.IsSelected"
													Value="True">
													<Setter
														Property="BorderBrush"
														Value="{DynamicResource {x:Static SystemColors.ControlBrushKey}}" />
													<Setter
														Property="Background"
														Value="#F4F4F4" />
												</Trigger>
											</Style.Triggers>
										</Style>
									</DataGridColumn.CellStyle>
								</DataGridTemplateColumn>
								<DataGridTemplateColumn
									Width="*">
									<DataGridColumn.HeaderTemplate>
										<DataTemplate>
											<TextBlock
												Text=""
												Width="Auto"
												TextWrapping="Wrap"
												TextAlignment="Center"
												HorizontalAlignment="Center" />
										</DataTemplate>
									</DataGridColumn.HeaderTemplate>
									<DataGridTemplateColumn.CellTemplate>
										<DataTemplate>
											<StackPanel
												Margin="0"
												HorizontalAlignment="Stretch">
												<Border
													Height="18"
													Background="#FFFFFFFF"
													Margin="-1,0,-1,0">
													<controls:ImageButton
														Click="GradientRemoveEvent_Click"
														VerticalAlignment="Top"
														Padding="0"
														Style="{DynamicResource ButtonStyleTwo}"
														ImageSize="15"
														Margin="{Binding Path=IsLastRowValid, UpdateSourceTrigger=PropertyChanged, Converter='{StaticResource marginConverter}'}" />
												</Border>
												<Rectangle
													Fill="#FFD3D3D3"
													Height="1" />
												<Border
													Height="17"
													Background="#F4F4F4"
													Margin="-1,0,-1,-1">
													<controls:ImageButton
														Click="GradientAddEvent_Click"
														Padding="0"
														Style="{DynamicResource ButtonStyleOne}"
														ImageSize="15"
														Margin="{Binding Path=IsLastRowValid, UpdateSourceTrigger=PropertyChanged, Converter='{StaticResource marginConverter}'}" />
												</Border>
											</StackPanel>
										</DataTemplate>
									</DataGridTemplateColumn.CellTemplate>
									<DataGridColumn.CellStyle>
										<Style
											TargetType="{x:Type DataGridCell}">
											<Setter
												Property="IsTabStop"
												Value="False" />
											<Setter
												Property="BorderBrush"
												Value="#F4F4F4" />
											<Setter
												Property="Background"
												Value="#F4F4F4" />
											<Style.Triggers>
												<Trigger
													Property="DataGridCell.IsSelected"
													Value="True">
													<Setter
														Property="BorderBrush"
														Value="#F4F4F4" />
													<Setter
														Property="Background"
														Value="#F4F4F4" />
												</Trigger>
											</Style.Triggers>
										</Style>
									</DataGridColumn.CellStyle>
								</DataGridTemplateColumn>
							</DataGrid.Columns>
						</DataGrid>
					</Border>
					<Grid
						Row="1"
						Margin="0,0,4,0">
						<Grid.RowDefinitions>
							<RowDefinition
								Height="Auto" />
							<RowDefinition
								Height="Auto" />
							<RowDefinition
								Height="Auto" />
						</Grid.RowDefinitions>
						<Grid.ColumnDefinitions>
							<ColumnDefinition
								Width="*" />
						</Grid.ColumnDefinitions>
						<TextBlock
							HorizontalAlignment="Right"
							FontStyle="Italic"
							Style="{StaticResource footnoteText}"
							Text="{Binding Method.TrapColumnEquil.EquilTime, Converter='{StaticResource ColumnEquilTimeToString}', ConverterParameter='Approx. Trap Equil Time'}"
							Visibility="{Binding IsTwoColumn, UpdateSourceTrigger=PropertyChanged, Converter='{StaticResource boolToVisConverterCollapse}'}" />
						<TextBlock
							Grid.Row="1"
							Grid.Column="0"
							HorizontalAlignment="Right"
							FontStyle="Italic"
							Style="{StaticResource footnoteText}"
							Height="12"
							Margin="0,0,2,1"
							VerticalAlignment="Bottom"
							Text="{Binding Method.SeparationColumnEquil.EquilTime, Converter='{StaticResource ColumnEquilTimeToString}', ConverterParameter='Approx. Separation Equil Time'}"
							Visibility="{Binding IsOneOrTwoColumn, UpdateSourceTrigger=PropertyChanged, Converter='{StaticResource boolToVisConverterCollapse}'}" />
						<TextBlock
							Grid.Row="2"
							Grid.Column="0"
							HorizontalAlignment="Right"
							FontStyle="Italic"
							Style="{StaticResource footnoteText}"
							Text="{Binding Method.SampleLoading.EquilTime, Converter='{StaticResource ColumnEquilTimeToString}', ConverterParameter='Approx. Sample Loading Time'}"
							Visibility="{Binding IsOneOrTwoColumn, Converter='{StaticResource boolToVisConverterCollapse}'}" />
					</Grid>
				</Grid>
			</DockPanel>
		</Border>
	</Grid>
</UserControl>
