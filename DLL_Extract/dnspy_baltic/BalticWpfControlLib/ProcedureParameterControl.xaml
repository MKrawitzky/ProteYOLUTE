<UserControl
	x:Class="BalticWpfControlLib.ProcedureParameterControl"
	xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
	xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
	xmlns:gl="clr-namespace:System.Globalization;assembly=mscorlib"
	xmlns:utils="clr-namespace:BalticWpfControlLib.Utilities"
	xmlns:local="clr-namespace:BalticWpfControlLib"
	xmlns:syncfusion="http://schemas.syncfusion.com/wpf">
	<FrameworkElement.Resources>
		<ResourceDictionary>
			<ResourceDictionary.MergedDictionaries>
				<ResourceDictionary
					Source="Resources/MyResourceDictionary.xaml" />
				<ResourceDictionary
					Source="Resources/SyncfusionStyle.xaml" />
			</ResourceDictionary.MergedDictionaries>
			<local:ParameterTypeTemplateSelector
				x:Key="dataTemplateSelector" />
			<local:ParameterValueConverter
				x:Key="paramValueConverter" />
			<local:ToolTipTextToVisibilityConverter
				x:Key="tipTextToVisibilityConverter" />
			<local:BoolToVisCollapseConverter
				x:Key="boolToVisCollapseConverter" />
			<local:BoolToVisInvCollapseConverter
				x:Key="boolToVisibilityInvConverter" />
			<local:IndentToMarginConverter
				x:Key="indentToMarginConverter" />
			<local:ParamToVisCollapseConverter
				x:Key="paramToVisCollapseConverter" />
			<utils:ObjectToIntConverter
				x:Key="ObjectToIntConverter" />
		</ResourceDictionary>
	</FrameworkElement.Resources>
	<local:ContainerTemplatableItemsControl
		x:Name="ParameterItems"
		SourceUpdated="ParameterItems_SourceUpdated"
		Grid.IsSharedSizeScope="True"
		KeyboardNavigation.IsTabStop="False"
		ItemTemplateSelector="{StaticResource dataTemplateSelector}">
		<FrameworkElement.Resources>
			<ResourceDictionary>
				<DataTemplate
					x:Key="defaultParamTemplate"
					DataType="{x:Type local:ProcParam}">
					<TextBlock
						TextWrapping="Wrap"
						TextTrimming="CharacterEllipsis"
						VerticalAlignment="Center"
						Text="{Binding Path=Value, NotifyOnSourceUpdated=True, Converter={StaticResource paramValueConverter}}" />
				</DataTemplate>
				<DataTemplate
					x:Key="intParamTemplate"
					DataType="{x:Type local:ProcParam}">
					<syncfusion:IntegerTextBox
						HorizontalContentAlignment="Right"
						Width="65"
						Value="{Binding Value, NotifyOnSourceUpdated=True, UpdateSourceTrigger=PropertyChanged, Converter={StaticResource ObjectToIntConverter}}">
						<FrameworkElement.ToolTip>
							<ToolTip
								Visibility="{Binding ToolTipText, Converter={StaticResource tipTextToVisibilityConverter}}">
								<Grid>
									<Grid.RowDefinitions>
										<RowDefinition
											Height="Auto" />
										<RowDefinition
											Height="Auto" />
									</Grid.RowDefinitions>
									<TextBlock
										Text="{Binding Path=ToolTipText}" />
									<Image
										Grid.Row="1"
										Source="{Binding Path=ToolTipImageName}" />
								</Grid>
							</ToolTip>
						</FrameworkElement.ToolTip>
					</syncfusion:IntegerTextBox>
				</DataTemplate>
				<DataTemplate
					x:Key="doubleParamTemplate"
					DataType="{x:Type local:ProcParam}">
					<syncfusion:DoubleTextBox
						HorizontalContentAlignment="Right"
						Width="65"
						Value="{Binding Path=Value, NotifyOnSourceUpdated=True, UpdateSourceTrigger=PropertyChanged}"
						NumberDecimalDigits="{Binding Path=Decimals}">
						<FrameworkElement.ToolTip>
							<ToolTip
								Visibility="{Binding ToolTipText, Converter={StaticResource tipTextToVisibilityConverter}}">
								<Grid>
									<Grid.RowDefinitions>
										<RowDefinition
											Height="Auto" />
										<RowDefinition
											Height="Auto" />
									</Grid.RowDefinitions>
									<TextBlock
										Text="{Binding Path=ToolTipText}" />
									<Image
										Grid.Row="1"
										Source="{Binding Path=ToolTipImageName}" />
								</Grid>
							</ToolTip>
						</FrameworkElement.ToolTip>
					</syncfusion:DoubleTextBox>
				</DataTemplate>
				<DataTemplate
					x:Key="customParamTemplate"
					DataType="{x:Type local:ProcParam}" />
				<DataTemplate
					x:Key="stringParamTemplate"
					DataType="{x:Type local:ProcParam}">
					<TextBox
						Text="{Binding Path=Value, NotifyOnSourceUpdated=True}" />
				</DataTemplate>
				<DataTemplate
					x:Key="radioParamTemplate"
					DataType="{x:Type local:ProcParam}">
					<RadioButton
						HorizontalContentAlignment="Right"
						Style="{StaticResource BalticRadioButtonStyle}"
						Content="{Binding Path=Name}"
						IsChecked="{Binding Path=Value, UpdateSourceTrigger=PropertyChanged, NotifyOnSourceUpdated=True}"
						Loaded="RadioButton_Loaded">
						<FrameworkElement.ToolTip>
							<ToolTip
								Visibility="{Binding ToolTipText, Converter={StaticResource tipTextToVisibilityConverter}}">
								<Grid>
									<Grid.RowDefinitions>
										<RowDefinition
											Height="Auto" />
										<RowDefinition
											Height="Auto" />
									</Grid.RowDefinitions>
									<TextBlock
										Text="{Binding Path=ToolTipText}" />
									<Image
										Grid.Row="1"
										Source="{Binding Path=ToolTipImageName}" />
								</Grid>
							</ToolTip>
						</FrameworkElement.ToolTip>
					</RadioButton>
				</DataTemplate>
				<DataTemplate
					x:Key="checkParamTemplate"
					DataType="{x:Type local:ProcParam}">
					<CheckBox
						HorizontalContentAlignment="Right"
						Style="{StaticResource BalticCheckBoxStyle}"
						Content="{Binding Path=Name}"
						IsChecked="{Binding Path=Value, UpdateSourceTrigger=PropertyChanged, NotifyOnSourceUpdated=True}">
						<FrameworkElement.ToolTip>
							<ToolTip
								Visibility="{Binding ToolTipText, Converter={StaticResource tipTextToVisibilityConverter}}">
								<Grid>
									<Grid.RowDefinitions>
										<RowDefinition
											Height="Auto" />
										<RowDefinition
											Height="Auto" />
									</Grid.RowDefinitions>
									<TextBlock
										Text="{Binding Path=ToolTipText}" />
									<Image
										Grid.Row="1"
										Source="{Binding Path=ToolTipImageName}" />
								</Grid>
							</ToolTip>
						</FrameworkElement.ToolTip>
					</CheckBox>
				</DataTemplate>
				<DataTemplate
					x:Key="boolParamTemplate"
					DataType="{x:Type local:ProcParam}">
					<FrameworkTemplate.Resources>
						<ResourceDictionary>
							<LinearGradientBrush
								x:Key="CheckedBlue"
								StartPoint="0,0"
								EndPoint="0,1">
								<GradientStop
									Color="#FF285AB3"
									Offset="0" />
								<GradientStop
									Color="#FF4184EC"
									Offset="0.5" />
								<GradientStop
									Color="#FF558BED"
									Offset="0.5" />
								<GradientStop
									Color="#FF7DACF0"
									Offset="1" />
							</LinearGradientBrush>
							<LinearGradientBrush
								x:Key="CheckedOrange"
								StartPoint="0,0"
								EndPoint="0,1">
								<GradientStop
									Color="#FFCA6A13"
									Offset="0" />
								<GradientStop
									Color="#FFF67D0C"
									Offset="0.2" />
								<GradientStop
									Color="#FFFE7F0C"
									Offset="0.2" />
								<GradientStop
									Color="#FFFA8E12"
									Offset="0.5" />
								<GradientStop
									Color="#FFFF981D"
									Offset="0.5" />
								<GradientStop
									Color="#FFFCBC5A"
									Offset="1" />
							</LinearGradientBrush>
							<SolidColorBrush
								x:Key="CheckedOrangeBorder"
								Color="#FF8E4A1B" />
							<SolidColorBrush
								x:Key="CheckedBlueBorder"
								Color="#FF143874" />
							<Style
								x:Key="{x:Type CheckBox}"
								TargetType="{x:Type CheckBox}">
								<Setter
									Property="Foreground"
									Value="{DynamicResource {x:Static SystemColors.WindowTextBrushKey}}" />
								<Setter
									Property="Background"
									Value="{DynamicResource {x:Static SystemColors.WindowBrushKey}}" />
								<Setter
									Property="Template">
									<Setter.Value>
										<ControlTemplate
											TargetType="{x:Type CheckBox}">
											<FrameworkTemplate.Resources>
												<ResourceDictionary>
													<Storyboard
														x:Key="OnChecking">
														<DoubleAnimationUsingKeyFrames
															BeginTime="00:00:00"
															Storyboard.TargetName="slider"
															Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[3].(TranslateTransform.X)">
															<SplineDoubleKeyFrame
																KeyTime="00:00:00.1000000"
																Value="37" />
														</DoubleAnimationUsingKeyFrames>
													</Storyboard>
													<Storyboard
														x:Key="OnUnchecking">
														<DoubleAnimationUsingKeyFrames
															BeginTime="00:00:00"
															Storyboard.TargetName="slider"
															Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[3].(TranslateTransform.X)">
															<SplineDoubleKeyFrame
																KeyTime="00:00:00.1000000"
																Value="0" />
														</DoubleAnimationUsingKeyFrames>
													</Storyboard>
												</ResourceDictionary>
											</FrameworkTemplate.Resources>
											<Grid>
												<Grid.ColumnDefinitions>
													<ColumnDefinition
														Width="Auto" />
													<ColumnDefinition
														Width="Auto" />
												</Grid.ColumnDefinitions>
												<DockPanel
													x:Name="dockPanel">
													<ContentPresenter
														SnapsToDevicePixels="{TemplateBinding UIElement.SnapsToDevicePixels}"
														Content="{TemplateBinding ContentControl.Content}"
														ContentStringFormat="{TemplateBinding ContentControl.ContentStringFormat}"
														ContentTemplate="{TemplateBinding ContentControl.ContentTemplate}"
														RecognizesAccessKey="True"
														VerticalAlignment="Center" />
													<Grid
														Width="74"
														HorizontalAlignment="Left">
														<Border
															x:Name="BackgroundBorder"
															BorderBrush="#FF939393"
															BorderThickness="1"
															CornerRadius="3"
															Height="27"
															Width="74">
															<Border.Background>
																<LinearGradientBrush
																	StartPoint="0,0"
																	EndPoint="0,1">
																	<GradientStop
																		Color="#FFB5B5B5"
																		Offset="0" />
																	<GradientStop
																		Color="#FFDEDEDE"
																		Offset="0.1" />
																	<GradientStop
																		Color="#FFEEEEEE"
																		Offset="0.5" />
																	<GradientStop
																		Color="#FFFAFAFA"
																		Offset="0.5" />
																	<GradientStop
																		Color="#FFFEFEFE"
																		Offset="1" />
																</LinearGradientBrush>
															</Border.Background>
															<Grid>
																<Grid.ColumnDefinitions>
																	<ColumnDefinition />
																	<ColumnDefinition />
																</Grid.ColumnDefinitions>
																<Ellipse
																	x:Name="Off"
																	Width="14"
																	Height="14"
																	Stroke="#FF7A7A7A"
																	StrokeThickness="2"
																	Grid.Column="1"
																	HorizontalAlignment="Center"
																	VerticalAlignment="Center" />
																<Line
																	x:Name="On"
																	X1="0"
																	Y1="0"
																	X2="0"
																	Y2="14"
																	Stroke="#FF7A7A7A"
																	StrokeThickness="2"
																	Grid.Column="0"
																	HorizontalAlignment="Center"
																	VerticalAlignment="Center" />
															</Grid>
														</Border>
														<Border
															x:Name="slider"
															BorderBrush="#FF939393"
															HorizontalAlignment="Left"
															Width="37"
															Height="27"
															BorderThickness="1"
															CornerRadius="3"
															RenderTransformOrigin="0.5,0.5"
															Margin="0">
															<UIElement.RenderTransform>
																<TransformGroup>
																	<ScaleTransform
																		ScaleX="1"
																		ScaleY="1" />
																	<SkewTransform
																		AngleX="0"
																		AngleY="0" />
																	<RotateTransform
																		Angle="0" />
																	<TranslateTransform
																		X="0"
																		Y="0" />
																</TransformGroup>
															</UIElement.RenderTransform>
															<Border.Background>
																<LinearGradientBrush
																	EndPoint="0,1"
																	StartPoint="0,0">
																	<GradientStop
																		Color="#FFF0F0F0"
																		Offset="0" />
																	<GradientStop
																		Color="#FFCDCDCD"
																		Offset="0.1" />
																	<GradientStop
																		Color="#FFFBFBFB"
																		Offset="1" />
																</LinearGradientBrush>
															</Border.Background>
														</Border>
													</Grid>
												</DockPanel>
											</Grid>
											<ControlTemplate.Triggers>
												<Trigger
													Property="ToggleButton.IsChecked"
													Value="True">
													<TriggerBase.ExitActions>
														<BeginStoryboard
															x:Name="OnUnchecking_BeginStoryboard"
															Storyboard="{StaticResource OnUnchecking}" />
													</TriggerBase.ExitActions>
													<TriggerBase.EnterActions>
														<BeginStoryboard
															x:Name="OnChecking_BeginStoryboard"
															Storyboard="{StaticResource OnChecking}" />
													</TriggerBase.EnterActions>
													<Setter
														TargetName="On"
														Property="Shape.Stroke"
														Value="#FFFFFFFF" />
													<Setter
														TargetName="Off"
														Property="Shape.Stroke"
														Value="#FFFFFFFF" />
													<Setter
														TargetName="BackgroundBorder"
														Property="Border.Background"
														Value="{StaticResource CheckedBlue}" />
													<Setter
														TargetName="BackgroundBorder"
														Property="Border.BorderBrush"
														Value="{StaticResource CheckedBlueBorder}" />
												</Trigger>
												<Trigger
													Property="IsEnabled"
													Value="False" />
											</ControlTemplate.Triggers>
										</ControlTemplate>
									</Setter.Value>
								</Setter>
							</Style>
						</ResourceDictionary>
					</FrameworkTemplate.Resources>
					<CheckBox
						IsChecked="{Binding Path=Value, NotifyOnSourceUpdated=True}">
						<FrameworkElement.ToolTip>
							<ToolTip
								Visibility="{Binding ToolTipText, Converter={StaticResource tipTextToVisibilityConverter}}">
								<Grid>
									<Grid.RowDefinitions>
										<RowDefinition
											Height="Auto" />
										<RowDefinition
											Height="Auto" />
									</Grid.RowDefinitions>
									<TextBlock
										Text="{Binding Path=ToolTipText}" />
									<Image
										Grid.Row="1"
										Source="{Binding Path=ToolTipImageName}" />
								</Grid>
							</ToolTip>
						</FrameworkElement.ToolTip>
					</CheckBox>
				</DataTemplate>
				<DataTemplate
					x:Key="separatorParamTemplate">
					<Grid>
						<Rectangle
							Height="1"
							Stroke="#0071BC"
							StrokeThickness="1"
							ClipToBounds="False"
							Margin="2"
							SnapsToDevicePixels="True" />
					</Grid>
				</DataTemplate>
			</ResourceDictionary>
		</FrameworkElement.Resources>
		<ItemsControl.ItemContainerStyle>
			<Style
				TargetType="{x:Type ContentControl}">
				<Setter
					Property="KeyboardNavigation.IsTabStop"
					Value="False" />
				<Setter
					Property="Template">
					<Setter.Value>
						<ControlTemplate
							TargetType="{x:Type ContentControl}">
							<Border
								Name="ItemBorder"
								BorderThickness="2, 1"
								BorderBrush="{TemplateBinding Control.Background}"
								CornerRadius="4"
								Margin="0">
								<UIElement.Visibility>
									<MultiBinding
										Converter="{StaticResource paramToVisCollapseConverter}">
										<Binding
											Path="IsVisible" />
										<Binding
											Path="Type.Name" />
									</MultiBinding>
								</UIElement.Visibility>
								<Grid>
									<Grid.RowDefinitions>
										<RowDefinition
											Height="Auto" />
									</Grid.RowDefinitions>
									<Grid
										VerticalAlignment="Center"
										Margin="{Binding Indent, Converter='{StaticResource indentToMarginConverter}'}"
										Visibility="{Binding IsStandard, Converter='{StaticResource boolToVisCollapseConverter}'}">
										<Grid.ColumnDefinitions>
											<ColumnDefinition
												SharedSizeGroup="A" />
											<ColumnDefinition
												Width="Auto" />
											<ColumnDefinition
												Width="Auto" />
										</Grid.ColumnDefinitions>
										<Grid.RowDefinitions>
											<RowDefinition
												Height="Auto" />
											<RowDefinition
												Height="Auto" />
										</Grid.RowDefinitions>
										<TextBlock
											Grid.Column="0"
											HorizontalAlignment="Right"
											VerticalAlignment="Center"
											Text="{Binding Path=Name, StringFormat={}{0}:}" />
										<ContentPresenter
											Grid.Row="0"
											Grid.Column="1"
											HorizontalAlignment="Stretch"
											VerticalAlignment="Center"
											Margin="4,0,4,0"
											MinWidth="45" />
										<TextBlock
											Grid.Row="0"
											Grid.Column="2"
											HorizontalAlignment="Left"
											VerticalAlignment="Center"
											Text="{Binding Unit}" />
									</Grid>
									<Grid
										VerticalAlignment="Center"
										Margin="4"
										Visibility="{Binding IsSeparator, Converter='{StaticResource boolToVisCollapseConverter}'}">
										<Grid.ColumnDefinitions>
											<ColumnDefinition
												Width="*" />
										</Grid.ColumnDefinitions>
										<ContentPresenter
											HorizontalAlignment="Stretch"
											VerticalAlignment="Center" />
									</Grid>
									<Grid
										VerticalAlignment="Center"
										Visibility="{Binding IsBoolButton, Converter='{StaticResource boolToVisCollapseConverter}'}"
										Margin="{Binding Indent, Converter='{StaticResource indentToMarginConverter}'}">
										<Grid.RowDefinitions>
											<RowDefinition
												Height="Auto" />
											<RowDefinition
												Height="Auto" />
										</Grid.RowDefinitions>
										<ContentPresenter
											HorizontalAlignment="Left"
											VerticalAlignment="Center"
											Margin="4,0,4,0" />
										<local:ContainerTemplatableItemsControl
											SourceUpdated="ParameterItems_SourceUpdated"
											Grid.Row="1"
											Grid.IsSharedSizeScope="True"
											KeyboardNavigation.IsTabStop="False"
											ItemTemplateSelector="{StaticResource dataTemplateSelector}"
											ItemsSource="{Binding ChildProcParams}">
											<ItemsControl.ItemsPanel>
												<ItemsPanelTemplate>
													<WrapPanel />
												</ItemsPanelTemplate>
											</ItemsControl.ItemsPanel>
											<ItemsControl.ItemContainerStyle>
												<Style
													TargetType="{x:Type ContentControl}">
													<Setter
														Property="KeyboardNavigation.IsTabStop"
														Value="False" />
													<Setter
														Property="Template">
														<Setter.Value>
															<ControlTemplate
																TargetType="{x:Type ContentControl}">
																<Border
																	Name="ItemBorder"
																	BorderThickness="2"
																	BorderBrush="{TemplateBinding Control.Background}"
																	CornerRadius="4"
																	Margin="0,1,0,1">
																	<UIElement.Visibility>
																		<MultiBinding
																			Converter="{StaticResource paramToVisCollapseConverter}">
																			<Binding
																				Path="IsVisible" />
																			<Binding
																				Path="Type.Name" />
																		</MultiBinding>
																	</UIElement.Visibility>
																	<Grid>
																		<Grid
																			VerticalAlignment="Center"
																			Margin="4"
																			Visibility="{Binding IsBoolButton, Converter='{StaticResource boolToVisibilityInvConverter}'}">
																			<Grid.ColumnDefinitions>
																				<ColumnDefinition
																					SharedSizeGroup="A" />
																				<ColumnDefinition
																					SharedSizeGroup="B" />
																				<ColumnDefinition
																					Width="Auto" />
																			</Grid.ColumnDefinitions>
																			<Grid.RowDefinitions>
																				<RowDefinition
																					Height="Auto" />
																				<RowDefinition
																					Height="Auto" />
																			</Grid.RowDefinitions>
																			<TextBlock
																				Grid.Column="0"
																				HorizontalAlignment="Right"
																				VerticalAlignment="Center"
																				Text="{Binding Path=Name, StringFormat={}{0}:}" />
																			<ContentPresenter
																				Grid.Row="0"
																				Grid.Column="1"
																				HorizontalAlignment="Stretch"
																				VerticalAlignment="Center"
																				Margin="4,0,4,0" />
																			<TextBlock
																				Grid.Row="0"
																				Grid.Column="2"
																				HorizontalAlignment="Left"
																				VerticalAlignment="Center"
																				Text="{Binding Unit}" />
																		</Grid>
																		<Grid
																			VerticalAlignment="Center"
																			Visibility="{Binding IsBoolButton, Converter='{StaticResource boolToVisCollapseConverter}'}"
																			Margin="{Binding Indent, Converter='{StaticResource indentToMarginConverter}'}">
																			<ContentPresenter
																				HorizontalAlignment="Left"
																				VerticalAlignment="Center"
																				Margin="4,6,4,0" />
																		</Grid>
																	</Grid>
																</Border>
																<ControlTemplate.Triggers>
																	<DataTrigger
																		Value="True"
																		Binding="{Binding HasError}">
																		<Setter
																			TargetName="ItemBorder"
																			Property="Border.BorderBrush"
																			Value="#FFFF0000" />
																		<Setter
																			Property="FrameworkElement.ToolTip"
																			Value="{Binding ErrorMessage}" />
																	</DataTrigger>
																</ControlTemplate.Triggers>
															</ControlTemplate>
														</Setter.Value>
													</Setter>
												</Style>
											</ItemsControl.ItemContainerStyle>
										</local:ContainerTemplatableItemsControl>
									</Grid>
								</Grid>
							</Border>
							<ControlTemplate.Triggers>
								<DataTrigger
									Value="True"
									Binding="{Binding HasError}">
									<Setter
										TargetName="ItemBorder"
										Property="Border.BorderBrush"
										Value="#FFFF0000" />
									<Setter
										Property="FrameworkElement.ToolTip"
										Value="{Binding ErrorMessage}" />
								</DataTrigger>
							</ControlTemplate.Triggers>
						</ControlTemplate>
					</Setter.Value>
				</Setter>
			</Style>
		</ItemsControl.ItemContainerStyle>
	</local:ContainerTemplatableItemsControl>
</UserControl>
