<UserControl
	x:Class="BalticWpfControlLib.AnalyticalColEquilUserControl"
	xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
	xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
	xmlns:local="clr-namespace:BalticWpfControlLib"
	xmlns:utilities="clr-namespace:BalticWpfControlLib.Utilities"
	xmlns:syncfusion="http://schemas.syncfusion.com/wpf"
	BorderThickness="0,1,1,1"
	BorderBrush="#FF708090"
	Background="#FFD3D3D3">
	<FrameworkElement.Resources>
		<ResourceDictionary>
			<ResourceDictionary.MergedDictionaries>
				<ResourceDictionary
					Source="Resources/MyResourceDictionary.xaml" />
				<ResourceDictionary
					Source="Resources/SyncfusionStyle.xaml" />
			</ResourceDictionary.MergedDictionaries>
		</ResourceDictionary>
	</FrameworkElement.Resources>
	<Grid
		VerticalAlignment="Stretch"
		HorizontalAlignment="Stretch"
		Margin="5,0,0,0">
		<FrameworkElement.Resources>
			<ResourceDictionary>
				<utilities:ColumnEquilTimeToStringConverter
					x:Key="ColumnEquilTimeToString" />
				<Style
					x:Key="titleText"
					TargetType="{x:Type TextBlock}">
					<Setter
						Property="FontWeight"
						Value="Normal" />
					<Setter
						Property="FontSize"
						Value="10" />
					<Setter
						Property="HorizontalAlignment"
						Value="Right" />
					<Setter
						Property="Foreground"
						Value="#0071BC" />
					<Setter
						Property="Margin"
						Value="4,0,4,0" />
				</Style>
				<Style
					x:Key="{x:Type TextBox}"
					TargetType="{x:Type TextBox}">
					<Setter
						Property="Validation.ErrorTemplate">
						<Setter.Value>
							<ControlTemplate>
								<DockPanel
									LastChildFill="True">
									<Border
										BorderBrush="#FFFF0000"
										BorderThickness="1">
										<AdornedElementPlaceholder />
									</Border>
								</DockPanel>
							</ControlTemplate>
						</Setter.Value>
					</Setter>
					<Style.Triggers>
						<Trigger
							Property="Validation.HasError"
							Value="true">
							<Setter
								Property="FrameworkElement.ToolTip"
								Value="{Binding Path=(Validation.Errors)[0].ErrorContent, RelativeSource={RelativeSource Self}}" />
						</Trigger>
					</Style.Triggers>
				</Style>
			</ResourceDictionary>
		</FrameworkElement.Resources>
		<Grid.RowDefinitions>
			<RowDefinition
				Height="Auto" />
			<RowDefinition
				Height="*" />
			<RowDefinition
				Height="*" />
			<RowDefinition
				Height="*" />
		</Grid.RowDefinitions>
		<Grid.ColumnDefinitions>
			<ColumnDefinition
				Width="80" />
			<ColumnDefinition />
		</Grid.ColumnDefinitions>
		<TextBlock
			Grid.Row="0"
			Grid.Column="0"
			Grid.ColumnSpan="2"
			FontStyle="Italic"
			Style="{StaticResource titleText}"
			Text="{Binding Method.SeparationColumnEquil.EquilTime, Converter='{StaticResource ColumnEquilTimeToString}', ConverterParameter='Approx. Equilibration Time', UpdateSourceTrigger=PropertyChanged}" />
		<Label
			Grid.Column="0"
			Grid.Row="1"
			HorizontalAlignment="Right"
			Content="Volume:"
			VerticalAlignment="Center" />
		<StackPanel
			Orientation="Horizontal"
			Grid.Column="1"
			Grid.Row="1">
			<FrameworkElement.ToolTip>
				<TextBlock
					Text="{Binding Path=ColumnVolume, StringFormat='Column volume is {0:G3}µL'}" />
			</FrameworkElement.ToolTip>
			<Border
				x:Name="bdrScale"
				BorderThickness="2"
				CornerRadius="1"
				Height="26"
				BorderBrush="#00FFFFFF"
				VerticalAlignment="Center">
				<syncfusion:DoubleTextBox
					Name="txtScale"
					HorizontalAlignment="Left"
					Height="23"
					Width="30"
					VerticalContentAlignment="Center"
					VerticalAlignment="Center"
					HorizontalContentAlignment="Right"
					NumberDecimalDigits="1"
					Value="{Binding Path=Scale, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, NotifyOnSourceUpdated=True, ValidatesOnDataErrors=True, NotifyOnValidationError=True}"
					Validation.Error="Validation_Error"
					MouseWheel="txtScale_MouseWheel"
					ValueChanged="txtScale_ValueChanged" />
			</Border>
			<Label
				HorizontalAlignment="Left"
				Content="x column volume(s)"
				VerticalAlignment="Center" />
		</StackPanel>
		<Label
			Grid.Column="0"
			Grid.Row="2"
			HorizontalAlignment="Right"
			Content="Pressure:"
			VerticalAlignment="Center" />
		<StackPanel
			Orientation="Horizontal"
			Grid.Column="1"
			Grid.Row="2"
			ToolTip="{Binding PressureToolTip}">
			<Border
				x:Name="bdrPressure"
				BorderThickness="2"
				CornerRadius="1"
				Height="26"
				BorderBrush="#00FFFFFF"
				VerticalAlignment="Center">
				<syncfusion:DoubleTextBox
					Name="txtPressure"
					HorizontalAlignment="Left"
					Height="23"
					VerticalContentAlignment="Center"
					VerticalAlignment="Center"
					HorizontalContentAlignment="Right"
					NumberDecimalDigits="1"
					Width="60"
					Value="{Binding Path=Pressure, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, NotifyOnSourceUpdated=True, ValidatesOnDataErrors=True, NotifyOnValidationError=True}"
					Validation.Error="Validation_Error"
					MouseWheel="txtPressure_MouseWheel"
					ValueChanged="txtPressure_ValueChanged" />
			</Border>
			<Label
				Name="lblPressUnits"
				HorizontalAlignment="Left"
				Content="bar"
				VerticalContentAlignment="Center"
				VerticalAlignment="Center" />
		</StackPanel>
		<Button
			Name="btnRevert"
			Grid.Column="0"
			Grid.Row="3"
			Grid.ColumnSpan="2"
			Style="{StaticResource BalticButtonStyle}"
			HorizontalAlignment="Center"
			VerticalAlignment="Bottom"
			Height="22"
			Margin="0,0,0,6"
			Click="BlueDotTileButton_Click">
			<StackPanel
				Orientation="Horizontal">
				<Image
					Source="Images/undo_24.png"
					Height="18" />
				<TextBlock
					Text="Revert to Default"
					FontSize="11"
					Margin="2,0,2,0"
					VerticalAlignment="Center" />
			</StackPanel>
		</Button>
	</Grid>
</UserControl>
