<Window
	x:Class="BalticWpfControlLib.CapillariesDiagramWindow"
	xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
	xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
	xmlns:Utilities="clr-namespace:BalticWpfControlLib.Utilities"
	xmlns:local="clr-namespace:BalticWpfControlLib"
	Title="Edit Capillaries"
	Width="620"
	Height="640"
	MinWidth="580"
	MinHeight="500"
	WindowStartupLocation="CenterOwner"
	ShowInTaskbar="False">
	<FrameworkElement.Resources>
		<ResourceDictionary>
			<ResourceDictionary.MergedDictionaries>
				<ResourceDictionary
					Source="../BrukerLC.Styling;component/LookAndFeel.xaml" />
				<ResourceDictionary
					Source="Resources/MyResourceDictionary.xaml" />
				<ResourceDictionary
					Source="Themes/ImageButton.xaml" />
				<ResourceDictionary
					Source="Resources/BrukerIcons.xaml" />
			</ResourceDictionary.MergedDictionaries>
		</ResourceDictionary>
	</FrameworkElement.Resources>
	<Grid>
		<FrameworkElement.Resources>
			<ResourceDictionary>
				<Utilities:BoolToVisibilityConverter
					x:Key="boolToVisConverter" />
			</ResourceDictionary>
		</FrameworkElement.Resources>
		<Grid.RowDefinitions>
			<RowDefinition
				Height="*" />
			<RowDefinition
				Height="Auto" />
		</Grid.RowDefinitions>
		<Image
			Width="100"
			Opacity="0.5"
			Source="{StaticResource LogoProteoElute}"
			Grid.ColumnSpan="2"
			VerticalAlignment="Top"
			HorizontalAlignment="Left"
			Margin="14,10,0,0"
			Panel.ZIndex="100" />
		<DiagramControl
			Name="Diagram"
			VerticalAlignment="Top"
			HorizontalAlignment="Center" />
		<Grid
			Row="1">
			<Grid.ColumnDefinitions>
				<ColumnDefinition
					Width="*" />
				<ColumnDefinition
					Width="*" />
			</Grid.ColumnDefinitions>
			<StackPanel
				Orientation="Horizontal"
				HorizontalAlignment="Left"
				VerticalAlignment="Bottom">
				<Button
					Name="btnSaveDefault"
					Content="Save As Default"
					Height="22"
					Margin="4,8,18,4"
					Click="btnSaveDefault_Click" />
				<Button
					Name="btnRevertFactory"
					Content="Revert to Factory Default"
					Height="22"
					IsDefault="True"
					Margin="0,8,8,4"
					Visibility="{Binding IsModifiedFromFactory, UpdateSourceTrigger=PropertyChanged, Converter='{StaticResource boolToVisConverter}'}"
					Click="btnRevertFactory_Click" />
			</StackPanel>
			<StackPanel
				Grid.Column="1"
				Orientation="Horizontal"
				HorizontalAlignment="Right"
				VerticalAlignment="Bottom">
				<Button
					Name="btnRevert"
					Content="Revert To Default"
					Height="22"
					Margin="4,8,18,4"
					Click="btnRevert_Click" />
				<Button
					Name="btnOK"
					Content="OK"
					Width="75"
					Height="22"
					IsDefault="True"
					Margin="0,8,8,4"
					Click="btnOK_Click" />
				<Button
					Content="Cancel"
					Width="75"
					Height="22"
					Margin="0,8,4,4"
					IsCancel="True" />
			</StackPanel>
		</Grid>
	</Grid>
</Window>
