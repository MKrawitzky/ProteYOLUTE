<UserControl
	x:Class="BalticWpfControlLib.LCChartUserControl"
	xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
	xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
	xmlns:syncfusion="http://schemas.syncfusion.com/wpf"
	xmlns:chart="clr-namespace:Syncfusion.UI.Xaml.Charts;assembly=Syncfusion.SfChart.WPF"
	xmlns:balticWpfControlLib="clr-namespace:BalticWpfControlLib"
	Unloaded="OnUnloaded">
	<FrameworkElement.Resources>
		<ResourceDictionary>
			<ResourceDictionary.MergedDictionaries>
				<ResourceDictionary
					Source="Resources/MyResourceDictionary.xaml" />
			</ResourceDictionary.MergedDictionaries>
		</ResourceDictionary>
	</FrameworkElement.Resources>
	<Grid
		Background="#FFF5F5F5">
		<FrameworkElement.Resources>
			<ResourceDictionary>
				<Style
					x:Key="AxisStyle"
					TargetType="{x:Type Line}">
					<Setter
						Property="Stroke"
						Value="#FFA9A9A9" />
					<Setter
						Property="StrokeThickness"
						Value="1" />
				</Style>
				<Style
					x:Key="MinorTickStyle"
					TargetType="{x:Type Line}">
					<Setter
						Property="Stroke"
						Value="#FFA9A9A9" />
					<Setter
						Property="StrokeThickness"
						Value="0.4" />
				</Style>
				<Style
					x:Key="MinorGridLineStyle"
					TargetType="{x:Type Line}">
					<Setter
						Property="StrokeThickness"
						Value="0" />
				</Style>
			</ResourceDictionary>
		</FrameworkElement.Resources>
		<Grid.RowDefinitions>
			<RowDefinition
				Height="*" />
		</Grid.RowDefinitions>
		<Grid.ColumnDefinitions>
			<ColumnDefinition
				Width="*" />
			<ColumnDefinition
				Width="Auto" />
		</Grid.ColumnDefinitions>
		<chart:SfChart
			x:Name="sfChartRealTime"
			Margin="4,10,10,4"
			AreaBorderThickness="0,1,1,1"
			Background="#00FFFFFF"
			MouseWheel="sfChartRealTime_MouseWheel">
			<chart:SfChart.Behaviors>
				<chart:ChartZoomPanBehavior
					x:Name="sfChartBehavior"
					ZoomMode="XY"
					EnablePinchZooming="False"
					ZoomRelativeToCursor="True"
					EnableMouseWheelZooming="True"
					EnableSelectionZooming="True"
					EnablePanning="True" />
			</chart:SfChart.Behaviors>
			<chart:SfChart.PrimaryAxis>
				<chart:NumericalAxis
					SmallTicksPerInterval="1"
					RangePadding="Round"
					AxisLineStyle="{StaticResource AxisStyle}"
					MajorTickLineStyle="{StaticResource AxisStyle}"
					MinorTickLineStyle="{StaticResource MinorTickStyle}"
					MinorGridLineStyle="{StaticResource MinorGridLineStyle}"
					MouseWheel="NumericalAxis_MouseWheel"
					MouseDoubleClick="NumericalAxis_MouseDoubleClick"
					MouseEnter="NumericalAxis_MouseEnter"
					MouseLeave="NumericalAxis_MouseLeave"
					LabelCreated="NumericalAxis_LabelCreated">
					<chart:ChartAxis.Header>
						<TextBlock
							Margin="4"
							Text="Time (min)"
							FontSize="12"
							FontFamily="SegoeUI" />
					</chart:ChartAxis.Header>
				</chart:NumericalAxis>
			</chart:SfChart.PrimaryAxis>
			<chart:SfChart.SecondaryAxis>
				<chart:NumericalAxis
					Margin="1,0,0,0"
					PlotOffset="0.5"
					SmallTicksPerInterval="1"
					AxisLineStyle="{StaticResource AxisStyle}"
					MajorTickLineStyle="{StaticResource AxisStyle}"
					MinorTickLineStyle="{StaticResource MinorTickStyle}"
					MinorGridLineStyle="{StaticResource MinorGridLineStyle}"
					RangePadding="Normal"
					MouseWheel="SecondaryAxis_MouseWheel"
					MouseDoubleClick="SecondaryAxis_MouseDoubleClick"
					MouseEnter="SecondaryAxis_MouseEnter"
					MouseLeave="SecondaryAxis_MouseLeave"
					LabelCreated="NumericalAxis_LabelCreated" />
			</chart:SfChart.SecondaryAxis>
		</chart:SfChart>
		<Expander
			Grid.Column="1"
			ExpandDirection="Left"
			BorderBrush="#0071BC"
			Margin="0,4,4,4"
			Width="Auto">
			<HeaderedContentControl.Header>
				<DockPanel
					VerticalAlignment="Stretch"
					HorizontalAlignment="Stretch">
					<TextBlock
						DockPanel.Dock="Top"
						Text="Trace Selection"
						RenderTransformOrigin="0.5,0.5"
						Margin="0,0,0,0">
						<FrameworkElement.LayoutTransform>
							<TransformGroup>
								<ScaleTransform
									ScaleX="1"
									ScaleY="1" />
								<SkewTransform
									AngleX="0"
									AngleY="0" />
								<RotateTransform
									Angle="90" />
								<TranslateTransform
									X="0"
									Y="0" />
							</TransformGroup>
						</FrameworkElement.LayoutTransform>
						<UIElement.RenderTransform>
							<TransformGroup>
								<ScaleTransform
									ScaleX="1"
									ScaleY="1" />
								<SkewTransform
									AngleX="0"
									AngleY="0" />
								<RotateTransform
									Angle="0" />
								<TranslateTransform
									X="0"
									Y="0" />
							</TransformGroup>
						</UIElement.RenderTransform>
					</TextBlock>
					<Grid
						DockPanel.Dock="Right"
						Margin="0,20,0,0">
						<Grid.ColumnDefinitions>
							<ColumnDefinition
								Width="*" />
						</Grid.ColumnDefinitions>
						<WrapPanel>
							<FrameworkElement.LayoutTransform>
								<RotateTransform
									CenterX="0.5"
									CenterY="0.5"
									Angle="90" />
							</FrameworkElement.LayoutTransform>
							<CheckBox
								Content="Diagnostic Traces"
								HorizontalAlignment="Center"
								Margin="18,0,0,0"
								IsChecked="{Binding IsDiagnosticTracesSelected}" />
						</WrapPanel>
					</Grid>
				</DockPanel>
			</HeaderedContentControl.Header>
			<syncfusion:CheckListBox
				syncfusion:SkinStorage.VisualStyle="Default"
				DisplayMemberPath="TraceName"
				Margin="4"
				ItemsSource="{Binding TraceSelectionSource, NotifyOnSourceUpdated=True, UpdateSourceTrigger=PropertyChanged}">
				<FrameworkElement.Resources>
					<ResourceDictionary>
						<Style
							x:Key="{x:Type syncfusion:CheckListBoxItem}"
							TargetType="{x:Type syncfusion:CheckListBoxItem}">
							<Setter
								Property="syncfusion:CheckListBoxItem.IsChecked"
								Value="{Binding IsChecked, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
							<Setter
								Property="Foreground"
								Value="{Binding TraceColor}" />
						</Style>
					</ResourceDictionary>
				</FrameworkElement.Resources>
				<ItemsControl.ItemsPanel>
					<ItemsPanelTemplate>
						<StackPanel />
					</ItemsPanelTemplate>
				</ItemsControl.ItemsPanel>
			</syncfusion:CheckListBox>
		</Expander>
	</Grid>
</UserControl>
