<UserControl
	x:Class="BalticWpfControlLib.GradientMainUserControl"
	xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
	xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
	xmlns:syncfusion="http://schemas.syncfusion.com/wpf"
	xmlns:chart="clr-namespace:Syncfusion.UI.Xaml.Charts;assembly=Syncfusion.SfChart.WPF"
	xmlns:Controls="clr-namespace:BalticWpfControlLib.Controls"
	xmlns:local="clr-namespace:BalticWpfControlLib"
	Height="480"
	Width="300"
	Loaded="GradientMainUserControl_Loaded">
	<FrameworkElement.Resources>
		<ResourceDictionary>
			<ResourceDictionary.MergedDictionaries>
				<ResourceDictionary
					Source="Resources/MyResourceDictionary.xaml" />
				<ResourceDictionary
					Source="Resources/SyncfusionStyle.xaml" />
			</ResourceDictionary.MergedDictionaries>
			<Style
				x:Key="AxisStyle"
				TargetType="{x:Type Line}">
				<Setter
					Property="Stroke"
					Value="#FFA9A9A9" />
				<Setter
					Property="StrokeThickness"
					Value="1" />
			</Style>
			<Style
				x:Key="MinorTickStyle"
				TargetType="{x:Type Line}">
				<Setter
					Property="Stroke"
					Value="#FFA9A9A9" />
				<Setter
					Property="StrokeThickness"
					Value="0.4" />
			</Style>
			<Style
				x:Key="MinorGridLineStyle"
				TargetType="{x:Type Line}">
				<Setter
					Property="StrokeThickness"
					Value="0" />
			</Style>
			<Style
				x:Key="titleText"
				TargetType="{x:Type TextBlock}">
				<Setter
					Property="Margin"
					Value="2,2,2,2" />
				<Setter
					Property="FontWeight"
					Value="Normal" />
				<Setter
					Property="FontSize"
					Value="9" />
				<Setter
					Property="HorizontalAlignment"
					Value="Left" />
				<Setter
					Property="Foreground"
					Value="#FF4682B4" />
			</Style>
			<Style
				x:Key="editText"
				TargetType="{x:Type TextBox}">
				<Setter
					Property="Margin"
					Value="5,5,10,0" />
				<Setter
					Property="FontWeight"
					Value="Normal" />
				<Setter
					Property="FontSize"
					Value="12" />
				<Setter
					Property="HorizontalAlignment"
					Value="Left" />
				<Setter
					Property="VerticalAlignment"
					Value="Center" />
			</Style>
			<Style
				x:Key="{x:Type TextBox}"
				TargetType="{x:Type TextBox}">
				<Setter
					Property="Validation.ErrorTemplate">
					<Setter.Value>
						<ControlTemplate>
							<DockPanel
								LastChildFill="True">
								<Border
									BorderBrush="#FFFF0000"
									BorderThickness="1">
									<AdornedElementPlaceholder />
								</Border>
							</DockPanel>
						</ControlTemplate>
					</Setter.Value>
				</Setter>
				<Style.Triggers>
					<Trigger
						Property="Validation.HasError"
						Value="true">
						<Setter
							Property="FrameworkElement.ToolTip"
							Value="{Binding Path=(Validation.Errors)[0].ErrorContent, RelativeSource={RelativeSource Self}}" />
					</Trigger>
				</Style.Triggers>
			</Style>
		</ResourceDictionary>
	</FrameworkElement.Resources>
	<Grid
		Margin="2">
		<Border
			BorderBrush="#FFD3D3D3"
			BorderThickness="1">
			<StackPanel
				VerticalAlignment="Stretch"
				Height="Auto">
				<TextBlock
					Text="MAIN"
					Style="{StaticResource titleText}" />
				<Border
					Margin="5,10,5,5">
					<Grid>
						<FrameworkElement.Resources>
							<ResourceDictionary>
								<Style
									x:Key="inlineText"
									TargetType="{x:Type TextBlock}">
									<Setter
										Property="Margin"
										Value="3,0,2,0" />
									<Setter
										Property="FontWeight"
										Value="Normal" />
									<Setter
										Property="FontSize"
										Value="12" />
									<Setter
										Property="HorizontalAlignment"
										Value="Right" />
									<Setter
										Property="VerticalAlignment"
										Value="Center" />
								</Style>
								<Style
									x:Key="cbInlineText"
									TargetType="{x:Type CheckBox}">
									<Setter
										Property="Margin"
										Value="3,0,2,0" />
									<Setter
										Property="FontWeight"
										Value="Normal" />
									<Setter
										Property="FontSize"
										Value="12" />
									<Setter
										Property="HorizontalAlignment"
										Value="Right" />
									<Setter
										Property="VerticalAlignment"
										Value="Center" />
								</Style>
								<Style
									x:Key="{x:Type DataGridCell}"
									TargetType="{x:Type DataGridCell}">
									<Setter
										Property="Template">
										<Setter.Value>
											<ControlTemplate
												TargetType="{x:Type DataGridCell}">
												<Border
													Padding="4">
													<ContentPresenter />
												</Border>
											</ControlTemplate>
										</Setter.Value>
									</Setter>
								</Style>
								<Style
									x:Key="{x:Type TextBox}"
									TargetType="{x:Type TextBox}">
									<Setter
										Property="Validation.ErrorTemplate">
										<Setter.Value>
											<ControlTemplate>
												<DockPanel
													LastChildFill="True">
													<Border
														BorderBrush="#FFFF0000"
														BorderThickness="1">
														<AdornedElementPlaceholder />
													</Border>
												</DockPanel>
											</ControlTemplate>
										</Setter.Value>
									</Setter>
									<Style.Triggers>
										<Trigger
											Property="Validation.HasError"
											Value="true">
											<Setter
												Property="FrameworkElement.ToolTip"
												Value="{Binding Path=(Validation.Errors)[0].ErrorContent, RelativeSource={RelativeSource Self}}" />
										</Trigger>
									</Style.Triggers>
								</Style>
							</ResourceDictionary>
						</FrameworkElement.Resources>
						<Grid.ColumnDefinitions>
							<ColumnDefinition
								Width="120" />
							<ColumnDefinition
								Width="*" />
						</Grid.ColumnDefinitions>
						<Grid.RowDefinitions>
							<RowDefinition
								Height="35" />
							<RowDefinition
								Height="35" />
							<RowDefinition
								Height="35" />
							<RowDefinition
								Height="35" />
							<RowDefinition
								Height="35" />
							<RowDefinition
								Height="35" />
						</Grid.RowDefinitions>
						<TextBlock
							Grid.Row="0"
							Grid.Column="0"
							Style="{StaticResource inlineText}"
							Text="Elution mode:" />
						<ComboBox
							x:Name="comboExpType"
							Grid.Row="0"
							Grid.Column="1"
							Margin="6,5,7,5"
							VerticalContentAlignment="Center"
							DisplayMemberPath="DisplayName"
							ItemsSource="{Binding ExperimentNames}"
							SelectedItem="{Binding SelectedElutionType, Mode=TwoWay, FallbackValue=Test}" />
						<TextBlock
							Grid.Row="1"
							Grid.Column="0"
							Style="{StaticResource inlineText}"
							Text="Legacy mode:" />
						<CheckBox
							Grid.Row="1"
							Grid.Column="1"
							VerticalAlignment="Center"
							Margin="6,5,7,5"
							IsEnabled="{Binding IsLegacyModeSelectable}"
							IsChecked="{Binding LegacyMode, Mode=TwoWay}" />
						<TextBlock
							Name="tbTrapColumn"
							Grid.Row="2"
							Grid.Column="0"
							Style="{StaticResource inlineText}"
							Text="Trap Column:"
							Visibility="Hidden" />
						<DockPanel
							Name="trapColPanel"
							Grid.Row="2"
							Grid.Column="1">
							<ComboBox
								Name="comboTrapColumn"
								DockPanel.Dock="Bottom"
								Margin="6,5,7,5"
								VerticalContentAlignment="Center"
								Visibility="Hidden"
								Style="{StaticResource ColumnComboBox}"
								SelectionChanged="PreComboBox_SelectionChanged">
								<ItemsControl.ItemContainerStyle>
									<Style
										TargetType="{x:Type ComboBoxItem}">
										<EventSetter
											Event="Loaded"
											Handler="TrapColumnItemLoaded" />
										<EventSetter
											Event="Unloaded"
											Handler="TrapColumnItemUnloaded" />
									</Style>
								</ItemsControl.ItemContainerStyle>
							</ComboBox>
							<Popup
								Placement="Right"
								PopupAnimation="Fade"
								PlacementTarget="{Binding ElementName=trapColPanel}">
								<FrameworkElement.Style>
									<Style
										TargetType="{x:Type Popup}">
										<Style.Triggers>
											<DataTrigger
												Value="True"
												Binding="{Binding IsMouseOver, ElementName=trapColPanel}">
												<TriggerBase.EnterActions>
													<BeginStoryboard>
														<Storyboard>
															<BooleanAnimationUsingKeyFrames
																Storyboard.TargetProperty="IsOpen"
																FillBehavior="HoldEnd">
																<DiscreteBooleanKeyFrame
																	KeyTime="0:0:1"
																	Value="True" />
															</BooleanAnimationUsingKeyFrames>
														</Storyboard>
													</BeginStoryboard>
												</TriggerBase.EnterActions>
												<TriggerBase.ExitActions>
													<BeginStoryboard>
														<Storyboard>
															<BooleanAnimationUsingKeyFrames
																Storyboard.TargetProperty="IsOpen"
																FillBehavior="HoldEnd">
																<DiscreteBooleanKeyFrame
																	KeyTime="0:0:0"
																	Value="False" />
															</BooleanAnimationUsingKeyFrames>
														</Storyboard>
													</BeginStoryboard>
												</TriggerBase.ExitActions>
											</DataTrigger>
										</Style.Triggers>
									</Style>
								</FrameworkElement.Style>
								<Border
									BorderThickness="1"
									SnapsToDevicePixels="True">
									<UIElement.Effect>
										<DropShadowEffect
											ShadowDepth="4" />
									</UIElement.Effect>
									<Border.Background>
										<LinearGradientBrush
											StartPoint="0,0"
											EndPoint="0,1">
											<GradientBrush.GradientStops>
												<GradientStopCollection>
													<GradientStop
														Color="White"
														Offset="0.0" />
													<GradientStop
														Color="LightGray"
														Offset="1.0" />
												</GradientStopCollection>
											</GradientBrush.GradientStops>
										</LinearGradientBrush>
									</Border.Background>
									<Border.BorderBrush>
										<SolidColorBrush
											Color="#FF888888" />
									</Border.BorderBrush>
									<Controls:ColumnInfoUserControl
										x:Name="TrapColumnInfoControl"
										Margin="2" />
								</Border>
							</Popup>
						</DockPanel>
						<TextBlock
							Name="tbSepColumn"
							Grid.Row="3"
							Grid.Column="0"
							Style="{StaticResource inlineText}"
							Text="Separation Column:"
							Visibility="Hidden" />
						<DockPanel
							Name="sepColPanel"
							Grid.Row="3"
							Grid.Column="1">
							<ComboBox
								Name="comboSepColumn"
								DockPanel.Dock="Bottom"
								Margin="6,5,7,5"
								VerticalContentAlignment="Center"
								Visibility="Hidden"
								Style="{StaticResource ColumnComboBox}"
								SelectionChanged="AnalComboBox_SelectionChanged">
								<ItemsControl.ItemContainerStyle>
									<Style
										TargetType="{x:Type ComboBoxItem}">
										<EventSetter
											Event="Loaded"
											Handler="SepColumnItemLoaded" />
										<EventSetter
											Event="Unloaded"
											Handler="SepColumnItemUnloaded" />
									</Style>
								</ItemsControl.ItemContainerStyle>
							</ComboBox>
							<Popup
								Placement="Right"
								PopupAnimation="Fade"
								PlacementTarget="{Binding ElementName=sepColPanel}">
								<FrameworkElement.Style>
									<Style
										TargetType="{x:Type Popup}">
										<Style.Triggers>
											<DataTrigger
												Value="True"
												Binding="{Binding IsMouseOver, ElementName=sepColPanel}">
												<TriggerBase.EnterActions>
													<BeginStoryboard>
														<Storyboard>
															<BooleanAnimationUsingKeyFrames
																Storyboard.TargetProperty="IsOpen"
																FillBehavior="HoldEnd">
																<DiscreteBooleanKeyFrame
																	KeyTime="0:0:1"
																	Value="True" />
															</BooleanAnimationUsingKeyFrames>
														</Storyboard>
													</BeginStoryboard>
												</TriggerBase.EnterActions>
												<TriggerBase.ExitActions>
													<BeginStoryboard>
														<Storyboard>
															<BooleanAnimationUsingKeyFrames
																Storyboard.TargetProperty="IsOpen"
																FillBehavior="HoldEnd">
																<DiscreteBooleanKeyFrame
																	KeyTime="0:0:0"
																	Value="False" />
															</BooleanAnimationUsingKeyFrames>
														</Storyboard>
													</BeginStoryboard>
												</TriggerBase.ExitActions>
											</DataTrigger>
										</Style.Triggers>
									</Style>
								</FrameworkElement.Style>
								<Border
									BorderThickness="1"
									SnapsToDevicePixels="True">
									<UIElement.Effect>
										<DropShadowEffect
											ShadowDepth="4" />
									</UIElement.Effect>
									<Border.Background>
										<LinearGradientBrush
											StartPoint="0,0"
											EndPoint="0,1">
											<GradientBrush.GradientStops>
												<GradientStopCollection>
													<GradientStop
														Color="White"
														Offset="0.0" />
													<GradientStop
														Color="LightGray"
														Offset="1.0" />
												</GradientStopCollection>
											</GradientBrush.GradientStops>
										</LinearGradientBrush>
									</Border.Background>
									<Border.BorderBrush>
										<SolidColorBrush
											Color="#FF888888" />
									</Border.BorderBrush>
									<Controls:ColumnInfoUserControl
										x:Name="SepColumnInfoControl"
										Margin="2" />
								</Border>
							</Popup>
						</DockPanel>
						<StackPanel
							Name="stkOvenTemp"
							Grid.Row="4"
							Grid.ColumnSpan="2"
							Grid.Column="0"
							Orientation="Horizontal"
							HorizontalAlignment="Center"
							Margin="22,0,0,0"
							ToolTip="{Binding TempToolTip}">
							<TextBlock
								Style="{StaticResource inlineText}"
								Text="Set Column Temperature: " />
							<Grid
								VerticalAlignment="Center">
								<Grid.ColumnDefinitions>
									<ColumnDefinition
										Width="Auto"
										MinWidth="50" />
									<ColumnDefinition
										Width="Auto"
										MinWidth="5" />
									<ColumnDefinition
										Width="Auto"
										MinWidth="28" />
									<ColumnDefinition
										Width="Auto" />
								</Grid.ColumnDefinitions>
								<Border
									x:Name="bdrTemperature"
									BorderThickness="2"
									CornerRadius="1"
									Height="26"
									BorderBrush="#00FFFFFF"
									VerticalAlignment="Center">
									<syncfusion:DoubleTextBox
										x:Name="txtOvenTemp"
										NumberDecimalDigits="1"
										Width="45"
										TextAlignment="Right"
										Height="23"
										VerticalAlignment="Center"
										HorizontalAlignment="Left"
										Value="{Binding Path=Method.OvenTemperature, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, NotifyOnSourceUpdated=True, ValidatesOnDataErrors=True, NotifyOnValidationError=True}"
										Validation.Error="Validation_Error"
										ValueChanged="txtOvenTemp_ValueChanged" />
								</Border>
								<TextBlock
									Name="tbDegC"
									Grid.Column="2"
									VerticalAlignment="Center"
									Text="ºC"
									Height="16" />
								<Image
									x:Name="imgTempInfo"
									Grid.Column="3"
									Source="Images/Info.png"
									Height="18"
									HorizontalAlignment="Left"
									VerticalAlignment="Center"
									Visibility="Hidden"
									ToolTip="Set Column Temperature affects the flow rate calculations.&#xA;Even when operating a stand-alone column oven,&#xA;please adjust this value appropriately" />
							</Grid>
						</StackPanel>
						<TextBlock
							Name="tbAnalysisTime"
							Grid.Row="5"
							Grid.Column="0"
							Style="{StaticResource inlineText}"
							Text="Gradient Time:" />
						<StackPanel
							Name="stkGradient"
							Grid.Row="5"
							Grid.Column="1"
							Orientation="Horizontal"
							ToolTip="{Binding AnalysisTimeToolTip}">
							<Grid>
								<Grid.ColumnDefinitions>
									<ColumnDefinition
										Width="Auto"
										MinWidth="50" />
									<ColumnDefinition
										Width="Auto"
										MinWidth="5" />
									<ColumnDefinition
										Width="Auto"
										MinWidth="28" />
								</Grid.ColumnDefinitions>
								<Border
									x:Name="bdrAnalysisTime"
									BorderThickness="2"
									CornerRadius="1"
									Height="26"
									BorderBrush="#00FFFFFF"
									VerticalAlignment="Center">
									<syncfusion:DoubleTextBox
										x:Name="tcGradientTime"
										CornerRadius="0"
										TextSelectionOnFocus="False"
										IsScrollingOnCircle="False"
										Width="45"
										TextAlignment="Right"
										Height="23"
										HorizontalAlignment="Left"
										VerticalAlignment="Center"
										Value="{Binding Path=Method.GradientTime, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
										MouseWheel="GradientTime_MouseWheel"
										ValueChanged="tcGradientTime_ValueChanged" />
								</Border>
								<TextBlock
									Name="tbMin"
									Grid.Column="2"
									VerticalAlignment="Center"
									Text="min"
									Height="16" />
							</Grid>
							<Button
								Name="btnGenerate"
								Style="{StaticResource BalticButtonStyle}"
								Margin="1,5,8,5"
								Visibility="Hidden"
								Click="btnGenerate_Click">
								<StackPanel
									Orientation="Horizontal">
									<Image
										Source="Images/flash_24.png"
										Height="14" />
									<TextBlock
										Text=" Generate" />
								</StackPanel>
							</Button>
						</StackPanel>
						<Button
							Name="btnAdapt"
							Grid.Row="5"
							Grid.Column="0"
							Style="{StaticResource BalticButtonStyle}"
							Width="95"
							Margin="12,5,0,5"
							IsEnabled="False"
							Visibility="Hidden"
							Click="btnAdapt_Click">
							<StackPanel
								Orientation="Horizontal">
								<Image
									Source="Images/reload_20@2x.png"
									Height="18" />
								<TextBlock
									Text=" Adapt" />
							</StackPanel>
						</Button>
						<Button
							Name="btnReset"
							Grid.Row="5"
							Grid.Column="1"
							Style="{StaticResource BalticButtonStyle}"
							Width="95"
							HorizontalAlignment="Center"
							Margin="6,5,0,5"
							Visibility="Hidden"
							Click="btnReset_Click">
							<StackPanel
								Orientation="Horizontal">
								<Image
									Source="Images/reset_20.png"
									Height="18" />
								<TextBlock
									Text=" Reset" />
							</StackPanel>
						</Button>
					</Grid>
				</Border>
				<Grid>
					<Grid.RowDefinitions>
						<RowDefinition
							Height="15" />
						<RowDefinition
							Height="Auto" />
					</Grid.RowDefinitions>
					<Grid.ColumnDefinitions>
						<ColumnDefinition
							Width="68" />
						<ColumnDefinition
							Width="78" />
						<ColumnDefinition
							Width="45" />
						<ColumnDefinition
							Width="*" />
					</Grid.ColumnDefinitions>
					<Line
						Stroke="#FFFF0000"
						X1="45"
						Y1="7"
						X2="68"
						Y2="7"
						Grid.Row="0"
						Grid.Column="0"
						SnapsToDevicePixels="True"
						StrokeThickness="1" />
					<TextBlock
						DockPanel.Dock="Left"
						Grid.Row="0"
						Grid.Column="1"
						Text="Composition"
						Margin="3,0,0,0"
						VerticalAlignment="Center" />
					<Line
						Stroke="#FF32CD32"
						X1="22"
						Y1="7"
						X2="45"
						Y2="7"
						Grid.Row="0"
						Grid.Column="2"
						SnapsToDevicePixels="True" />
					<TextBlock
						DockPanel.Dock="Left"
						Grid.Row="0"
						Grid.Column="3"
						Text="Flow rate"
						Margin="5,0,0,0"
						VerticalAlignment="Center" />
					<DockPanel
						HorizontalAlignment="Stretch"
						VerticalAlignment="Stretch"
						Height="224"
						Margin="0"
						LastChildFill="True"
						Grid.Row="1"
						Grid.Column="0"
						Grid.ColumnSpan="4">
						<chart:SfChart
							x:Name="sfGradientChart"
							Margin="4"
							AreaBorderThickness="0,1,1,1">
							<chart:SfChart.Behaviors>
								<chart:ChartZoomPanBehavior
									x:Name="sfChartBehavior"
									ZoomMode="XY"
									EnablePinchZooming="False"
									ZoomRelativeToCursor="False"
									EnableMouseWheelZooming="True"
									EnableSelectionZooming="True"
									EnablePanning="False" />
							</chart:SfChart.Behaviors>
							<chart:SfChart.PrimaryAxis>
								<chart:NumericalAxis
									Minimum="0"
									FontSize="11"
									Interval="10"
									AxisLineStyle="{StaticResource AxisStyle}"
									MajorTickLineStyle="{StaticResource AxisStyle}"
									MinorTickLineStyle="{StaticResource MinorTickStyle}"
									LabelFormat="N"
									LabelCreated="On_LabelCreated">
									<chart:ChartAxis.Header>
										<TextBlock
											Margin="4"
											Text="Time (min)"
											FontSize="11"
											FontFamily="SegoeUI" />
									</chart:ChartAxis.Header>
								</chart:NumericalAxis>
							</chart:SfChart.PrimaryAxis>
							<chart:SfChart.SecondaryAxis>
								<chart:NumericalAxis
									Minimum="0"
									Maximum="100"
									SmallTicksPerInterval="1"
									Interval="20"
									Margin="1,0,0,0"
									PlotOffset="0.5"
									FontSize="11"
									AxisLineStyle="{StaticResource AxisStyle}"
									MajorTickLineStyle="{StaticResource AxisStyle}"
									MinorTickLineStyle="{StaticResource MinorTickStyle}"
									MinorGridLineStyle="{StaticResource MinorGridLineStyle}"
									LabelFormat="N"
									LabelCreated="On_LabelCreated">
									<chart:ChartAxis.Header>
										<TextBlock
											Margin="4"
											Text="Composition (%B)"
											FontSize="11"
											FontFamily="SegoeUI" />
									</chart:ChartAxis.Header>
								</chart:NumericalAxis>
							</chart:SfChart.SecondaryAxis>
							<chart:FastLineSeries
								ListenPropertyChange="True"
								XBindingPath="Time"
								YBindingPath="Composition"
								Interior="#FFFF0000"
								LegendIcon="SeriesType"
								StrokeThickness="1"
								Height="147"
								VerticalAlignment="Top" />
							<chart:FastLineSeries
								ListenPropertyChange="True"
								XBindingPath="Time"
								YBindingPath="Flow"
								Interior="#FF32CD32"
								LegendIcon="SeriesType"
								StrokeThickness="1">
								<chart:CartesianSeries.YAxis>
									<chart:NumericalAxis
										Name="FlowAxis"
										LabelFormat="N"
										SmallTicksPerInterval="1"
