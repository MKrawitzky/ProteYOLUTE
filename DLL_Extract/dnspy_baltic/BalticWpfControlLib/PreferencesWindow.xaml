<Window
	x:Class="BalticWpfControlLib.PreferencesWindow"
	xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	Title="Preferences"
	ResizeMode="NoResize"
	SizeToContent="WidthAndHeight"
	ShowInTaskbar="False"
	WindowStartupLocation="CenterOwner"
	xmlns:balticwpfcontrollib="clr-namespace:BalticWpfControlLib">
	<Grid
		Name="prefGrid">
		<Grid.RowDefinitions>
			<RowDefinition
				Height="Auto" />
			<RowDefinition
				Height="*" />
			<RowDefinition
				Height="Auto" />
		</Grid.RowDefinitions>
		<Grid.ColumnDefinitions>
			<ColumnDefinition
				Width="*" />
			<ColumnDefinition
				Width="Auto" />
		</Grid.ColumnDefinitions>
		<Button
			Name="btnOK"
			Grid.Column="0"
			Grid.Row="2"
			Content="OK"
			Height="25"
			Width="75"
			HorizontalAlignment="Right"
			VerticalAlignment="Bottom"
			Margin="8,8,4,8"
			IsDefault="True"
			Click="Button_OK_Click" />
		<Button
			Grid.Column="1"
			Grid.Row="2"
			Content="Cancel"
			Height="25"
			Width="75"
			VerticalAlignment="Bottom"
			Margin="4,8,8,8"
			Click="Button_Cancel_Click" />
	</Grid>
</Window>
