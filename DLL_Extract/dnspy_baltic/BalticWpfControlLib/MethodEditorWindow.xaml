<Window
	x:Class="BalticWpfControlLib.MethodEditorWindow"
	xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:local="clr-namespace:BalticWpfControlLib"
	Height="500"
	Width="559"
	Title="Bruker Instant Expertise Method Editor"
	ResizeMode="NoResize"
	Background="{DynamicResource {x:Static SystemColors.ControlBrushKey}}"
	WindowStartupLocation="CenterScreen"
	ShowInTaskbar="False"
	Loaded="OnLoaded"
	Closing="Window_Closing">
	<Grid
		Name="gridMethod">
		<Grid.RowDefinitions>
			<RowDefinition
				Height="*" />
			<RowDefinition
				Height="Auto" />
		</Grid.RowDefinitions>
		<StackPanel
			Name="stkTrapWarn"
			Grid.Row="1"
			Orientation="Horizontal"
			Height="22"
			Margin="4,2,2,0"
			VerticalAlignment="Center">
			<Image
				Source="Images/Warning.png"
				Height="22"
				HorizontalAlignment="Left"
				VerticalAlignment="Center"
				Margin="0,1,0,0" />
			<TextBlock
				x:Name="msgText"
				HorizontalAlignment="Left"
				Margin="2,0,0,0"
				VerticalAlignment="Center"
				Text="&quot;None&quot; trap column selection is not recommended !" />
		</StackPanel>
		<StackPanel
			Orientation="Horizontal"
			Grid.Row="1"
			HorizontalAlignment="Right"
			VerticalAlignment="Bottom">
			<Button
				Name="btnOK"
				Content="OK"
				Width="75"
				Height="22"
				IsDefault="True"
				Margin="0,8,8,4"
				Click="btnOK_Click" />
			<Button
				Name="btnCancel"
				Content="Cancel"
				Width="75"
				Height="22"
				Margin="0,8,4,4"
				IsCancel="True" />
		</StackPanel>
	</Grid>
</Window>
