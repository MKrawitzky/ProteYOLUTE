<ResourceDictionary
	xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
	<ResourceDictionary.MergedDictionaries>
		<ResourceDictionary Source="/BrukerLC.Styling;component/Colors/Brushes.xaml" />
		<ResourceDictionary Source="/BrukerLC.Styling;component/Styles/FrameworkElement.xaml" />
	</ResourceDictionary.MergedDictionaries>
	<Style x:Key="DefaultDiagramControlStyle" TargetType="{x:Type DiagramControl}">
		<Setter Property="HorizontalContentAlignment" Value="Stretch" />
		<Setter Property="VerticalContentAlignment" Value="Stretch" />
		<Setter Property="Background" Value="{StaticResource WhiteBrush}" />
		<Setter Property="Template">
			<Setter.Value>
				<ControlTemplate TargetType="{x:Type DiagramControl}">
					<Viewbox Stretch="Uniform">
						<Canvas Width="500" Height="560" Margin="10,0,0,0"
							HorizontalAlignment="{TemplateBinding Control.HorizontalContentAlignment}"
							VerticalAlignment="{TemplateBinding Control.VerticalContentAlignment}"
							Background="{TemplateBinding Control.Background}">

							<!-- PUMPS -->
							<PumpControl Canvas.Left="5" Canvas.Top="340"
								DataContext="{TemplateBinding DiagramControl.PumpADataContext}"
								PumpOrientation="Left" Title="Pump A Details:" />
							<PumpControl Canvas.Left="265" Canvas.Top="340"
								DataContext="{TemplateBinding DiagramControl.PumpBDataContext}"
								PumpOrientation="Right" Title="Pump B Details:" />

							<TableControl Canvas.Left="-16" Canvas.Top="24"
								DataContext="{TemplateBinding DiagramControl.PumpLogDataContext}"
								Heading="Pump Volume Log" />

							<!-- VALVE A (Pump A) — 75% larger via RenderTransform -->
							<ValveControl Canvas.Left="90" Canvas.Top="350"
								DataContext="{TemplateBinding DiagramControl.ValveDDataContext}"
								ItemsSource="{Binding Path=Connections}"
								RenderTransformOrigin="0.5,0.5">
								<ValveControl.RenderTransform>
									<ScaleTransform ScaleX="1.75" ScaleY="1.75"/>
								</ValveControl.RenderTransform>
							</ValveControl>
							<!-- VALVE B (Pump B) — 75% larger -->
							<ValveControl Canvas.Left="220" Canvas.Top="350"
								DataContext="{TemplateBinding DiagramControl.ValveCDataContext}"
								ItemsSource="{Binding Path=Connections}"
								RenderTransformOrigin="0.5,0.5">
								<ValveControl.RenderTransform>
									<ScaleTransform ScaleX="1.75" ScaleY="1.75"/>
								</ValveControl.RenderTransform>
							</ValveControl>

							<!-- TRAP VALVE — 75% larger -->
							<ValveControl Canvas.Left="360" Canvas.Top="70"
								DataContext="{TemplateBinding DiagramControl.ValveADataContext}"
								ItemsSource="{Binding Path=Connections}"
								RenderTransformOrigin="0.5,0.5">
								<ValveControl.RenderTransform>
									<ScaleTransform ScaleX="1.75" ScaleY="1.75"/>
								</ValveControl.RenderTransform>
							</ValveControl>
							<!-- INJECTION VALVE — 75% larger -->
							<ValveControl Canvas.Left="360" Canvas.Top="160"
								DataContext="{TemplateBinding DiagramControl.ValveBDataContext}"
								ItemsSource="{Binding Path=Connections}"
								RenderTransformOrigin="0.5,0.5">
								<ValveControl.RenderTransform>
									<ScaleTransform ScaleX="1.75" ScaleY="1.75"/>
								</ValveControl.RenderTransform>
							</ValveControl>

							<!-- INJECTION PORT -->
							<InjectionControl Canvas.Left="365" Canvas.Top="20"
								DataContext="{TemplateBinding DiagramControl.InjectionDataContext}" />

							<!-- OUTPUT -->
							<OutputControl Canvas.Left="430" Canvas.Top="82"
								DataContext="{TemplateBinding DiagramControl.OutputDataContext}" />
							<TemperatureControl Canvas.Left="430" Canvas.Top="100"
								DataContext="{TemplateBinding DiagramControl.TemperatureDataContext}" />

							<!-- PRESSURE SENSORS — on pump heads mid body -->
							<Border Canvas.Left="42" Canvas.Top="385" Width="22" Height="20"
								Background="#FF6A6A6A" BorderBrush="#FF404040" BorderThickness="1.5"
								CornerRadius="2" ToolTip="Pressure Sensor A">
								<TextBlock Text="P" FontSize="8" FontWeight="Bold" Foreground="#FFFFFFFF"
									HorizontalAlignment="Center" VerticalAlignment="Center" />
							</Border>
							<Border Canvas.Left="254" Canvas.Top="385" Width="22" Height="20"
								Background="#FF6A6A6A" BorderBrush="#FF404040" BorderThickness="1.5"
								CornerRadius="2" ToolTip="Pressure Sensor B">
								<TextBlock Text="P" FontSize="8" FontWeight="Bold" Foreground="#FFFFFFFF"
									HorizontalAlignment="Center" VerticalAlignment="Center" />
							</Border>

							<!-- FLOW SENSORS — centered between pumps, bottom of pump heads -->
							<SensorControl Canvas.Left="145" Canvas.Top="440"
								DataContext="{TemplateBinding DiagramControl.SensorADataContext}"
								SensorOrientation="Left" />
							<SensorControl Canvas.Left="145" Canvas.Top="415"
								DataContext="{TemplateBinding DiagramControl.SensorBDataContext}"
								SensorOrientation="Left" />

							<!-- MIXING TEE -->
							<Border Canvas.Left="330" Canvas.Top="430" Width="26" Height="26"
								Background="#FF808080" CornerRadius="13"
								BorderBrush="#FF505050" BorderThickness="2" ToolTip="Mixing Tee">
								<TextBlock Text="MT" FontSize="8" FontWeight="Bold"
									Foreground="#FFFFFFFF" HorizontalAlignment="Center"
									VerticalAlignment="Center" />
							</Border>

							<!-- LOOP — big circle on injection valve -->
							<LoopControl Canvas.Left="335" Canvas.Top="162"
								DataContext="{TemplateBinding DiagramControl.LoopDataContext}" />

							<!-- TRAP COLUMN — on trap valve -->
							<TrapControl Canvas.Left="388" Canvas.Top="62"
								DataContext="{TemplateBinding DiagramControl.TrapDataContext}" />

							<!-- PLUG — Valve B P5 -->
							<BlindPlugControl Canvas.Left="208" Canvas.Top="390"
								DataContext="{TemplateBinding DiagramControl.ValveBPlugDataContextDataContext}" />
							<BlindPlugControl Canvas.Left="180" Canvas.Top="310"
								DataContext="{TemplateBinding DiagramControl.ValveAPlugDataContextDataContext}" />

							<!-- PELTIER STACK -->
							<Border Canvas.Left="10" Canvas.Top="30" Width="140" Height="80"
								CornerRadius="4" BorderThickness="1.5" BorderBrush="#FF8090A0"
								ToolTip="Peltier Stack / Sample Cooler">
								<Border.Background>
									<LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
										<GradientStop Color="#FFE0E4EA" Offset="0" />
										<GradientStop Color="#FFC8CED8" Offset="0.5" />
										<GradientStop Color="#FFB0B8C4" Offset="1" />
									</LinearGradientBrush>
								</Border.Background>
								<StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
									<TextBlock Text="Peltier Stack" FontSize="10" FontWeight="SemiBold"
										Foreground="#FF404850" HorizontalAlignment="Center" />
									<TextBlock Text="Sample Cooler" FontSize="8"
										Foreground="#FF607080" HorizontalAlignment="Center" />
								</StackPanel>
							</Border>

							<LineBreakControl Canvas.Left="160" Canvas.Top="430"
								DataContext="{TemplateBinding DiagramControl.LineBreakOnPumpALink1DataContext}" />
							<LineBreakControl Canvas.Left="167" Canvas.Top="430"
								DataContext="{TemplateBinding DiagramControl.LineBreakOnPumpALink2DataContext}" />

							<!-- HIDDEN LINK CONTROLS — zero size, for data binding only -->
							<LinkControlBasic x:Name="PumpAtoValveDTop" Canvas.Left="0" Canvas.Top="0" DataContext="{TemplateBinding DiagramControl.PumpAToValveDTopLinkDataContext}" EndPointLeft="0" EndPointTop="0" PathData="F1 M 0,0 L 0,0" />
							<LinkControlBasic x:Name="PumpAtoValveDBottom" Canvas.Left="0" Canvas.Top="0" DataContext="{TemplateBinding DiagramControl.PumpAToValveDBottomLinkDataContext}" EndPointLeft="0" EndPointTop="0" PathData="F1 M 0,0 L 0,0" />
							<LinkControlBasic x:Name="SolventAtoValveD" Canvas.Left="0" Canvas.Top="0" DataContext="{TemplateBinding DiagramControl.SolventAtoValveDLinkDataContext}" EndPointLeft="0" EndPointTop="0" PathData="F1 M 0,0 L 0,0" />
							<LinkControlBasic x:Name="WasteDtoValveD" Canvas.Left="0" Canvas.Top="0" DataContext="{TemplateBinding DiagramControl.WasteDtoValveDLinkDataContext}" EndPointLeft="0" EndPointTop="0" PathData="F1 M 0,0 L 0,0" />
							<LinkControl x:Name="SensorAtoValveD" Canvas.Left="0" Canvas.Top="0" DataContext="{TemplateBinding DiagramControl.SensorAtoValveDLinkDataContext}" EndPointLeft="0" EndPointTop="0" PathData="F1 M 0,0 L 0,0" />
							<LinkControlBasic x:Name="PumpBtoValveCTop" Canvas.Left="0" Canvas.Top="0" DataContext="{TemplateBinding DiagramControl.PumpBtoValveCTopLinkDataContext}" EndPointLeft="0" EndPointTop="0" PathData="F1 M 0,0 L 0,0" />
							<LinkControlBasic x:Name="PumpBToValveCBottom" Canvas.Left="0" Canvas.Top="0" DataContext="{TemplateBinding DiagramControl.PumpBToValveCBottomLinkDataContext}" EndPointLeft="0" EndPointTop="0" PathData="F1 M 0,0 L 0,0" />
							<LinkControlBasic x:Name="SolventBtoValveC" Canvas.Left="0" Canvas.Top="0" DataContext="{TemplateBinding DiagramControl.SolventBtoValveCTopLinkDataContext}" EndPointLeft="0" EndPointTop="0" PathData="F1 M 0,0 L 0,0" />
							<LinkControlBasic x:Name="WasteCtoValveC" Canvas.Left="0" Canvas.Top="0" DataContext="{TemplateBinding DiagramControl.WasteCtoValveCLinkDataContext}" EndPointLeft="0" EndPointTop="0" PathData="F1 M 0,0 L 0,0" />
							<LinkControl x:Name="SensorBtoValveC" Canvas.Left="0" Canvas.Top="0" DataContext="{TemplateBinding DiagramControl.SensorBtoValveCLinkDataContext}" EndPointLeft="0" EndPointTop="0" PathData="F1 M 0,0 L 0,0" />
							<LinkControl x:Name="SensorAToMid" Canvas.Left="0" Canvas.Top="0" DataContext="{TemplateBinding DiagramControl.SensorAToMidLinkDataContext}" EndPointLeft="0" EndPointTop="0" PathData="F1 M 0,0 L 0,0" />
							<LinkControl x:Name="SensorBToMid" Canvas.Left="0" Canvas.Top="0" DataContext="{TemplateBinding DiagramControl.SensorBToMidLinkDataContext}" EndPointLeft="0" EndPointTop="0" PathData="F1 M 0,0 L 0,0" />
							<LinkControl x:Name="ValveDToValveA" Canvas.Left="0" Canvas.Top="0" DataContext="{TemplateBinding DiagramControl.ValveDToValveALinkDataContext}" EndPointLeft="0" EndPointTop="0" PathData="F1 M 0,0 L 0,0" />
							<LinkControl x:Name="MidToValveB" Canvas.Left="0" Canvas.Top="0" DataContext="{TemplateBinding DiagramControl.MidToValveBLinkDataContext}" EndPointLeft="0" EndPointTop="0" PathData="F1 M 0,0 L 0,0" />
							<LinkControlBasic x:Name="WasteAtoValveA" Canvas.Left="0" Canvas.Top="0" DataContext="{TemplateBinding DiagramControl.WasteAtoValveALinkDataContext}" EndPointLeft="0" EndPointTop="0" PathData="F1 M 0,0 L 0,0" />
							<LinkControlBasic x:Name="WasteBtoValveB" Canvas.Left="0" Canvas.Top="0" DataContext="{TemplateBinding DiagramControl.WasteBtoValveBLinkDataContext}" EndPointLeft="0" EndPointTop="0" PathData="F1 M 0,0 L 0,0" />
							<LinkControl x:Name="ValveAToValeB" Canvas.Left="0" Canvas.Top="0" DataContext="{TemplateBinding DiagramControl.ValveAToValveBLinkDataContext}" EndPointLeft="0" EndPointTop="0" PathData="F1 M 0,0 L 0,0" />
							<LinkControl x:Name="ValveBToOutput" Canvas.Left="0" Canvas.Top="0" DataContext="{TemplateBinding DiagramControl.ValveBToOutputLinkDataContext}" EndPointLeft="0" EndPointTop="0" PathData="F1 M 0,0 L 0,0" />
							<LinkControlBasic x:Name="MidToValveA" Canvas.Left="0" Canvas.Top="0" DataContext="{TemplateBinding DiagramControl.MixTeeToInjectionValveLinkDataContext}" EndPointLeft="0" EndPointTop="0" PathData="F1 M 0,0 L 0,0" />
							<LinkControlBasic x:Name="ValveAToOutput" Canvas.Left="0" Canvas.Top="0" DataContext="{TemplateBinding DiagramControl.InjectionValveToSeparatorLinkDataContext}" EndPointLeft="0" EndPointTop="0" PathData="F1 M 0,0 L 0,0" />
							<LinkControlBasic x:Name="BlingPlugToValveC" Canvas.Left="0" Canvas.Top="0" DataContext="{TemplateBinding DiagramControl.BlingPlugToValveCLinkDataContext}" EndPointLeft="0" EndPointTop="0" PathData="F1 M 0,0 L 0,0" />
							<LinkControlBasic x:Name="ValveDToBlingPlug" Canvas.Left="0" Canvas.Top="0" DataContext="{TemplateBinding DiagramControl.ValveAToPlugLinkDataContext}" EndPointLeft="0" EndPointTop="0" PathData="F1 M 0,0 L 0,0" />
							<Rectangle x:Name="RectangleOnPumpBLink1" Canvas.Left="0" Canvas.Top="0" Width="0" Height="0" Fill="{TemplateBinding Control.Background}" />
							<Rectangle x:Name="RectangleOnPumpBLink2" Canvas.Left="0" Canvas.Top="0" Width="0" Height="0" Fill="{TemplateBinding Control.Background}" />

							<!-- WASTE/SOLVENT — hidden but must exist for data binding -->
							<WasteControl x:Name="WasteD" Canvas.Left="-100" Canvas.Top="0" />
							<WasteControl x:Name="WasteC" Canvas.Left="-100" Canvas.Top="0" />
							<WasteControl x:Name="WasteA" Canvas.Left="-100" Canvas.Top="0" />
							<WasteControl x:Name="WasteB" Canvas.Left="-100" Canvas.Top="0"
								DataContext="{TemplateBinding DiagramControl.WasteBDataContext}" />
							<SolventControl Canvas.Left="-100" Canvas.Top="0"
								DataContext="{TemplateBinding DiagramControl.SolventADataContext}" />
							<SolventControl Canvas.Left="-100" Canvas.Top="0"
								DataContext="{TemplateBinding DiagramControl.SolventBDataContext}" />

						</Canvas>
					</Viewbox>
				</ControlTemplate>
			</Setter.Value>
		</Setter>
	</Style>
</ResourceDictionary>
