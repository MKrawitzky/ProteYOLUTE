<ResourceDictionary
	xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:attached="clr-namespace:BrukerLC.Utils.Attached;assembly=BrukerLC.Utils">
	<ResourceDictionary.MergedDictionaries>
		<ResourceDictionary
			Source="/BrukerLC.Styling;component/Colors/Brushes.xaml" />
		<ResourceDictionary
			Source="/BrukerLC.Styling;component/Styles/FrameworkElement.xaml" />
		<ResourceDictionary
			Source="/BrukerLC.Styling;component/VectorGraphics/Shapes.xaml" />
		<ResourceDictionary
			Source="/BrukerLC.Styling;component/Converters/Converters.xaml" />
	</ResourceDictionary.MergedDictionaries>
	<Style
		x:Key="DefaultSolventControlStyle"
		TargetType="{x:Type SolventControl}"
		BasedOn="{StaticResource FrameworkElementStyle}">
		<Setter
			Property="attached:APActivatable.IsActive"
			Value="{Binding IsActive, FallbackValue=False}" />
		<Setter
			Property="attached:APActivatable.ActiveBrush"
			Value="{Binding ActiveBrush, FallbackValue=Blue}" />
		<Setter
			Property="attached:APValidation.HasError"
			Value="{Binding HasError, FallbackValue=False}" />
		<Setter
			Property="attached:APValidation.ErrorMessage"
			Value="{Binding ErrorMessage}" />
		<Setter
			Property="attached:APVisibleEnableable.IsVisible"
			Value="{Binding IsVisible, FallbackValue=True}" />
		<Setter
			Property="attached:APVisibleEnableable.IsNearTransparent"
			Value="{Binding IsNearTransparent, FallbackValue=False}" />
		<Setter
			Property="Foreground"
			Value="{StaticResource GrayBrush}" />
		<Setter
			Property="Background"
			Value="{StaticResource LightGrayBrush}" />
		<Setter
			Property="BorderBrush"
			Value="{StaticResource DarkGrayBrush}" />
		<Setter
			Property="HorizontalContentAlignment"
			Value="Center" />
		<Setter
			Property="VerticalContentAlignment"
			Value="Center" />
		<Setter
			Property="Template">
			<Setter.Value>
				<ControlTemplate
					TargetType="{x:Type SolventControl}">
					<Grid
						Visibility="{Binding Path=(attached:APVisibleEnableable.IsVisible), Converter={StaticResource VisibilityConverter}, RelativeSource={RelativeSource Self}}"
						Opacity="{Binding Path=(attached:APVisibleEnableable.IsNearTransparent), Converter={StaticResource OpacityConverter}, RelativeSource={RelativeSource Self}}">
						<Border
							Width="29"
							Height="29"
							Background="{TemplateBinding Control.Background}"
							CornerRadius="15">
							<Grid
								HorizontalAlignment="{TemplateBinding Control.HorizontalContentAlignment}"
								VerticalAlignment="{TemplateBinding Control.VerticalContentAlignment}">
								<Rectangle
									Width="10"
									Height="6"
									Margin="-1 7 0 0"
									Fill="{TemplateBinding Control.Foreground}" />
								<Path
									Data="{StaticResource SolventBorderGeometry}"
									Fill="{StaticResource WhiteBrush}" />
								<Path
									Margin="2 -1 0 0"
									Fill="{TemplateBinding Control.BorderBrush}"
									Data="{StaticResource SolventCapGeometry}" />
							</Grid>
						</Border>
					</Grid>
				</ControlTemplate>
			</Setter.Value>
		</Setter>
		<Style.Triggers>
			<Trigger
				Property="attached:APActivatable.IsActive"
				Value="True">
				<Setter
					Property="Foreground"
					Value="{Binding (APActivatable.ActiveBrush), RelativeSource={RelativeSource Self}}" />
			</Trigger>
			<Trigger
				Property="attached:APValidation.HasError"
				Value="True">
				<Setter
					Property="Background"
					Value="{StaticResource ErrorBrush}" />
			</Trigger>
		</Style.Triggers>
	</Style>
</ResourceDictionary>
