<ResourceDictionary
	xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
	<ResourceDictionary.MergedDictionaries>
		<ResourceDictionary
			Source="/BrukerLC.Styling;component/Colors/Brushes.xaml" />
		<ResourceDictionary
			Source="/BrukerLC.Styling;component/Converters/Converters.xaml" />
		<ResourceDictionary
			Source="/BrukerLC.Styling;component/VectorGraphics/Shapes.xaml" />
		<ResourceDictionary
			Source="/BrukerLC.Styling;component/Settings/Typography.xaml" />
		<ResourceDictionary
			Source="/BrukerLC.Styling;component/Styles/FrameworkElement.xaml" />
	</ResourceDictionary.MergedDictionaries>
	<Style
		x:Key="pumpDataText"
		TargetType="{x:Type TextBlock}">
		<Setter
			Property="FontSize"
			Value="11" />
		<Setter
			Property="FontFamily"
			Value="SegoeUI" />
	</Style>
	<Style
		x:Key="pumpTitleText"
		TargetType="{x:Type TextBlock}">
		<Setter
			Property="FontWeight"
			Value="Normal" />
		<Setter
			Property="FontSize"
			Value="12" />
		<Setter
			Property="FontStyle"
			Value="Normal" />
		<Setter
			Property="HorizontalAlignment"
			Value="left" />
	</Style>
	<Style
		x:Key="DefaultMainPumpControlStyle"
		TargetType="{x:Type PumpControl}"
		BasedOn="{StaticResource FrameworkElementStyle}">
		<Setter
			Property="PumpControl.Throughput"
			Value="{Binding Throughput}" />
		<Setter
			Property="PumpControl.ThroughputUnit"
			Value="{Binding ThroughputUnit}" />
		<Setter
			Property="PumpControl.ThroughputSetPoint"
			Value="{Binding ThroughputSetPoint}" />
		<Setter
			Property="PumpControl.Pressure"
			Value="{Binding Pressure}" />
		<Setter
			Property="PumpControl.PressureUnit"
			Value="{Binding PressureUnit}" />
		<Setter
			Property="PumpControl.FillLevel"
			Value="{Binding FillLevel}" />
		<Setter
			Property="PumpControl.VolumeUsed"
			Value="{Binding VolumeUsed}" />
		<Setter
			Property="PumpControl.VolumeLeft"
			Value="{Binding VolumeLeft}" />
		<Setter
			Property="PumpControl.VolumeUnit"
			Value="{Binding VolumeUnit}" />
		<Setter
			Property="PumpControl.Title"
			Value="{Binding Title}" />
		<Setter
			Property="APValidation.HasError"
			Value="{Binding HasError}" />
		<Setter
			Property="APValidation.ErrorMessage"
			Value="{Binding ErrorMessage}" />
		<Setter
			Property="APActivatable.IsActive"
			Value="{Binding IsActive}" />
		<Setter
			Property="APActivatable.ActiveBrush"
			Value="{Binding ActiveBrush}" />
		<Setter
			Property="Width"
			Value="90" />
		<Setter
			Property="VerticalContentAlignment"
			Value="Center" />
		<Setter
			Property="HorizontalContentAlignment"
			Value="Center" />
		<Setter
			Property="BorderThickness"
			Value="3" />
		<Setter
			Property="PumpControl.CornerRadius"
			Value="10" />
		<Setter
			Property="FontSize"
			Value="{StaticResource 10FontSize}" />
		<Setter
			Property="Template">
			<Setter.Value>
				<ControlTemplate
					TargetType="{x:Type PumpControl}">
					<StackPanel>
						<Viewbox
							Name="pumpViewBox"
							Stretch="Uniform">
							<Grid>
								<Grid.RowDefinitions>
									<RowDefinition
										Height="Auto" />
									<RowDefinition
										Height="Auto" />
									<RowDefinition
										Height="Auto" />
								</Grid.RowDefinitions>
								<Grid.ColumnDefinitions>
									<ColumnDefinition
										Width="*" />
								</Grid.ColumnDefinitions>
								<Grid
									x:Name="PressureLabels"
									Row="0"
									VerticalAlignment="{TemplateBinding Control.VerticalContentAlignment}">
									<Grid.ColumnDefinitions>
										<ColumnDefinition
											Width="1*" />
										<ColumnDefinition
											Width="1*" />
									</Grid.ColumnDefinitions>
									<ContentPresenter
										HorizontalAlignment="Right"
										VerticalAlignment="{TemplateBinding Control.VerticalContentAlignment}"
										TextElement.Foreground="#FF000000"
										Content="{TemplateBinding Pressure, ConverterParameter=' 0;-0', Converter={StaticResource DecimalPlacesConverter}}" />
									<TextBlock
										Grid.Column="1"
										Margin="2,0,0,0"
										HorizontalAlignment="Left"
										VerticalAlignment="{TemplateBinding Control.VerticalContentAlignment}"
										Foreground="{TemplateBinding Control.Foreground}"
										Text="{TemplateBinding PumpControl.PressureUnit}" />
								</Grid>
								<Grid
									Width="90"
									Row="1"
									VerticalAlignment="{TemplateBinding Control.VerticalContentAlignment}">
									<Grid.ColumnDefinitions>
										<ColumnDefinition
											Width="*" />
									</Grid.ColumnDefinitions>
									<Grid.RowDefinitions>
										<RowDefinition
											Height="Auto" />
									</Grid.RowDefinitions>
									<Border
										x:Name="PumpBorder"
										Grid.Column="0"
										BorderBrush="{TemplateBinding Control.BorderBrush}"
										BorderThickness="{TemplateBinding Control.BorderThickness}"
										CornerRadius="{TemplateBinding PumpControl.CornerRadius}"
										Background="{TemplateBinding Foreground, Converter={StaticResource ColorOpacityConverter}}">
										<Grid>
											<Grid.ColumnDefinitions>
												<ColumnDefinition
													Width="*" />
												<ColumnDefinition
													Width="Auto" />
												<ColumnDefinition
													Width="Auto" />
											</Grid.ColumnDefinitions>
											<Border
												Height="40"
												Grid.Column="2"
												Margin="0 -1 0 0"
												Background="{TemplateBinding Control.Foreground}"
												CornerRadius="{TemplateBinding PumpControl.CornerRadius}"
												Width="{Binding FillLevel, ConverterParameter=80, Converter={StaticResource HeightToPrecentageConverter}}" />
											<Border
												Grid.Column="0"
												VerticalAlignment="Center"
												Height="8"
												Background="#FF808080" />
											<Path
												Margin="-1,0,0,0"
												Grid.Column="1"
												VerticalAlignment="Center"
												Fill="#FF808080"
												Data="{StaticResource MainPumpGeometry}" />
										</Grid>
									</Border>
									<Border
										x:Name="OuterBorder"
										Grid.Column="0"
										Background="#00FFFFFF"
										BorderBrush="{TemplateBinding Control.BorderBrush}"
										BorderThickness="{TemplateBinding Control.BorderThickness}"
										CornerRadius="{TemplateBinding PumpControl.CornerRadius}" />
								</Grid>
								<Grid
									x:Name="ThroughtputLabels"
									Row="2"
									VerticalAlignment="{TemplateBinding Control.VerticalContentAlignment}"
									Visibility="Hidden">
									<Grid.ColumnDefinitions>
										<ColumnDefinition
											Width="1*" />
										<ColumnDefinition
											Width="1*" />
									</Grid.ColumnDefinitions>
									<ContentPresenter
										Grid.Column="0"
										HorizontalAlignment="Right"
										VerticalAlignment="{TemplateBinding Control.VerticalContentAlignment}"
										TextElement.Foreground="#FF000000"
										Content="{TemplateBinding Throughput, ConverterParameter=' 0.0;-0.0', Converter={StaticResource DecimalPlacesConverter}}" />
									<TextBlock
										Grid.Column="1"
										Margin="2,0,0,0"
										HorizontalAlignment="Left"
										VerticalAlignment="{TemplateBinding Control.VerticalContentAlignment}"
										Foreground="{TemplateBinding Control.Foreground}"
										Text="{TemplateBinding PumpControl.ThroughputUnit}" />
								</Grid>
							</Grid>
						</Viewbox>
						<Popup
							Placement="Right"
							PopupAnimation="Fade"
							PlacementTarget="{Binding ElementName=pumpViewBox}">
							<FrameworkElement.Style>
								<Style
									TargetType="{x:Type Popup}">
									<Style.Triggers>
										<DataTrigger
											Value="True"
											Binding="{Binding IsMouseOver, ElementName=pumpViewBox}">
											<TriggerBase.EnterActions>
												<BeginStoryboard>
													<Storyboard>
														<BooleanAnimationUsingKeyFrames
															Storyboard.TargetProperty="IsOpen"
															FillBehavior="HoldEnd">
															<DiscreteBooleanKeyFrame
																KeyTime="0:0:1"
																Value="True" />
														</BooleanAnimationUsingKeyFrames>
													</Storyboard>
												</BeginStoryboard>
											</TriggerBase.EnterActions>
											<TriggerBase.ExitActions>
												<BeginStoryboard>
													<Storyboard>
														<BooleanAnimationUsingKeyFrames
															Storyboard.TargetProperty="IsOpen"
															FillBehavior="HoldEnd">
															<DiscreteBooleanKeyFrame
																KeyTime="0:0:0"
																Value="False" />
														</BooleanAnimationUsingKeyFrames>
													</Storyboard>
												</BeginStoryboard>
											</TriggerBase.ExitActions>
										</DataTrigger>
									</Style.Triggers>
								</Style>
							</FrameworkElement.Style>
							<Border
								BorderThickness="1"
								SnapsToDevicePixels="True">
								<UIElement.Effect>
									<DropShadowEffect
										ShadowDepth="4" />
								</UIElement.Effect>
								<Border.Background>
									<LinearGradientBrush
										StartPoint="0,0"
										EndPoint="0,1">
										<GradientBrush.GradientStops>
											<GradientStopCollection>
												<GradientStop
													Color="White"
													Offset="0.0" />
												<GradientStop
													Color="LightGray"
													Offset="1.0" />
											</GradientStopCollection>
										</GradientBrush.GradientStops>
									</LinearGradientBrush>
								</Border.Background>
								<Border.BorderBrush>
									<SolidColorBrush
										Color="#FF888888" />
								</Border.BorderBrush>
								<Grid>
									<Grid.RowDefinitions>
										<RowDefinition
											Height="Auto" />
										<RowDefinition
											Height="*" />
										<RowDefinition
											Height="*" />
										<RowDefinition
											Height="*" />
										<RowDefinition
											Height="*" />
									</Grid.RowDefinitions>
									<Grid.ColumnDefinitions>
										<ColumnDefinition
											Width="80" />
										<ColumnDefinition />
									</Grid.ColumnDefinitions>
									<TextBlock
										Grid.ColumnSpan="2"
										Text="{TemplateBinding PumpControl.Title}"
										Margin="2,2,2,4"
										Style="{StaticResource pumpTitleText}" />
									<TextBlock
										Grid.Row="1"
										Text="Set Flow:"
										Margin="8,1,1,2"
										Style="{StaticResource pumpDataText}" />
									<StackPanel
										Grid.Row="1"
										Grid.Column="1"
										Orientation="Horizontal"
										Margin="4,1,1,2">
										<TextBlock
											Style="{StaticResource pumpDataText}"
											Text="{TemplateBinding ThroughputSetPoint, ConverterParameter=' 0.0;-0.0', Converter={StaticResource DecimalPlacesConverter}}" />
										<TextBlock
											Text="{TemplateBinding PumpControl.ThroughputUnit}"
											Margin="2,0,0,0"
											Style="{StaticResource pumpDataText}" />
									</StackPanel>
									<TextBlock
										Grid.Row="2"
										Text="Pressure:"
										Margin="8,1,1,2"
										Style="{StaticResource pumpDataText}" />
									<StackPanel
										Grid.Row="2"
										Grid.Column="1"
										Orientation="Horizontal"
										Margin="4,1,1,2">
										<TextBlock
											Style="{StaticResource pumpDataText}"
											Text="{TemplateBinding Pressure, ConverterParameter=' 0;-0', Converter={StaticResource DecimalPlacesConverter}}" />
										<TextBlock
											Text="{TemplateBinding PumpControl.PressureUnit}"
											Margin="2,0,0,0"
											Style="{StaticResource pumpDataText}" />
									</StackPanel>
									<TextBlock
										Grid.Row="3"
										Text="Volume Used:"
										Margin="8,1,1,2"
										Style="{StaticResource pumpDataText}" />
									<StackPanel
										Grid.Row="3"
										Grid.Column="1"
										Orientation="Horizontal"
										Margin="4,1,1,2">
										<TextBlock
											Style="{StaticResource pumpDataText}"
											Text="{TemplateBinding VolumeUsed, ConverterParameter=' 0.0;-0.0', Converter={StaticResource DecimalPlacesConverter}}" />
										<TextBlock
											Text="{TemplateBinding PumpControl.VolumeUnit}"
											Margin="2,0,0,0"
											Style="{StaticResource pumpDataText}" />
									</StackPanel>
									<TextBlock
										Grid.Row="4"
										Text="Volume Left:"
										Margin="8,1,1,2"
										Style="{StaticResource pumpDataText}" />
									<StackPanel
										Grid.Row="4"
										Grid.Column="1"
										Orientation="Horizontal"
										Margin="4,1,1,2">
										<TextBlock
											Style="{StaticResource pumpDataText}"
											Text="{TemplateBinding VolumeLeft, ConverterParameter=' 0.0;-0.0', Converter={StaticResource DecimalPlacesConverter}}" />
										<TextBlock
											Text="{TemplateBinding PumpControl.VolumeUnit}"
											Margin="2,0,0,0"
											Style="{StaticResource pumpDataText}" />
									</StackPanel>
								</Grid>
							</Border>
						</Popup>
					</StackPanel>
				</ControlTemplate>
			</Setter.Value>
		</Setter>
		<Style.Triggers>
			<Trigger
				Property="APActivatable.IsActive"
				Value="True">
				<Setter
					Property="Foreground"
					Value="{Binding (APActivatable.ActiveBrush), RelativeSource={RelativeSource Self}}" />
				<Setter
					Property="BorderBrush"
					Value="{StaticResource LightGrayBrush}" />
			</Trigger>
			<Trigger
				Property="APValidation.HasError"
				Value="True">
				<Setter
					Property="Foreground"
					Value="{StaticResource GrayBrush}" />
				<Setter
					Property="Background"
					Value="{StaticResource LightGrayBrush}" />
				<Setter
					Property="BorderBrush"
					Value="{StaticResource ErrorBrush}" />
			</Trigger>
		</Style.Triggers>
	</Style>
	<Style
		x:Key="MainPumpControlAStyle"
		TargetType="{x:Type PumpControl}"
		BasedOn="{StaticResource DefaultMainPumpControlStyle}">
		<Style.Triggers>
			<Trigger
				Property="APActivatable.IsActive"
				Value="True">
				<Setter
					Property="Foreground"
					Value="{Binding (APActivatable.ActiveBrush), RelativeSource={RelativeSource Self}}" />
				<Setter
					Property="BorderBrush"
					Value="{StaticResource LightGrayBrush}" />
				<Setter
					Property="Background"
					Value="{StaticResource BlueBrush_30}" />
			</Trigger>
		</Style.Triggers>
	</Style>
	<Style
		x:Key="MainPumpControlBStyle"
		TargetType="{x:Type PumpControl}"
		BasedOn="{StaticResource DefaultMainPumpControlStyle}">
		<Style.Triggers>
			<Trigger
				Property="APActivatable.IsActive"
				Value="True">
				<Setter
					Property="Foreground"
					Value="{Binding (APActivatable.ActiveBrush), RelativeSource={RelativeSource Self}}" />
				<Setter
					Property="BorderBrush"
					Value="{StaticResource LightGrayBrush}" />
				<Setter
					Property="Background"
					Value="{StaticResource BlueBrush_30}" />
			</Trigger>
		</Style.Triggers>
	</Style>
</ResourceDictionary>
