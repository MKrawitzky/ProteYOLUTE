<ResourceDictionary
	xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
	<ResourceDictionary.MergedDictionaries>
		<ResourceDictionary
			Source="/BrukerLC.Styling;component/Colors/Brushes.xaml" />
		<ResourceDictionary
			Source="/BrukerLC.Styling;component/Styles/FrameworkElement.xaml" />
		<ResourceDictionary
			Source="/BrukerLC.Styling;component/VectorGraphics/Shapes.xaml" />
		<ResourceDictionary
			Source="/BrukerLC.Styling;component/Converters/Converters.xaml" />
	</ResourceDictionary.MergedDictionaries>
	<Style
		x:Key="DefaultCapillaryControlStyle"
		TargetType="{x:Type CapillaryControl}"
		BasedOn="{StaticResource FrameworkElementStyle}">
		<Setter
			Property="CapillaryControl.Length"
			Value="{Binding Length, FallbackValue=1}" />
		<Setter
			Property="CapillaryControl.LengthUnit"
			Value="{Binding LengthUnit}" />
		<Setter
			Property="CapillaryControl.ID"
			Value="{Binding ID, FallbackValue=1}" />
		<Setter
			Property="CapillaryControl.IDUnit"
			Value="{Binding IDUnit}" />
		<Setter
			Property="CapillaryControl.PathData"
			Value="{Binding PathData}" />
		<Setter
			Property="CapillaryControl.Heading"
			Value="{Binding Heading}" />
		<Setter
			Property="APActivatable.IsActive"
			Value="{Binding IsActive, FallbackValue=False}" />
		<Setter
			Property="APActivatable.ActiveBrush"
			Value="{Binding ActiveBrush, FallbackValue=Blue}" />
		<Setter
			Property="APValidation.HasError"
			Value="{Binding HasError, FallbackValue=False}" />
		<Setter
			Property="APValidation.ErrorMessage"
			Value="{Binding ErrorMessage}" />
		<Setter
			Property="Foreground"
			Value="{StaticResource BlackBrush}" />
		<Setter
			Property="Background"
			Value="{StaticResource WhiteBrush}" />
		<Setter
			Property="BorderBrush"
			Value="{StaticResource BlackBrush}" />
		<Setter
			Property="HorizontalContentAlignment"
			Value="Center" />
		<Setter
			Property="VerticalContentAlignment"
			Value="Center" />
		<Setter
			Property="Template">
			<Setter.Value>
				<ControlTemplate
					TargetType="{x:Type CapillaryControl}">
					<Grid
						HorizontalAlignment="Left"
						VerticalAlignment="Top">
						<Path
							Data="{TemplateBinding CapillaryControl.PathData}"
							Stroke="{TemplateBinding Control.Background}"
							StrokeThickness="1"
							Fill="#FFF8F8FF">
							<UIElement.Effect>
								<DropShadowEffect
									ShadowDepth="3"
									Direction="330"
									Color="Black"
									Opacity="0.7"
									BlurRadius="4" />
							</UIElement.Effect>
						</Path>
						<Grid
							HorizontalAlignment="Left"
							VerticalAlignment="Top">
							<Grid
								x:Name="capillaryData"
								Margin="4,2,0,0"
								VerticalAlignment="Top"
								HorizontalAlignment="Left">
								<Grid.ColumnDefinitions>
									<ColumnDefinition
										Width="Auto" />
									<ColumnDefinition
										Width="Auto" />
									<ColumnDefinition
										Width="Auto" />
								</Grid.ColumnDefinitions>
								<Grid.RowDefinitions>
									<RowDefinition
										Height="*" />
									<RowDefinition
										Height="Auto" />
									<RowDefinition
										Height="Auto" />
								</Grid.RowDefinitions>
								<TextBlock
									Grid.ColumnSpan="3"
									Text="{TemplateBinding CapillaryControl.Heading}"
									FontSize="9"
									Margin="4,2,0,0"
									Foreground="#0071BC" />
								<TextBlock
									Grid.Row="1"
									HorizontalAlignment="Right"
									Margin="8,2,0,0"
									Foreground="#FF000000"
									Text="Length:"
									FontSize="10"
									VerticalAlignment="Center" />
								<ContentPresenter
									Grid.Row="1"
									Grid.Column="1"
									Margin="2,2,0,0"
									HorizontalAlignment="Left"
									VerticalAlignment="Center"
									Content="{TemplateBinding CapillaryControl.Length}"
									TextElement.Foreground="#FF000000"
									TextElement.FontSize="10" />
								<TextBlock
									Grid.Row="1"
									Grid.Column="2"
									HorizontalAlignment="Left"
									VerticalAlignment="Center"
									Margin="2,2,0,0"
									Foreground="#FF000000"
									Text="{TemplateBinding CapillaryControl.LengthUnit}"
									FontSize="10" />
								<TextBlock
									Grid.Row="2"
									HorizontalAlignment="Right"
									VerticalAlignment="Center"
									Margin="8,0,0,0"
									Foreground="#FF000000"
									Text="ID:"
									FontSize="10" />
								<ContentPresenter
									Grid.Row="2"
									Grid.Column="1"
									Margin="2,0,0,0"
									HorizontalAlignment="Left"
									VerticalAlignment="Center"
									Content="{TemplateBinding CapillaryControl.ID}"
									TextElement.Foreground="#FF000000"
									TextElement.FontSize="10" />
								<TextBlock
									Grid.Row="2"
									Grid.Column="2"
									HorizontalAlignment="Left"
									VerticalAlignment="Center"
									Margin="2,0,0,0"
									Foreground="#FF000000"
									Text="{TemplateBinding CapillaryControl.IDUnit}"
									FontSize="10" />
							</Grid>
						</Grid>
					</Grid>
				</ControlTemplate>
			</Setter.Value>
		</Setter>
		<Style.Triggers>
			<Trigger
				Property="APActivatable.IsActive"
				Value="True">
				<Setter
					Property="Foreground"
					Value="{Binding (APActivatable.ActiveBrush), RelativeSource={RelativeSource Self}}" />
			</Trigger>
			<Trigger
				Property="APValidation.HasError"
				Value="True">
				<Setter
					Property="Background"
					Value="{StaticResource ErrorBrush}" />
			</Trigger>
		</Style.Triggers>
	</Style>
</ResourceDictionary>
