<Window x:Class="DiagramEditor.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ProteYOLUTE Schematic Editor - by Michael Krawitzky"
        Width="1400" Height="950" WindowStartupLocation="CenterScreen"
        Background="#FF1E1E1E" KeyDown="Window_KeyDown">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="170"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="280"/>
        </Grid.ColumnDefinitions>

        <!-- LEFT: Palette -->
        <Border Grid.Column="0" Background="#FF2D2D30" Margin="4">
            <DockPanel>
                <TextBlock DockPanel.Dock="Top" Text="ADD" Foreground="#FFCCCCCC" FontWeight="Bold" Margin="8,8,8,4" FontSize="11"/>
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel x:Name="palette" Margin="4"/>
                </ScrollViewer>
            </DockPanel>
        </Border>

        <!-- CENTER: Canvas -->
        <Border Grid.Column="1" Background="#FF333337" Margin="4" ClipToBounds="True">
            <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
                <Viewbox Stretch="Uniform" Margin="10">
                    <Border Background="White" BorderBrush="#FF555555" BorderThickness="2">
                        <Canvas x:Name="editorCanvas" Width="600" Height="600"
                                MouseLeftButtonDown="Canvas_MouseLeftButtonDown"
                                MouseMove="Canvas_MouseMove"
                                MouseLeftButtonUp="Canvas_MouseLeftButtonUp"
                                MouseRightButtonDown="Canvas_RightClick"
                                Background="White"/>
                    </Border>
                </Viewbox>
            </ScrollViewer>
        </Border>

        <!-- RIGHT: Tools -->
        <Border Grid.Column="2" Background="#FF2D2D30" Margin="4">
            <DockPanel>
                <!-- Bottom buttons -->
                <StackPanel DockPanel.Dock="Bottom" Margin="8,4">
                    <Button Content="SAVE" Click="Save_Click" Background="#FF0078D4" Foreground="White" Padding="6,3" Margin="0,2" FontWeight="Bold"/>
                    <Button Content="EXPORT" Click="ExportXaml_Click" Background="#FF005A9E" Foreground="White" Padding="6,3" Margin="0,2" FontWeight="Bold"/>
                    <Button Content="BUILD &amp; DEPLOY" Click="BuildDeploy_Click" Background="#FF107C10" Foreground="White" Padding="6,3" Margin="0,2" FontWeight="Bold"/>
                    <Button Content="DELETE SELECTED" Click="DeleteSelected_Click" Background="#FFC42B1C" Foreground="White" Padding="6,3" Margin="0,2" FontWeight="Bold"/>
                    <Button Content="UNDO LAST TUBING" Click="UndoTubing_Click" Background="#FF884400" Foreground="White" Padding="6,3" Margin="0,2" FontWeight="Bold"/>
                </StackPanel>

                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="8">
                        <!-- Info -->
                        <TextBlock x:Name="txtSelected" Text="Click a component or port" Foreground="#FFAAAAAA" TextWrapping="Wrap" FontSize="10"/>
                        <TextBlock x:Name="txtCoords" Text="" Foreground="#FF00CC00" FontFamily="Consolas" FontSize="9" Margin="0,4,0,0"/>

                        <!-- Z-Order -->
                        <TextBlock Text="LAYER" Foreground="#FFCCCCCC" FontWeight="Bold" Margin="0,8,0,2" FontSize="10"/>
                        <WrapPanel Margin="0,2">
                            <Button Content="▲ Front" Click="BringFront_Click" Width="60" Margin="1" Background="#FF555555" Foreground="White" FontSize="9"/>
                            <Button Content="▼ Back" Click="SendBack_Click" Width="60" Margin="1" Background="#FF555555" Foreground="White" FontSize="9"/>
                            <Button Content="△ Up" Click="BringUp_Click" Width="48" Margin="1" Background="#FF555555" Foreground="White" FontSize="9"/>
                            <Button Content="▽ Down" Click="SendDown_Click" Width="48" Margin="1" Background="#FF555555" Foreground="White" FontSize="9"/>
                        </WrapPanel>

                        <!-- Resize -->
                        <TextBlock Text="RESIZE" Foreground="#FFCCCCCC" FontWeight="Bold" Margin="0,8,0,2" FontSize="10"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="W:" Foreground="#FFAAAAAA" VerticalAlignment="Center" Margin="0,0,3,0" FontSize="10"/>
                            <TextBox x:Name="txtWidth" Grid.Column="1" Background="#FF3A3A3C" Foreground="White" BorderBrush="#FF555555" Margin="0,1" FontSize="10" TextChanged="Size_TextChanged"/>
                            <TextBlock Text="H:" Grid.Column="2" Foreground="#FFAAAAAA" VerticalAlignment="Center" Margin="6,0,3,0" FontSize="10"/>
                            <TextBox x:Name="txtHeight" Grid.Column="3" Background="#FF3A3A3C" Foreground="White" BorderBrush="#FF555555" Margin="0,1" FontSize="10" TextChanged="Size_TextChanged"/>
                        </Grid>
                        <WrapPanel Margin="0,3">
                            <Button Content="-25%" Click="ShrinkBtn_Click" Width="48" Margin="1" Background="#FF555555" Foreground="White" FontSize="9"/>
                            <Button Content="+25%" Click="GrowBtn_Click" Width="48" Margin="1" Background="#FF555555" Foreground="White" FontSize="9"/>
                            <Button Content="+50%" Click="Grow50Btn_Click" Width="48" Margin="1" Background="#FF555555" Foreground="White" FontSize="9"/>
                            <Button Content="x2" Click="DoubleBtn_Click" Width="48" Margin="1" Background="#FF555555" Foreground="White" FontSize="9"/>
                        </WrapPanel>

                        <!-- Tubing -->
                        <TextBlock Text="TUBING" Foreground="#FFCCCCCC" FontWeight="Bold" Margin="0,8,0,2" FontSize="10"/>
                        <TextBlock Text="Mode:" Foreground="#FF888888" FontSize="9"/>
                        <WrapPanel Margin="0,2">
                            <RadioButton x:Name="rbModeDrag" Content="Drag" Foreground="#FFCCCCCC" Margin="0,0,8,0" IsChecked="True" GroupName="Mode" FontSize="9"/>
                            <RadioButton x:Name="rbModeTube" Content="Draw Tubing" Foreground="#FF00CC00" Margin="0,0,8,0" GroupName="Mode" FontSize="9"/>
                        </WrapPanel>
                        <TextBlock Text="Width:" Foreground="#FF888888" FontSize="9" Margin="0,3,0,0"/>
                        <WrapPanel Margin="0,1">
                            <RadioButton x:Name="rbThin" Content="Thin" Foreground="#FFCCCCCC" Margin="0,0,6,0" IsChecked="True" FontSize="9"/>
                            <RadioButton x:Name="rbMedium" Content="Med" Foreground="#FFCCCCCC" Margin="0,0,6,0" FontSize="9"/>
                            <RadioButton x:Name="rbThick" Content="Thick" Foreground="#FFCCCCCC" FontSize="9"/>
                        </WrapPanel>
                        <TextBlock Text="Color:" Foreground="#FF888888" FontSize="9" Margin="0,3,0,0"/>
                        <WrapPanel Margin="0,1">
                            <RadioButton x:Name="rbColorGray" Content="Gray" Foreground="Gray" Margin="0,0,5,0" IsChecked="True" GroupName="TC" FontSize="9"/>
                            <RadioButton x:Name="rbColorBlue" Content="Blue" Foreground="#FF4488CC" Margin="0,0,5,0" GroupName="TC" FontSize="9"/>
                            <RadioButton x:Name="rbColorRed" Content="Red" Foreground="#FFCC4444" Margin="0,0,5,0" GroupName="TC" FontSize="9"/>
                            <RadioButton x:Name="rbColorGreen" Content="Grn" Foreground="#FF44AA44" Margin="0,0,5,0" GroupName="TC" FontSize="9"/>
                            <RadioButton x:Name="rbColorPurple" Content="Prpl" Foreground="#FF8844CC" GroupName="TC" FontSize="9"/>
                        </WrapPanel>
                        <TextBlock Text="Click ports or canvas to place waypoints." Foreground="#FF666666" FontSize="8" Margin="0,4,0,0" TextWrapping="Wrap"/>
                        <TextBlock Text="Press ENTER to finish, ESC to cancel." Foreground="#FF666666" FontSize="8" TextWrapping="Wrap"/>

                        <!-- Instructions -->
                        <TextBlock Text="TIPS" Foreground="#FFCCCCCC" FontWeight="Bold" Margin="0,10,0,2" FontSize="10"/>
                        <TextBlock Foreground="#FF888888" FontSize="8" TextWrapping="Wrap"
                            Text="• Drag mode: move components&#10;• Draw Tubing mode: click waypoints, ENTER to finish&#10;• Right-click port for info&#10;• Valves show 6 ports with rotor grooves&#10;• ESC cancels tubing"/>
                    </StackPanel>
                </ScrollViewer>
            </DockPanel>
        </Border>
    </Grid>
</Window>
