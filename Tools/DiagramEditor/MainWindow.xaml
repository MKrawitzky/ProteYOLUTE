<Window x:Class="DiagramEditor.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ProteYOLUTE Diagram Editor - by Michael Krawitzky"
        Width="1200" Height="800" WindowStartupLocation="CenterScreen"
        Background="#FF1E1E1E">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="250"/>
        </Grid.ColumnDefinitions>

        <!-- LEFT: Component Palette -->
        <Border Grid.Column="0" Background="#FF2D2D30" Margin="4">
            <DockPanel>
                <TextBlock DockPanel.Dock="Top" Text="COMPONENTS" Foreground="#FFCCCCCC"
                           FontWeight="Bold" Margin="8" FontSize="12"/>
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel x:Name="palette" Margin="4">
                        <!-- Populated in code -->
                    </StackPanel>
                </ScrollViewer>
            </DockPanel>
        </Border>

        <!-- CENTER: Canvas Editor -->
        <Border Grid.Column="1" Background="#FF333337" Margin="4" ClipToBounds="True">
            <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
                <Viewbox Stretch="Uniform" Margin="10">
                    <Border Background="White" BorderBrush="#FF555555" BorderThickness="2">
                        <Canvas x:Name="editorCanvas" Width="455" Height="535"
                                MouseLeftButtonDown="Canvas_MouseLeftButtonDown"
                                MouseMove="Canvas_MouseMove"
                                MouseLeftButtonUp="Canvas_MouseLeftButtonUp"
                                Background="White">
                        </Canvas>
                    </Border>
                </Viewbox>
            </ScrollViewer>
        </Border>

        <!-- RIGHT: Properties Panel -->
        <Border Grid.Column="2" Background="#FF2D2D30" Margin="4">
            <DockPanel>
                <TextBlock DockPanel.Dock="Top" Text="PROPERTIES" Foreground="#FFCCCCCC"
                           FontWeight="Bold" Margin="8" FontSize="12"/>
                <StackPanel DockPanel.Dock="Bottom" Margin="8">
                    <Button Content="EXPORT XAML" Click="ExportXaml_Click"
                            Background="#FF0078D4" Foreground="White" Padding="8,4" Margin="0,4"
                            FontWeight="Bold"/>
                    <Button Content="BUILD &amp; DEPLOY" Click="BuildDeploy_Click"
                            Background="#FF107C10" Foreground="White" Padding="8,4" Margin="0,4"
                            FontWeight="Bold"/>
                    <Button Content="ADD CUSTOM" Click="AddCustom_Click"
                            Background="#FF6A00B0" Foreground="White" Padding="8,4" Margin="0,4"
                            FontWeight="Bold"/>
                    <Button Content="ADD TUBING" Click="AddTubing_Click"
                            Background="#FF8A6000" Foreground="White" Padding="8,4" Margin="0,4"
                            FontWeight="Bold"/>
                    <Button Content="DELETE SELECTED" Click="DeleteSelected_Click"
                            Background="#FFC42B1C" Foreground="White" Padding="8,4" Margin="0,4"
                            FontWeight="Bold"/>
                </StackPanel>
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel x:Name="propsPanel" Margin="8">
                        <TextBlock x:Name="txtSelected" Text="Nothing selected"
                                   Foreground="#FFAAAAAA" TextWrapping="Wrap"/>
                        <TextBlock x:Name="txtCoords" Text="" Foreground="#FF00CC00"
                                   FontFamily="Consolas" Margin="0,8,0,0"/>
                    </StackPanel>
                </ScrollViewer>
            </DockPanel>
        </Border>
    </Grid>
</Window>
