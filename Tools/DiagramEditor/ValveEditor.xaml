<Window x:Class="DiagramEditor.ValveEditor"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ProteYOLUTE Valve Port Editor" Width="900" Height="700"
        WindowStartupLocation="CenterScreen" Background="#FF1E1E1E">
    <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
        <StackPanel>
            <TextBlock Text="6-Port Valve Editor — Click ports to assign connections"
                       Foreground="White" FontSize="14" FontWeight="Bold" Margin="20,10"/>
            <WrapPanel Margin="10">
                <!-- Valve A -->
                <Border Margin="10" Padding="10" Background="#FF2D2D30" CornerRadius="5">
                    <StackPanel>
                        <TextBlock Text="VALVE A (Pump A)" Foreground="#FF6699FF" FontWeight="Bold" FontSize="13" HorizontalAlignment="Center"/>
                        <Canvas x:Name="canvasA" Width="250" Height="250" Background="#FF333337" Margin="5"/>
                    </StackPanel>
                </Border>
                <!-- Valve B -->
                <Border Margin="10" Padding="10" Background="#FF2D2D30" CornerRadius="5">
                    <StackPanel>
                        <TextBlock Text="VALVE B (Pump B)" Foreground="#FFFF6666" FontWeight="Bold" FontSize="13" HorizontalAlignment="Center"/>
                        <Canvas x:Name="canvasB" Width="250" Height="250" Background="#FF333337" Margin="5"/>
                    </StackPanel>
                </Border>
                <!-- Injection Valve -->
                <Border Margin="10" Padding="10" Background="#FF2D2D30" CornerRadius="5">
                    <StackPanel>
                        <TextBlock Text="INJECTION VALVE (I)" Foreground="#FFAADDAA" FontWeight="Bold" FontSize="13" HorizontalAlignment="Center"/>
                        <Canvas x:Name="canvasI" Width="250" Height="250" Background="#FF333337" Margin="5"/>
                    </StackPanel>
                </Border>
                <!-- Trap Valve -->
                <Border Margin="10" Padding="10" Background="#FF2D2D30" CornerRadius="5">
                    <StackPanel>
                        <TextBlock Text="TRAP VALVE (T)" Foreground="#FFFFCC66" FontWeight="Bold" FontSize="13" HorizontalAlignment="Center"/>
                        <Canvas x:Name="canvasT" Width="250" Height="250" Background="#FF333337" Margin="5"/>
                    </StackPanel>
                </Border>
            </WrapPanel>
            <TextBlock x:Name="txtStatus" Text="" Foreground="#FF00CC00" FontFamily="Consolas" Margin="20,5" TextWrapping="Wrap"/>
        </StackPanel>
    </ScrollViewer>
</Window>
